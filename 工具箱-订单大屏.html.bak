<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>订单双率看板 · 精准匹配版</title>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', monospace; }
        body { background: radial-gradient(circle at 20% 30%, #020617, #000); height: 100vh; overflow: hidden; color: #e2e8f0; }
        .app { display: flex; height: 100vh; }
        .right-panel {
            position: fixed; right: 0; top: 0; width: 400px; height: 100%;
            background: rgba(8,12,25,0.95); backdrop-filter: blur(16px);
            border-left: 1px solid rgba(0,255,255,0.5); z-index: 30;
            transform: translateX(0); transition: transform 0.3s;
            display: flex; flex-direction: column; padding: 15px; gap: 15px;
            overflow-y: auto;
        }
        .right-panel.hide { transform: translateX(100%); }
        .panel-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #2f6f9f; }
        .panel-header h3 { color: #0cf; }
        .toggle-btn { background: none; border: none; color: #0cf; font-size: 1.2rem; cursor: pointer; }
        .file-btn, .btn { background: #1e2a47; border: 1px solid #3c6e9e; padding: 6px 12px; border-radius: 40px; cursor: pointer; font-size: 0.75rem; text-align: center; color: #fff; }
        .btn-primary { background: #0f3b5c; border-color: #0cf; }
        .btn-warning { background: #5a3e1a; border-color: #ffaa66; }
        .btn-export-result { background: #2a5a4a; border-color: #66ffaa; }
        .main-area { flex: 1; padding: 15px; overflow-y: auto; transition: margin-right 0.3s; margin-right: 0; }
        .main-area.shift { margin-right: 400px; }
        .stats, .stats-row2 { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
        .stat-card { background: rgba(8,12,30,0.7); backdrop-filter: blur(8px); border-radius: 20px; border: 1px solid rgba(0,255,255,0.3); flex: 1; min-width: 100px; padding: 6px 10px; cursor: pointer; }
        .stat-label { font-size: 0.65rem; color: #7da2cc; }
        .stat-value { font-size: 1.2rem; font-weight: 700; }
        .filter-area { background: rgba(8,12,30,0.6); border-radius: 20px; margin-bottom: 16px; border: 1px solid rgba(0,255,255,0.3); padding: 12px; }
        .filter-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
        .customer-box { display: flex; flex-wrap: wrap; gap: 8px; max-height: 200px; overflow-y: auto; padding: 4px 0; }
        .customer-check { background: rgba(0,0,0,0.3); border-radius: 20px; padding: 2px 8px; font-size: 0.7rem; white-space: nowrap; }
        .customer-check input { margin-right: 4px; vertical-align: middle; }
        .req-row { display: flex; align-items: center; gap: 12px; margin-top: 8px; flex-wrap: wrap; }
        .req-wrapper { position: relative; flex: 2; min-width: 200px; }
        .req-wrapper input { width: 100%; background: #1e2a47; border: 1px solid #3c6e9e; padding: 6px 12px; border-radius: 20px; color: white; font-size: 0.75rem; }
        .suggest-dropdown {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: #1e2a47;
            border: 1px solid #3c6e9e;
            border-radius: 8px;
            max-height: 200px;
            overflow-y: auto;
            z-index: 1000;
            display: none;
        }
        .suggest-dropdown div { padding: 6px 10px; cursor: pointer; font-size: 0.7rem; color: #fff; }
        .suggest-dropdown div:hover { background: #2a3a5a; }
        .table-wrapper { background: rgba(0,0,0,0.55); backdrop-filter: blur(8px); border-radius: 20px; border: 1px solid rgba(0,255,255,0.3); overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; font-size: 0.7rem; white-space: nowrap; }
        th, td { padding: 6px 8px; text-align: left; border-bottom: 1px solid #2f6080; }
        th { background: #1e2a47; cursor: pointer; color: #fff; }
        tr:hover { background: rgba(0,160,255,0.1); }
        .rate-100 { background: rgba(220,53,69,0.25); }
        .rate-90 { background: rgba(13,110,253,0.25); }
        .rate-80 { background: rgba(25,135,84,0.25); }
        .diff-highlight { background: rgba(255,165,0,0.25); border-left: 3px solid #ffaa44; }
        .progress { width: 70px; background: #1e2a3a; border-radius: 20px; height: 5px; display: inline-block; margin-right: 4px; overflow: hidden; }
        .progress-fill { height: 100%; background: linear-gradient(90deg, #12c2e9, #c471ed); width: 0%; }
        .empty-state { text-align: center; padding: 40px; color: #7f9bc0; }
        .req-link { cursor: pointer; color: #88ccff; text-decoration: underline; }
        .error-badge { background: #dc3545; color: white; border-radius: 12px; padding: 0 6px; font-size: 0.6rem; margin-left: 6px; cursor: pointer; display: inline-block; }
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.7); z-index: 1000;
            display: flex; justify-content: center; align-items: center;
            visibility: hidden; opacity: 0; transition: visibility 0s, opacity 0.2s;
        }
        .modal-overlay.active { visibility: visible; opacity: 1; }
        .modal-container {
            background: #0f172a; border: 1px solid #2f6f9f; border-radius: 16px;
            width: 90%; max-width: 1400px; height: 85%; display: flex; flex-direction: column;
            overflow: hidden;
        }
        .modal-header, .modal-search { padding: 12px 20px; border-bottom: 1px solid #2f6f9f; }
        .modal-header { display: flex; justify-content: space-between; background: #020617; }
        .modal-close { background: none; border: none; color: #fff; font-size: 24px; cursor: pointer; }
        .modal-search { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
        .modal-search input, .modal-search select { padding: 6px 12px; background: #1e2a47; border: 1px solid #3c6e9e; color: white; border-radius: 20px; flex: 1; }
        .modal-content { flex: 1; overflow-y: auto; padding: 12px 20px; }
        .error-summary-table { width: 100%; border-collapse: collapse; font-size: 0.7rem; }
        .error-summary-table th, .error-summary-table td { padding: 6px; border-bottom: 1px solid #2f6080; text-align: left; }
        .error-summary-table th { background: #1e2a47; color: #fff; }
        .checkbox-label { display: flex; align-items: center; gap: 8px; font-size: 0.8rem; cursor: pointer; }
        .file-list { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 6px; }
        .file-tag { background: #1a2a4a; border-radius: 20px; padding: 2px 8px; font-size: 0.7rem; display: inline-flex; align-items: center; gap: 6px; border: 1px solid #3a6a9a; }
        .file-tag button { background: none; border: none; color: #ffaa88; cursor: pointer; }
        input[type="file"] { display: none; }
        .filter-btns { display: flex; gap: 8px; }
        .filter-btns button, .error-filter-btns button { background: #1e2a47; border: 1px solid #3c6e9e; padding: 2px 8px; border-radius: 20px; cursor: pointer; font-size: 0.7rem; color: #fff; }
        .badge-error { background: #dc3545; padding: 2px 6px; border-radius: 12px; color: white; font-size: 0.7rem; }
    </style>
</head>
<body>
<div class="app">
    <div id="rightPanel" class="right-panel">
        <div class="panel-header"><h3>📂 文件管理</h3><button class="toggle-btn" id="closePanelBtn">✖</button></div>
        <div><label>📄 订单文件</label><div class="file-btn" id="orderFileBtn">📎 选择文件</div><input type="file" id="orderFileInput" accept=".xlsx,.xls,.csv" multiple><div id="orderFileList" class="file-list"></div></div>
        <div><label>📦 批销文件</label><div class="file-btn" id="shipFileBtn">📎 选择文件</div><input type="file" id="shipFileInput" accept=".xlsx,.xls,.csv" multiple><div id="shipFileList" class="file-list"></div></div>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
            <div class="btn btn-primary" id="processBtn">🚀 解析并保存</div>
            <div class="btn btn-warning" id="exportUnshippedBtn">📤 导出未批销</div>
            <div class="btn btn-export-result" id="exportResultBtn">📊 导出订单匹配结果</div>
            <div class="btn" id="resetDataBtn">🗑️ 重置</div>
        </div>
        <div class="checkbox-label"><input type="checkbox" id="mergeCustomersCheckbox"><span>🔗 合并客户匹配（仅导出未批销）</span></div>
        <div style="font-size:0.65rem; text-align:center; margin-top:auto;">💾 自动保存筛选排序 | F2 折叠右侧面板</div>
    </div>
    <div id="mainArea" class="main-area shift">
        <div class="stats">
            <div class="stat-card"><div class="stat-label">📋 馆配项目数</div><div class="stat-value" id="statProjects">0</div></div>
            <div class="stat-card"><div class="stat-label">📚 订单总册数</div><div class="stat-value" id="statOrderQty">0</div></div>
            <div class="stat-card"><div class="stat-label">📦 收货总册数</div><div class="stat-value" id="statReceivedQty">0</div></div>
            <div class="stat-card"><div class="stat-label">✅ 批销总册数</div><div class="stat-value" id="statShippedQty">0</div></div>
            <div class="stat-card"><div class="stat-label">📊 收货率/批销率</div><div class="stat-value" id="statRateBoth">0% / 0%</div></div>
            <div class="stat-card" id="globalErrorCard" style="border-color:#ffaa66;"><div class="stat-label">⚠️ 异常批销</div><div class="stat-value" id="globalErrorCount">0</div></div>
        </div>
        <div class="stats-row2">
            <div class="stat-card"><div class="stat-label">📖 订单品种数</div><div class="stat-value" id="statOrderTitleCount">0</div></div>
            <div class="stat-card"><div class="stat-label">📖 收货品种数</div><div class="stat-value" id="statReceivedTitleCount">0</div></div>
            <div class="stat-card"><div class="stat-label">📖 批销品种数</div><div class="stat-value" id="statShippedTitleCount">0</div></div>
            <div class="stat-card"><div class="stat-label">💰 订单码洋</div><div class="stat-value" id="statOrderAmount">0</div></div>
            <div class="stat-card"><div class="stat-label">💰 收货码洋</div><div class="stat-value" id="statReceivedAmount">0</div></div>
            <div class="stat-card"><div class="stat-label">💰 批销码洋</div><div class="stat-value" id="statShippedAmount">0</div></div>
        </div>
        <div class="filter-area">
            <div class="filter-header">
                <span>🔍 按客户筛选</span>
                <div class="filter-btns">
                    <button id="selectAllBtn">全选</button>
                    <button id="deselectAllBtn">全取消</button>
                </div>
            </div>
            <div id="customerCheckboxes" class="customer-box"></div>
            <div class="req-row">
                <label>📄 馆配单号：</label>
                <div class="req-wrapper">
                    <input type="text" id="reqNumberInput" placeholder="输入单号结尾，自动匹配" autocomplete="off">
                    <div id="reqDropdown" class="suggest-dropdown"></div>
                </div>
                <button id="applyFilterBtn" class="btn" style="padding:4px 12px;">🔍 筛选</button>
                <button id="resetFilterBtn" class="btn" style="padding:4px 12px;">重置</button>
            </div>
        </div>
        <div class="table-wrapper">
            <table id="dataTable">
                <thead id="tableHeader">
                    <tr>
                        <th data-field="reportDate">报订日期</th>
                        <th data-field="customer">客户名称</th>
                        <th data-field="reqNumber">馆配单号</th>
                        <th data-field="orderQty">订单册数</th>
                        <th data-field="receivedQty">收货册数</th>
                        <th data-field="arrivalRate">收货率</th>
                        <th data-field="shippedQty">批销册数</th>
                        <th data-field="shipRate">批销率</th>
                        <th>差异对比</th>
                        <th>批销进度</th>
                        <th>册数价格分布</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <tr><td colspan="11" class="empty-state">📌 请选择订单和批销文件，点击「解析并保存」</td></tr>
                </tbody>
            </table>
        </div>
        <div class="footer-tip">💡 点击馆配单号查看明细 | 红色数字表示批销册数与订单册数不一致 | 顶部异常卡片查看全局异常</div>
    </div>
</div>

<!-- 订单明细模态框 -->
<div id="orderModal" class="modal-overlay">
    <div class="modal-container">
        <div class="modal-header"><h3 id="modalTitle">订单明细</h3><button class="modal-close" id="modalCloseBtn">&times;</button></div>
        <div class="modal-search"><span>🔍 筛选:</span><input type="text" id="modalSearchInput" placeholder="书号/书名"></div>
        <div class="modal-content" id="modalContent"></div>
    </div>
</div>

<!-- 全局异常模态框 -->
<div id="globalErrorModal" class="modal-overlay">
    <div class="modal-container">
        <div class="modal-header"><h3>⚠️ 异常批销记录</h3><button class="modal-close" id="globalErrorModalCloseBtn">&times;</button></div>
        <div class="modal-search" style="flex-direction:column; align-items:stretch;">
            <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
                <span>🏷️ 按客户筛选</span>
                <div class="filter-btns">
                    <button id="errorSelectAllBtn">全选</button>
                    <button id="errorDeselectAllBtn">全取消</button>
                </div>
            </div>
            <div id="errorCustomerList" class="customer-box" style="max-height:150px;"></div>
            <div style="display:flex; gap:12px; margin-top:12px; align-items:center;">
                <span>📄 馆配单号：</span>
                <div class="req-wrapper" style="flex:1;">
                    <input type="text" id="errorReqInput" placeholder="输入单号结尾，自动匹配" autocomplete="off">
                    <div id="errorReqDropdown" class="suggest-dropdown"></div>
                </div>
                <button id="refreshErrorBtn" class="btn" style="padding:4px 12px;">🔍 筛选</button>
                <button id="resetErrorFilterBtn" class="btn" style="padding:4px 12px;">重置</button>
            </div>
        </div>
        <div class="modal-content" id="globalErrorModalContent"></div>
    </div>
</div>

<script>
(function(){
    // 特殊客户：必须按客户+单号+书号精确匹配
    const SPECIAL = new Set(["中南民族大学", "湖北省图书馆", "武汉市少年儿童图书馆"]);
    
    const $ = id => document.getElementById(id);
    const dom = {
        orderFilesList: $('orderFileList'), shipFilesList: $('shipFileList'),
        orderFileInput: $('orderFileInput'), shipFileInput: $('shipFileInput'),
        processBtn: $('processBtn'), exportUnshipped: $('exportUnshippedBtn'), resetBtn: $('resetDataBtn'),
        exportResultBtn: $('exportResultBtn'),
        closePanelBtn: $('closePanelBtn'), mainArea: $('mainArea'), rightPanel: $('rightPanel'),
        tableBody: $('tableBody'), customerCheckboxes: $('customerCheckboxes'),
        selectAllBtn: $('selectAllBtn'), deselectAllBtn: $('deselectAllBtn'),
        reqNumberInput: $('reqNumberInput'), reqDropdown: $('reqDropdown'),
        applyFilterBtn: $('applyFilterBtn'), resetFilterBtn: $('resetFilterBtn'),
        mergeCheckbox: $('mergeCustomersCheckbox'), globalErrorCard: $('globalErrorCard'),
        statProjects: $('statProjects'), statOrderQty: $('statOrderQty'), statShippedQty: $('statShippedQty'),
        statReceivedQty: $('statReceivedQty'), statRateBoth: $('statRateBoth'),
        statOrderTitle: $('statOrderTitleCount'), statReceivedTitle: $('statReceivedTitleCount'),
        statShippedTitle: $('statShippedTitleCount'), statOrderAmount: $('statOrderAmount'),
        statReceivedAmount: $('statReceivedAmount'), statShippedAmount: $('statShippedAmount'),
        globalErrorCountSpan: $('globalErrorCount'),
        orderModal: $('orderModal'), orderModalTitle: $('modalTitle'), orderModalSearch: $('modalSearchInput'),
        orderModalContent: $('modalContent'), orderModalClose: $('modalCloseBtn'),
        globalErrorModal: $('globalErrorModal'), globalErrorContent: $('globalErrorModalContent'), globalErrorModalClose: $('globalErrorModalCloseBtn'),
        errorCustomerList: $('errorCustomerList'), errorReqInput: $('errorReqInput'), errorReqDropdown: $('errorReqDropdown'),
        refreshErrorBtn: $('refreshErrorBtn'), resetErrorFilterBtn: $('resetErrorFilterBtn'),
        errorSelectAllBtn: $('errorSelectAllBtn'), errorDeselectAllBtn: $('errorDeselectAllBtn')
    };

    let state = {
        orderFiles: [], shipFiles: [],
        rawOrders: [], rawShipments: [],
        orderGroups: [],     // 主界面列表
        orderDetailsMap: new Map(),
        globalErrors: []
    };
    let selectedCustomers = new Set();
    let currentReqSuffix = '';
    let errorSelectedCustomers = new Set();
    let currentSort = { field: 'reportDate', order: 'desc' };

    function escapeHtml(str) { return (str+'').replace(/[&<>]/g, m => m==='&'?'&amp;': m==='<'?'&lt;':'&gt;'); }
    function findColumn(row, possible) { if(!row) return null; const keys=Object.keys(row); for(let p of possible){ let low=p.toLowerCase(); let m=keys.find(k=>k.toLowerCase()===low||k.toLowerCase().includes(low)); if(m) return m; } return null; }
    function parseDate(v){ if(!v) return null; let d=new Date(v); if(!isNaN(d)) return d; let s=String(v).trim().replace(/[年月]/g,'-').replace(/日/g,'').split(/[-\/ :]+/); if(s.length>=3){ let y=parseInt(s[0]),m=parseInt(s[1])-1,day=parseInt(s[2]); if(!isNaN(y)&&!isNaN(m)&&!isNaN(day)) return new Date(y,m,day); } return null; }
    function formatDateShort(date) { if(!date) return '—'; try{ let d=new Date(date); return `${d.getFullYear()}/${(d.getMonth()+1).toString().padStart(2,'0')}/${d.getDate().toString().padStart(2,'0')}`; }catch(e){ return '—'; } }
    function readFile(file){ return new Promise((resolve,reject)=>{ let fr=new FileReader(); fr.onload=e=>resolve(e.target.result); fr.onerror=reject; fr.readAsArrayBuffer(file); }); }
    
    function parseOrderExcel(buf){
        const wb=XLSX.read(buf,{type:'array'}); const sheet=wb.Sheets[wb.SheetNames[0]]; const rows=XLSX.utils.sheet_to_json(sheet,{defval:""}); if(!rows.length) throw new Error('无数据');
        const sample=rows[0]; const colCust=findColumn(sample,['客户名称','客户','购货单位']); const colReq=findColumn(sample,['馆配需求单名称','馆配需求单号','馆配单号']); const colIsbn=findColumn(sample,['书号','ISBN']); const colTitle=findColumn(sample,['书名']); const colPrice=findColumn(sample,['定价']); const colOrder=findColumn(sample,['订数','册数','数量']); const colReceived=findColumn(sample,['已到货数','已收数','到货册数']); const colDate=findColumn(sample,['上报日期','报订日期','报订时间']);
        if(!colCust||!colOrder) throw new Error('缺少客户名称或订数列');
        let res=[]; for(let r of rows){ let customer=(r[colCust]||'').toString().trim(); if(!customer) continue; let orderQty=parseFloat(r[colOrder]); if(isNaN(orderQty)||orderQty<=0) continue; let receivedQty=colReceived?parseFloat(r[colReceived]):0; if(isNaN(receivedQty)) receivedQty=0; let reqNumber=colReq?(r[colReq]||'').toString().trim():''; let isbn=colIsbn?(r[colIsbn]||'').toString().trim():''; let title=colTitle?(r[colTitle]||'').toString().trim():''; let price=colPrice?parseFloat(r[colPrice]):null; if(price!==null&&isNaN(price)) price=null; if(!reqNumber&&!isbn) continue; let reportDate=colDate?parseDate(r[colDate]):null; res.push({customer,reqNumber,isbn,title,price,orderQty,receivedQty,reportDate}); } return res;
    }
    
    // 解析批销，增加字段：批销人、批销时间、批销单价、批销码洋
    function parseShipmentExcel(buf){
        const wb=XLSX.read(buf,{type:'array'}); const sheet=wb.Sheets[wb.SheetNames[0]]; const rows=XLSX.utils.sheet_to_json(sheet,{defval:""}); if(!rows.length) throw new Error('无数据'); 
        const sample=rows[0]; 
        const colCust=findColumn(sample,['购货单位','客户名称','客户']); 
        const colReq=findColumn(sample,['馆配单据','馆配单号','馆配需求单名称']); 
        const colIsbn=findColumn(sample,['书号','ISBN']); 
        const colTitle=findColumn(sample,['书名']); 
        const colQty=findColumn(sample,['批销册数','册数','数量']);
        // 扩展字段
        const colPerson=findColumn(sample,['批销人','业务员','操作人','经办人']);
        const colDate=findColumn(sample,['批销日期','批销时间','发货时间','最后发货时间','物流下达时间']);
        const colPrice=findColumn(sample,['批销价','单价','实际价格','折扣后价格']);
        const colAmount=findColumn(sample,['批销码洋','码洋','金额']);
        if(!colCust||!colQty) throw new Error('缺少购货单位或批销册数列');
        let res=[]; 
        for(let r of rows){ 
            let customer=(r[colCust]||'').toString().trim(); 
            if(!customer) continue; 
            let qty=parseFloat(r[colQty]); 
            if(isNaN(qty)||qty===0) continue; 
            let reqNumber=colReq?(r[colReq]||'').toString().trim():''; 
            let isbn=colIsbn?(r[colIsbn]||'').toString().trim():''; 
            let title=colTitle?(r[colTitle]||'').toString().trim():''; 
            let person=colPerson?(r[colPerson]||'').toString().trim():'';
            let shipDate=colDate?parseDate(r[colDate]):null;
            let unitPrice=colPrice?parseFloat(r[colPrice]):null;
            let amount=colAmount?parseFloat(r[colAmount]):null;
            if(unitPrice!==null && isNaN(unitPrice)) unitPrice=null;
            if(amount!==null && isNaN(amount)) amount=null;
            // 如果没有批销码洋但有单价，则计算
            if(amount===null && unitPrice!==null) amount = qty * unitPrice;
            res.push({
                customer, reqNumber, isbn, title, shippedQty:qty, 
                shipPerson: person, shipDate: shipDate, shipUnitPrice: unitPrice, shipAmount: amount,
                _raw: r
            }); 
        } 
        return res;
    }
    
    function buildPriceDistribution(items){ let group=new Map(); for(let it of items){ let qty=it.qty,price=it.price; if(!price) continue; if(!group.has(qty)) group.set(qty,{min:price,max:price}); else{ let cur=group.get(qty); if(price<cur.min) cur.min=price; if(price>cur.max) cur.max=price; } } return Array.from(group.keys()).sort((a,b)=>a-b).map(q=>`${q}册(${group.get(q).min.toFixed(2)}-${group.get(q).max.toFixed(2)})`).join('；'); }

    async function aggregateData(orderFiles, shipFiles){
        let allOrders=[], allShips=[];
        for(let f of orderFiles){ let buf=await readFile(f); allOrders.push(...parseOrderExcel(buf)); }
        for(let f of shipFiles){ let buf=await readFile(f); allShips.push(...parseShipmentExcel(buf)); }
        state.rawOrders=allOrders; state.rawShipments=allShips;
        
        // 1. 构建订单分组
        let orderMap = new Map(); // key: "客户|单号"
        for(let o of allOrders){
            let key = `${o.customer}|${o.reqNumber||''}`;
            if(!orderMap.has(key)){
                orderMap.set(key, {
                    customer: o.customer, reqNumber: o.reqNumber,
                    totalOrderQty: 0, totalReceivedQty: 0,
                    totalOrderAmount: 0, totalReceivedAmount: 0,
                    details: new Map(), // isbn -> { orderQty, orderAmount, reportDate, shippedRecords: [] }
                    reportDate: o.reportDate,
                    errorList: []
                });
            }
            let item = orderMap.get(key);
            item.totalOrderQty += o.orderQty;
            item.totalReceivedQty += o.receivedQty;
            if(o.price){
                item.totalOrderAmount += o.orderQty * o.price;
                item.totalReceivedAmount += o.receivedQty * o.price;
            }
            let det = item.details.get(o.isbn) || { orderQty:0, orderAmount:0, reportDate: o.reportDate, shippedRecords: [] };
            det.orderQty += o.orderQty;
            if(o.price) det.orderAmount += o.orderQty * o.price;
            if(!det.reportDate || (o.reportDate && o.reportDate > det.reportDate)) det.reportDate = o.reportDate;
            item.details.set(o.isbn, det);
            if(!item.reportDate || (o.reportDate && o.reportDate < item.reportDate)) item.reportDate = o.reportDate;
        }
        
        // 普通客户订单列表（按日期倒序）
        let normalOrdersByCustomer = new Map();
        for(let [key, item] of orderMap.entries()){
            if(SPECIAL.has(item.customer)) continue;
            if(!normalOrdersByCustomer.has(item.customer)) normalOrdersByCustomer.set(item.customer, []);
            normalOrdersByCustomer.get(item.customer).push({ key, reportDate: item.reportDate });
        }
        for(let list of normalOrdersByCustomer.values()){
            list.sort((a,b)=> (b.reportDate?.getTime()||0) - (a.reportDate?.getTime()||0));
        }
        
        let specialShips = [], normalShips = [];
        for(let ship of allShips){
            if(SPECIAL.has(ship.customer)) specialShips.push(ship);
            else normalShips.push(ship);
        }
        
        let globalErrors = [];
        
        // 特殊客户精确匹配
        for(let ship of specialShips){
            let orderKey = `${ship.customer}|${ship.reqNumber||''}`;
            let orderItem = orderMap.get(orderKey);
            if(!orderItem) continue;
            let detail = orderItem.details.get(ship.isbn);
            if(!detail) {
                // 书号不在订单中 -> 异常
                let err = { customer: ship.customer, reqNumber: ship.reqNumber||'', isbn: ship.isbn, title: ship.title, shippedQty: ship.shippedQty, orderTotalQty: 0, reason: `书号 ${ship.isbn} 不在该订单中`, type: 'special' };
                globalErrors.push(err);
                orderItem.errorList.push(err);
                continue;
            }
            // 记录批销明细
            detail.shippedRecords.push({
                shippedQty: ship.shippedQty,
                shipPerson: ship.shipPerson,
                shipDate: ship.shipDate,
                shipUnitPrice: ship.shipUnitPrice,
                shipAmount: ship.shipAmount
            });
            // 数量异常判断
            let totalShipped = detail.shippedRecords.reduce((sum,r)=>sum+r.shippedQty,0);
            if(totalShipped !== detail.orderQty){
                let err = { customer: ship.customer, reqNumber: ship.reqNumber||'', isbn: ship.isbn, title: ship.title, shippedQty: totalShipped, orderTotalQty: detail.orderQty, reason: `批销总数量(${totalShipped})与订单数量(${detail.orderQty})不一致`, type: 'special' };
                // 避免重复添加相同原因的异常（只添加一次）
                if(!orderItem.errorList.some(e=>e.isbn===ship.isbn && e.reason.includes('不一致'))){
                    globalErrors.push(err);
                    orderItem.errorList.push(err);
                }
            }
        }
        
        // 普通客户匹配（按客户+书号，按订单日期倒序分配）
        let normalShipByBook = new Map(); // key: "客户|isbn" -> { totalShippedQty, samples: [{title, shipPerson, shipDate, shipUnitPrice, shipAmount}] }
        for(let ship of normalShips){
            let key = `${ship.customer}|${ship.isbn}`;
            if(!normalShipByBook.has(key)) normalShipByBook.set(key, { totalShippedQty:0, samples:[] });
            let entry = normalShipByBook.get(key);
            entry.totalShippedQty += ship.shippedQty;
            entry.samples.push({ title: ship.title, shipPerson: ship.shipPerson, shipDate: ship.shipDate, shipUnitPrice: ship.shipUnitPrice, shipAmount: ship.shipAmount });
        }
        
        for(let [cust, orders] of normalOrdersByCustomer.entries()){
            let allIsbns = new Set();
            for(let {key} of orders){
                let item = orderMap.get(key);
                for(let isbn of item.details.keys()) allIsbns.add(isbn);
            }
            for(let isbn of allIsbns){
                let shipKey = `${cust}|${isbn}`;
                let shipInfo = normalShipByBook.get(shipKey);
                if(!shipInfo) continue;
                let remaining = shipInfo.totalShippedQty;
                if(remaining === 0) continue;
                for(let {key} of orders){
                    let orderItem = orderMap.get(key);
                    let detail = orderItem.details.get(isbn);
                    if(!detail) continue;
                    let orderQty = detail.orderQty;
                    let assign = Math.min(remaining, orderQty);
                    if(assign === 0) continue;
                    // 分配批销数量到该订单的该书号，记录批销明细（合并样本信息）
                    let sample = shipInfo.samples[0]; // 取第一条批销记录的信息（实际可能有多条，简化为一条）
                    detail.shippedRecords.push({
                        shippedQty: assign,
                        shipPerson: sample.shipPerson,
                        shipDate: sample.shipDate,
                        shipUnitPrice: sample.shipUnitPrice,
                        shipAmount: sample.shipAmount ? (assign / shipInfo.totalShippedQty) * sample.shipAmount : (sample.shipUnitPrice ? assign * sample.shipUnitPrice : null)
                    });
                    remaining -= assign;
                    if(remaining === 0) break;
                }
                if(remaining > 0){
                    let totalOrderQty = 0;
                    for(let {key} of orders) totalOrderQty += (orderMap.get(key).details.get(isbn)?.orderQty || 0);
                    let err = { customer: cust, reqNumber: '', isbn, title: shipInfo.samples[0].title, shippedQty: shipInfo.totalShippedQty, orderTotalQty: totalOrderQty, reason: `批销数量(${shipInfo.totalShippedQty})超出该客户订单总数量(${totalOrderQty})`, type: 'normal' };
                    globalErrors.push(err);
                    let firstKey = orders[0]?.key;
                    if(firstKey && orderMap.has(firstKey)) orderMap.get(firstKey).errorList.push(err);
                }
            }
        }
        
        // 检查普通客户中批销的书号根本不在任何订单中
        for(let [shipKey, shipInfo] of normalShipByBook.entries()){
            let [cust, isbn] = shipKey.split('|');
            let found = false;
            let orders = normalOrdersByCustomer.get(cust) || [];
            for(let {key} of orders){
                if(orderMap.get(key).details.has(isbn)){ found = true; break; }
            }
            if(!found){
                let err = { customer: cust, reqNumber: '', isbn, title: shipInfo.samples[0].title, shippedQty: shipInfo.totalShippedQty, orderTotalQty: 0, reason: `书号 ${isbn} 不在该客户的任何订单中`, type: 'normal' };
                globalErrors.push(err);
                let firstKey = orders[0]?.key;
                if(firstKey && orderMap.has(firstKey)) orderMap.get(firstKey).errorList.push(err);
            }
        }
        
        // 构建主界面列表 result 和 orderDetailsMap
        let result = [];
        let orderDetailsMap = new Map();
        for(let [key, item] of orderMap.entries()){
            let totalShippedQty = 0;
            let totalShippedAmount = 0;
            for(let det of item.details.values()){
                let shippedSum = det.shippedRecords.reduce((s,r)=>s+r.shippedQty,0);
                totalShippedQty += shippedSum;
                totalShippedAmount += det.shippedRecords.reduce((s,r)=>s+(r.shipAmount||0),0);
            }
            let priceItems = Array.from(item.details.entries()).map(([isbn, det]) => ({ qty: det.orderQty, price: det.orderAmount/det.orderQty }));
            let priceDist = buildPriceDistribution(priceItems);
            // 异常计数：特殊客户使用 errorList 长度；普通客户若批销册数与订单册数不等则计数为1
            let errorCount = 0;
            if(SPECIAL.has(item.customer)){
                errorCount = item.errorList.length;
            } else {
                if(totalShippedQty !== item.totalOrderQty) errorCount = 1;
            }
            result.push({
                customer: item.customer,
                req_number: item.reqNumber,
                total_order_qty: item.totalOrderQty,
                total_received_qty: item.totalReceivedQty,
                total_shipped_qty: totalShippedQty,
                arrival_rate: item.totalOrderQty ? (item.totalReceivedQty/item.totalOrderQty)*100 : 0,
                ship_rate: item.totalOrderQty ? (totalShippedQty/item.totalOrderQty)*100 : 0,
                earliest_date: item.reportDate ? item.reportDate.toISOString() : null,
                price_distribution: priceDist || '—',
                error_count: errorCount
            });
            // 构建明细（用于弹窗和导出）
            let allIsbns = new Set(item.details.keys());
            let details = [];
            for(let isbn of allIsbns){
                let orderDetail = item.details.get(isbn);
                let shippedTotal = orderDetail.shippedRecords.reduce((s,r)=>s+r.shippedQty,0);
                let price = orderDetail.orderAmount / orderDetail.orderQty;
                let title = state.rawOrders.find(o=>o.customer===item.customer && o.reqNumber===item.reqNumber && o.isbn===isbn)?.title || '';
                // 合并批销记录信息（用于导出第三个sheet）
                let shipRecords = orderDetail.shippedRecords.map(r => ({
                    shippedQty: r.shippedQty,
                    shipPerson: r.shipPerson || '',
                    shipDate: r.shipDate ? formatDateShort(r.shipDate) : '',
                    shipUnitPrice: r.shipUnitPrice !== null ? r.shipUnitPrice.toFixed(2) : '',
                    shipAmount: r.shipAmount !== null ? r.shipAmount.toFixed(2) : ''
                }));
                details.push({
                    isbn, title, price,
                    orderQty: orderDetail.orderQty,
                    shippedQty: shippedTotal,
                    shippedRecords: shipRecords,
                    status: shippedTotal > orderDetail.orderQty ? '批销超出' : (shippedTotal>0 ? (shippedTotal===orderDetail.orderQty ? '已批销' : '部分批销') : '未批销')
                });
            }
            orderDetailsMap.set(key, { details, errors: item.errorList, errorCount: item.errorList.length });
        }
        return { result, orderDetailsMap, globalErrors };
    }
    
    // 获取当前筛选后的数据
    function getFilteredData() {
        let filtered = state.orderGroups.filter(r => selectedCustomers.has(r.customer));
        if (currentReqSuffix && filtered.length) {
            filtered = filtered.filter(r => r.req_number && r.req_number.endsWith(currentReqSuffix));
        }
        return filtered;
    }
    
    // 渲染表格等（与之前相同，略作简化）
    function renderCustomerCheckboxes() {
        let customers = [...new Set(state.orderGroups.map(i=>i.customer))].sort((a,b)=>a.localeCompare(b));
        if(!customers.length){ dom.customerCheckboxes.innerHTML='<span>暂无客户</span>'; return; }
        let html = '';
        for(let c of customers){
            let checked = selectedCustomers.has(c) ? 'checked' : '';
            html += `<label class="customer-check"><input type="checkbox" value="${escapeHtml(c)}" ${checked}> ${escapeHtml(c)}</label>`;
        }
        dom.customerCheckboxes.innerHTML = html;
        dom.customerCheckboxes.querySelectorAll('input').forEach(cb => {
            cb.onchange = (e) => {
                if(e.target.checked) selectedCustomers.add(e.target.value);
                else selectedCustomers.delete(e.target.value);
                renderTable();
                saveState();
            };
        });
    }
    
    function renderTable() {
        if (!dom.tableBody) return;
        let filtered = getFilteredData();
        // 排序
        let {field, order} = currentSort;
        filtered.sort((a,b)=>{
            let av, bv;
            if(field === 'reportDate'){
                av = a.earliest_date ? new Date(a.earliest_date).getTime() : 0;
                bv = b.earliest_date ? new Date(b.earliest_date).getTime() : 0;
            } else if(field === 'customer'){
                av = a.customer.toLowerCase();
                bv = b.customer.toLowerCase();
            } else if(field === 'reqNumber'){
                av = a.req_number;
                bv = b.req_number;
            } else if(field === 'orderQty'){
                av = a.total_order_qty;
                bv = b.total_order_qty;
            } else if(field === 'receivedQty'){
                av = a.total_received_qty;
                bv = b.total_received_qty;
            } else if(field === 'arrivalRate'){
                av = a.arrival_rate;
                bv = b.arrival_rate;
            } else if(field === 'shippedQty'){
                av = a.total_shipped_qty;
                bv = b.total_shipped_qty;
            } else if(field === 'shipRate'){
                av = a.ship_rate;
                bv = b.ship_rate;
            } else return 0;
            if(av === bv) return 0;
            let res = av > bv ? 1 : -1;
            return order === 'asc' ? res : -res;
        });
        
        let totalOrder = filtered.reduce((s,i)=>s+i.total_order_qty,0);
        let totalShipped = filtered.reduce((s,i)=>s+i.total_shipped_qty,0);
        let totalReceived = filtered.reduce((s,i)=>s+i.total_received_qty,0);
        let arrivalRate = totalOrder===0?0:(totalReceived/totalOrder)*100;
        let shipRate = totalOrder===0?0:(totalShipped/totalOrder)*100;
        dom.statProjects.innerText = filtered.length;
        dom.statOrderQty.innerText = totalOrder.toLocaleString();
        dom.statShippedQty.innerText = totalShipped.toLocaleString();
        dom.statReceivedQty.innerText = totalReceived.toLocaleString();
        dom.statRateBoth.innerText = `${arrivalRate.toFixed(1)}% / ${shipRate.toFixed(1)}%`;
        
        let selectedSet = new Set(filtered.map(r=>r.customer));
        let orderTitles=new Set(), receivedTitles=new Set(), shippedTitles=new Set();
        let totalOrderAmount=0, totalReceivedAmount=0, totalShippedAmount=0;
        for(let o of state.rawOrders.filter(o=>selectedSet.has(o.customer))){ if(o.isbn) orderTitles.add(o.isbn); if(o.price) totalOrderAmount+=o.orderQty*o.price; if(o.receivedQty>0&&o.isbn) receivedTitles.add(o.isbn); if(o.price) totalReceivedAmount+=o.receivedQty*o.price; }
        for(let s of state.rawShipments.filter(s=>selectedSet.has(s.customer))) if(s.isbn) shippedTitles.add(s.isbn);
        for(let [key,info] of state.orderDetailsMap.entries()){ let [customer]=key.split('|'); if(!selectedSet.has(customer)) continue; for(let d of info.details) if(d.shippedQty>0 && d.price) totalShippedAmount+=d.shippedQty*d.price; }
        dom.statOrderTitle.innerText=orderTitles.size;
        dom.statReceivedTitle.innerText=receivedTitles.size;
        dom.statShippedTitle.innerText=shippedTitles.size;
        dom.statOrderAmount.innerText=totalOrderAmount.toFixed(2);
        dom.statReceivedAmount.innerText=totalReceivedAmount.toFixed(2);
        dom.statShippedAmount.innerText=totalShippedAmount.toFixed(2);
        
        dom.globalErrorCountSpan.innerText = state.globalErrors.length;
        
        if(filtered.length === 0){
            dom.tableBody.innerHTML = '<tr><td colspan="11" class="empty-state">📭 暂无数据，请选择客户或调整筛选条件</td></tr>';
            return;
        }
        let html = '';
        for(let row of filtered){
            let rowClass = '';
            if(row.ship_rate>=100) rowClass='rate-100';
            else if(row.ship_rate>=90) rowClass='rate-90';
            else if(row.ship_rate>=80) rowClass='rate-80';
            let diffText = '';
            if(Math.abs(row.ship_rate-row.arrival_rate)<0.01) diffText='一致';
            else if(row.ship_rate>row.arrival_rate) diffText='偏大';
            else diffText='偏小';
            if(Math.abs(row.ship_rate-row.arrival_rate)>=10) rowClass+=' diff-highlight';
            let barWidth = Math.min(100, row.ship_rate);
            let dateStr = row.earliest_date ? formatDateShort(row.earliest_date) : '—';
            let reqDisplay = `<span class="req-link" data-customer="${escapeHtml(row.customer)}" data-req="${escapeHtml(row.req_number)}">${escapeHtml(row.req_number)}</span>`;
            if(row.error_count > 0){
                reqDisplay += `<span class="error-badge" data-customer="${escapeHtml(row.customer)}" data-req="${escapeHtml(row.req_number)}">${row.error_count}</span>`;
            }
            html += `<tr class="${rowClass}">
                <td>${dateStr}</td>
                <td><strong>${escapeHtml(row.customer)}</strong></td>
                <td>${reqDisplay}</td>
                <td>${row.total_order_qty.toLocaleString()}</td>
                <td>${row.total_received_qty.toLocaleString()}</td>
                <td>${row.arrival_rate.toFixed(1)}%</td>
                <td>${row.total_shipped_qty.toLocaleString()}</td>
                <td>${row.ship_rate.toFixed(1)}%</td>
                <td>${diffText}</td>
                <td><div class="progress"><div class="progress-fill" style="width:${barWidth}%"></div></div>${barWidth.toFixed(0)}%</td>
                <td class="price-dist">${escapeHtml(row.price_distribution)}</td>
            </tr>`;
        }
        dom.tableBody.innerHTML = html;
        document.querySelectorAll('.req-link').forEach(el => {
            el.onclick = (e) => { e.stopPropagation(); showOrderDetail(el.dataset.customer, el.dataset.req, false); };
        });
        document.querySelectorAll('.error-badge').forEach(el => {
            el.onclick = (e) => { e.stopPropagation(); showOrderDetail(el.dataset.customer, el.dataset.req, true); };
        });
    }
    
    function showOrderDetail(customer, req, focusError){
        let key = `${customer}|${req}`;
        let data = state.orderDetailsMap.get(key);
        if(!data){ alert('未找到明细'); return; }
        dom.orderModalTitle.innerText = `订单明细 - ${customer} / ${req || '(全部单号)'}`;
        function renderModal(){
            let search = dom.orderModalSearch.value.trim().toLowerCase();
            let filtered = search ? data.details.filter(d=>(d.isbn && d.isbn.toLowerCase().includes(search)) || (d.title && d.title.toLowerCase().includes(search))) : data.details;
            let html = `<table style="width:100%;border-collapse:collapse;"><thead><tr style="background:#1e2a47;"><th>书号</th><th>书名</th><th>定价</th><th>订数</th><th>批销册数</th><th>状态</th></tr></thead><tbody>`;
            for(let d of filtered){
                let statusCls = d.shippedQty > d.orderQty ? 'badge-error' : '';
                html += `<tr>
                    <td>${escapeHtml(d.isbn||'—')}</td>
                    <td>${escapeHtml(d.title||'—')}</td>
                    <td>${d.price?d.price.toFixed(2):'—'}</td>
                    <td>${d.orderQty}</td>
                    <td>${d.shippedQty}</td>
                    <td>${statusCls ? `<span class="badge-error">${d.status}</span>` : d.status}</td>
                </tr>`;
            }
            html += `</tbody></table>`;
            if(data.errors.length){
                html += `<div style="color:#ffaa66;margin:10px 0 8px;">⚠️ 该订单的异常批销记录</div><table style="width:100%;border-collapse:collapse;"><thead><tr style="background:#1e2a47;"><th>书号</th><th>书名</th><th>批销册数</th><th>订单数量</th><th>原因</th></tr></thead><tbody>`;
                for(let e of data.errors){
                    html += `<tr>
                        <td>${escapeHtml(e.isbn||'—')}</td>
                        <td>${escapeHtml(e.title||'—')}</td>
                        <td>${e.shippedQty}</td>
                        <td>${e.orderTotalQty!==undefined?e.orderTotalQty:'—'}</td>
                        <td>${escapeHtml(e.reason)}</td>
                    </tr>`;
                }
                html += `</tbody></table>`;
            } else {
                html += `<div style="margin-top:12px;color:#88ffaa;">✅ 无异常批销记录</div>`;
            }
            dom.orderModalContent.innerHTML = html;
        }
        renderModal();
        dom.orderModal.classList.add('active');
        if(focusError && data.errors.length) setTimeout(()=>{ let el=document.querySelector('.error-title'); if(el) el.scrollIntoView({behavior:'smooth',block:'start'}); },100);
        dom.orderModalSearch.oninput = renderModal;
    }
    
    // 全局异常弹窗（略，保持原有）
    function renderErrorCustomerList() {
        let customers = [...new Set(state.globalErrors.map(e=>e.customer))].sort((a,b)=>a.localeCompare(b));
        if(!customers.length){ dom.errorCustomerList.innerHTML='<span>暂无客户</span>'; return; }
        let html = '';
        for(let c of customers){
            let checked = errorSelectedCustomers.has(c) ? 'checked' : '';
            html += `<label class="customer-check"><input type="checkbox" value="${escapeHtml(c)}" ${checked}> ${escapeHtml(c)}</label>`;
        }
        dom.errorCustomerList.innerHTML = html;
        dom.errorCustomerList.querySelectorAll('input').forEach(cb => {
            cb.onchange = (e) => {
                if(e.target.checked) errorSelectedCustomers.add(e.target.value);
                else errorSelectedCustomers.delete(e.target.value);
                renderGlobalErrorModal();
            };
        });
    }
    function renderGlobalErrorModal(){
        let filtered = state.globalErrors.filter(e => errorSelectedCustomers.has(e.customer));
        let req = dom.errorReqInput.value.trim();
        if(req) filtered = filtered.filter(e => e.reqNumber && e.reqNumber.endsWith(req));
        if(filtered.length === 0){
            dom.globalErrorContent.innerHTML = '<div style="padding:20px;text-align:center;">✅ 暂无异常记录</div>';
            return;
        }
        let html = `<table class="error-summary-table"><thead><tr><th>客户名称</th><th>馆配单号</th><th>书号</th><th>书名</th><th>批销册数</th><th>订单数量</th><th>异常原因</th><th>操作</th></tr></thead><tbody>`;
        for(let e of filtered){
            let btn = e.reqNumber ? `<button class="view-order" data-customer="${escapeHtml(e.customer)}" data-req="${escapeHtml(e.reqNumber)}" style="background:#1e2a47;border:none;color:#0cf;cursor:pointer;">查看订单</button>` : '—';
            html += `<tr>
                <td>${escapeHtml(e.customer)}</td>
                <td>${escapeHtml(e.reqNumber||'—')}</td>
                <td>${escapeHtml(e.isbn||'—')}</td>
                <td>${escapeHtml(e.title||'—')}</td>
                <td>${e.shippedQty}</td>
                <td>${e.orderTotalQty!==undefined?e.orderTotalQty:'—'}</td>
                <td>${escapeHtml(e.reason)}</td>
                <td>${btn}</td>
            </tr>`;
        }
        html += `</tbody></table>`;
        dom.globalErrorContent.innerHTML = html;
        document.querySelectorAll('#globalErrorModal .view-order').forEach(btn=>{
            btn.onclick = ()=>{ let c = btn.dataset.customer, r = btn.dataset.req; if(c && r){ showOrderDetail(c,r,true); dom.globalErrorModal.classList.remove('active'); } };
        });
    }
    function openGlobalErrorModal(){
        if(!state.globalErrors.length){ alert('无异常记录'); return; }
        errorSelectedCustomers.clear();
        for(let c of selectedCustomers) errorSelectedCustomers.add(c);
        renderErrorCustomerList();
        dom.errorReqInput.value = '';
        renderGlobalErrorModal();
        dom.globalErrorModal.classList.add('active');
    }
    
    // 文件管理
    function renderFileLists(){
        dom.orderFilesList.innerHTML = state.orderFiles.map((f,i)=>`<span class="file-tag">📄 ${escapeHtml(f.name)} <button data-idx="${i}" class="del-order">✖</button></span>`).join('');
        dom.shipFilesList.innerHTML = state.shipFiles.map((f,i)=>`<span class="file-tag">📦 ${escapeHtml(f.name)} <button data-idx="${i}" class="del-ship">✖</button></span>`).join('');
        document.querySelectorAll('.del-order').forEach(btn=>btn.onclick=()=>{ state.orderFiles.splice(parseInt(btn.dataset.idx),1); renderFileLists(); afterFileChange(); });
        document.querySelectorAll('.del-ship').forEach(btn=>btn.onclick=()=>{ state.shipFiles.splice(parseInt(btn.dataset.idx),1); renderFileLists(); afterFileChange(); });
    }
    function afterFileChange(){ if(state.orderFiles.length===0 || state.shipFiles.length===0) clearAllData(); else processFiles(); }
    function clearAllData(){ state.orderGroups=[]; state.orderDetailsMap.clear(); state.globalErrors=[]; state.rawOrders=[]; state.rawShipments=[]; selectedCustomers.clear(); currentReqSuffix=''; errorSelectedCustomers.clear(); currentSort = { field: 'reportDate', order: 'desc' }; renderCustomerCheckboxes(); renderTable(); saveState(); }
    async function processFiles(){ if(!state.orderFiles.length||!state.shipFiles.length){ alert('请同时选择订单和批销文件'); return; } dom.processBtn.disabled=true; dom.processBtn.textContent='处理中...'; try{ let orderF=state.orderFiles.map(f=>f.fileObj), shipF=state.shipFiles.map(f=>f.fileObj); let {result,orderDetailsMap,globalErrors}=await aggregateData(orderF,shipF); state.orderGroups=result; state.orderDetailsMap=orderDetailsMap; state.globalErrors=globalErrors; selectedCustomers.clear(); [...new Set(result.map(i=>i.customer))].forEach(c=>selectedCustomers.add(c)); currentReqSuffix=''; errorSelectedCustomers.clear(); currentSort = { field: 'reportDate', order: 'desc' }; renderCustomerCheckboxes(); renderTable(); saveState(); alert(`成功！共${result.length}个馆配项目，异常${globalErrors.length}条`); }catch(e){ alert('处理失败:'+e.message); }finally{ dom.processBtn.disabled=false; dom.processBtn.textContent='🚀 解析并保存'; } }
    function saveState(){ localStorage.setItem('orderRateData',JSON.stringify(state.orderGroups)); localStorage.setItem('selectedCustomers',JSON.stringify([...selectedCustomers])); localStorage.setItem('currentSort',JSON.stringify(currentSort)); localStorage.setItem('orderFileNames',JSON.stringify(state.orderFiles.map(f=>f.name))); localStorage.setItem('shipFileNames',JSON.stringify(state.shipFiles.map(f=>f.name))); }
    function loadState(){ let data=localStorage.getItem('orderRateData'); if(data) try{ state.orderGroups=JSON.parse(data); }catch(e){} let sel=localStorage.getItem('selectedCustomers'); if(sel) try{ selectedCustomers=new Set(JSON.parse(sel)); }catch(e){} let sort=localStorage.getItem('currentSort'); if(sort) try{ currentSort=JSON.parse(sort); }catch(e){} let orderNames=localStorage.getItem('orderFileNames'); if(orderNames) try{ state.orderFiles=JSON.parse(orderNames).map(n=>({name:n,fileObj:null})); }catch(e){} let shipNames=localStorage.getItem('shipFileNames'); if(shipNames) try{ state.shipFiles=JSON.parse(shipNames).map(n=>({name:n,fileObj:null})); }catch(e){} renderFileLists(); renderCustomerCheckboxes(); if(state.orderGroups.length) renderTable(); }
    function resetAll(){ if(confirm('清空所有数据？')){ state.orderFiles=[]; state.shipFiles=[]; state.orderGroups=[]; state.orderDetailsMap.clear(); state.globalErrors=[]; state.rawOrders=[]; state.rawShipments=[]; localStorage.clear(); renderFileLists(); selectedCustomers.clear(); currentReqSuffix=''; errorSelectedCustomers.clear(); currentSort = { field: 'reportDate', order: 'desc' }; renderCustomerCheckboxes(); renderTable(); } }
    
    // 导出未批销（按当前筛选条件，以订单明细为主体，增加批销册数列，值为0）
    async function exportUnshipped(){
        if(state.orderGroups.length===0){ alert('无数据'); return; }
        let merge = dom.mergeCheckbox.checked;
        let filteredGroups = getFilteredData();
        if(filteredGroups.length === 0){ alert('当前筛选条件下无订单数据'); return; }
        let allRows = [];
        for(let row of filteredGroups){
            let key = `${row.customer}|${row.req_number}`;
            let info = state.orderDetailsMap.get(key);
            if(!info) continue;
            for(let detail of info.details){
                let shippedQty = detail.shippedQty;
                if(merge){
                    // 合并模式：导出所有未批销的图书（批销册数为0）
                    if(shippedQty === 0){
                        allRows.push({
                            '客户名称': row.customer,
                            '馆配单号': row.req_number,
                            '书号': detail.isbn,
                            '书名': detail.title,
                            '定价': detail.price,
                            '订单册数': detail.orderQty,
                            '批销册数': 0
                        });
                    }
                } else {
                    // 非合并：导出批销册数为0的图书
                    if(shippedQty === 0){
                        allRows.push({
                            '客户名称': row.customer,
                            '馆配单号': row.req_number,
                            '书号': detail.isbn,
                            '书名': detail.title,
                            '定价': detail.price,
                            '订单册数': detail.orderQty,
                            '批销册数': 0
                        });
                    }
                }
            }
        }
        if(allRows.length === 0){ alert('当前筛选条件下无未批销数据'); return; }
        let ws = XLSX.utils.json_to_sheet(allRows);
        let wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, '未批销清单');
        XLSX.writeFile(wb, `未批销_${new Date().toISOString().slice(0,19)}.xlsx`);
        alert(`导出完成，共${allRows.length}条未批销记录`);
    }
    
    // 导出订单匹配结果（三个sheet）
    function exportResult(){
        let filtered = getFilteredData();
        if(filtered.length === 0){ alert('当前筛选条件下无数据'); return; }
        // Sheet1: 统计汇总
        let totalOrder = filtered.reduce((s,i)=>s+i.total_order_qty,0);
        let totalShipped = filtered.reduce((s,i)=>s+i.total_shipped_qty,0);
        let totalReceived = filtered.reduce((s,i)=>s+i.total_received_qty,0);
        let arrivalRate = totalOrder===0?0:(totalReceived/totalOrder)*100;
        let shipRate = totalOrder===0?0:(totalShipped/totalOrder)*100;
        let statsData = [{
            '馆配项目数': filtered.length,
            '订单总册数': totalOrder,
            '收货总册数': totalReceived,
            '批销总册数': totalShipped,
            '收货率(%)': arrivalRate.toFixed(2),
            '批销率(%)': shipRate.toFixed(2),
            '订单品种数': dom.statOrderTitle.innerText,
            '收货品种数': dom.statReceivedTitle.innerText,
            '批销品种数': dom.statShippedTitle.innerText,
            '订单码洋': parseFloat(dom.statOrderAmount.innerText),
            '收货码洋': parseFloat(dom.statReceivedAmount.innerText),
            '批销码洋': parseFloat(dom.statShippedAmount.innerText)
        }];
        // Sheet2: 订单列表（主界面表格）
        let listData = filtered.map(row => ({
            '报订日期': row.earliest_date ? formatDateShort(row.earliest_date) : '—',
            '客户名称': row.customer,
            '馆配单号': row.req_number,
            '订单册数': row.total_order_qty,
            '收货册数': row.total_received_qty,
            '收货率(%)': row.arrival_rate.toFixed(2),
            '批销册数': row.total_shipped_qty,
            '批销率(%)': row.ship_rate.toFixed(2),
            '差异对比': (()=>{ if(Math.abs(row.ship_rate-row.arrival_rate)<0.01) return '一致'; else if(row.ship_rate>row.arrival_rate) return '偏大'; else return '偏小'; })(),
            '批销进度': `${row.ship_rate.toFixed(0)}%`,
            '册数价格分布': row.price_distribution
        }));
        // Sheet3: 订单批销明细（每个订单下的每个书号，附带批销人、时间、单价、码洋）
        let detailRows = [];
        for(let row of filtered){
            let key = `${row.customer}|${row.req_number}`;
            let info = state.orderDetailsMap.get(key);
            if(!info) continue;
            for(let detail of info.details){
                // 如果有批销记录，可能有多条，但合并展示为一条汇总？这里展示所有批销记录合并为一行（取第一条批销记录的信息，总册数）
                let firstRecord = detail.shippedRecords.length > 0 ? detail.shippedRecords[0] : null;
                detailRows.push({
                    '客户名称': row.customer,
                    '馆配单号': row.req_number,
                    '书号': detail.isbn,
                    '书名': detail.title,
                    '定价': detail.price,
                    '订单册数': detail.orderQty,
                    '批销册数': detail.shippedQty,
                    '批销人': firstRecord ? firstRecord.shipPerson : '',
                    '批销时间': firstRecord ? firstRecord.shipDate : '',
                    '批销单价': firstRecord && firstRecord.shipUnitPrice ? firstRecord.shipUnitPrice : '',
                    '批销码洋': firstRecord && firstRecord.shipAmount ? firstRecord.shipAmount : ''
                });
            }
        }
        let wb = XLSX.utils.book_new();
        let wsStats = XLSX.utils.json_to_sheet(statsData);
        let wsList = XLSX.utils.json_to_sheet(listData);
        let wsDetail = XLSX.utils.json_to_sheet(detailRows);
        XLSX.utils.book_append_sheet(wb, wsStats, '统计汇总');
        XLSX.utils.book_append_sheet(wb, wsList, '订单列表');
        XLSX.utils.book_append_sheet(wb, wsDetail, '订单批销明细');
        XLSX.writeFile(wb, `订单匹配结果_${new Date().toISOString().slice(0,19)}.xlsx`);
        alert('导出成功');
    }
    
    function toggleRightPanel(){ dom.rightPanel.classList.toggle('hide'); dom.mainArea.classList.toggle('shift'); }
    
    function setupSuggestion(inputEl, dropdownEl, getListFunc) {
        inputEl.addEventListener('input', function() {
            let val = this.value.trim();
            if(!val){ dropdownEl.style.display = 'none'; return; }
            let list = getListFunc();
            let matched = list.filter(item => item.toLowerCase().endsWith(val.toLowerCase()));
            if(matched.length === 0){ dropdownEl.style.display = 'none'; return; }
            dropdownEl.innerHTML = matched.map(m => `<div data-val="${escapeHtml(m)}">${escapeHtml(m)}</div>`).join('');
            dropdownEl.style.display = 'block';
            dropdownEl.querySelectorAll('div').forEach(div => {
                div.onclick = () => {
                    inputEl.value = div.dataset.val;
                    dropdownEl.style.display = 'none';
                    if(inputEl.id === 'reqNumberInput') dom.applyFilterBtn.click();
                    else if(inputEl.id === 'errorReqInput') renderGlobalErrorModal();
                };
            });
        });
        document.addEventListener('click', function(e) {
            if(!inputEl.contains(e.target) && !dropdownEl.contains(e.target)) dropdownEl.style.display = 'none';
        });
    }
    
    function bindEvents(){
        document.getElementById('orderFileBtn').onclick=()=>dom.orderFileInput.click();
        document.getElementById('shipFileBtn').onclick=()=>dom.shipFileInput.click();
        dom.orderFileInput.onchange=e=>{ let files=Array.from(e.target.files); for(let f of files){ let idx=state.orderFiles.findIndex(item=>item.name===f.name); if(idx!==-1) state.orderFiles.splice(idx,1); state.orderFiles.push({name:f.name,fileObj:f}); } renderFileLists(); if(state.orderFiles.length&&state.shipFiles.length) processFiles(); dom.orderFileInput.value=''; };
        dom.shipFileInput.onchange=e=>{ let files=Array.from(e.target.files); for(let f of files){ let idx=state.shipFiles.findIndex(item=>item.name===f.name); if(idx!==-1) state.shipFiles.splice(idx,1); state.shipFiles.push({name:f.name,fileObj:f}); } renderFileLists(); if(state.orderFiles.length&&state.shipFiles.length) processFiles(); dom.shipFileInput.value=''; };
        dom.processBtn.onclick=processFiles;
        dom.exportUnshipped.onclick=exportUnshipped;
        dom.exportResultBtn.onclick=exportResult;
        dom.resetBtn.onclick=resetAll;
        dom.closePanelBtn.onclick=toggleRightPanel;
        
        dom.selectAllBtn.onclick = () => {
            let all = [...new Set(state.orderGroups.map(i=>i.customer))];
            selectedCustomers.clear();
            all.forEach(c => selectedCustomers.add(c));
            renderCustomerCheckboxes();
            renderTable();
            saveState();
        };
        dom.deselectAllBtn.onclick = () => {
            selectedCustomers.clear();
            renderCustomerCheckboxes();
            renderTable();
            saveState();
        };
        dom.applyFilterBtn.onclick = () => {
            currentReqSuffix = dom.reqNumberInput.value.trim();
            renderTable();
        };
        dom.resetFilterBtn.onclick = () => {
            dom.reqNumberInput.value = '';
            currentReqSuffix = '';
            renderTable();
        };
        dom.reqNumberInput.addEventListener('keypress', e => { if(e.key === 'Enter') dom.applyFilterBtn.click(); });
        function getReqList(){
            let all = state.orderGroups.map(r => r.req_number).filter(v=>v);
            return [...new Set(all)];
        }
        setupSuggestion(dom.reqNumberInput, dom.reqDropdown, getReqList);
        
        dom.errorSelectAllBtn.onclick = () => {
            let all = [...new Set(state.globalErrors.map(e=>e.customer))];
            errorSelectedCustomers.clear();
            all.forEach(c => errorSelectedCustomers.add(c));
            renderErrorCustomerList();
            renderGlobalErrorModal();
        };
        dom.errorDeselectAllBtn.onclick = () => {
            errorSelectedCustomers.clear();
            renderErrorCustomerList();
            renderGlobalErrorModal();
        };
        dom.refreshErrorBtn.onclick = () => renderGlobalErrorModal();
        dom.resetErrorFilterBtn.onclick = () => { dom.errorReqInput.value = ''; renderGlobalErrorModal(); };
        dom.errorReqInput.addEventListener('keypress', e => { if(e.key === 'Enter') renderGlobalErrorModal(); });
        function getErrorReqList(){
            let custs = errorSelectedCustomers.size ? Array.from(errorSelectedCustomers) : null;
            let errors = state.globalErrors;
            if(custs) errors = errors.filter(e => custs.includes(e.customer));
            return [...new Set(errors.map(e=>e.reqNumber).filter(v=>v))];
        }
        setupSuggestion(dom.errorReqInput, dom.errorReqDropdown, getErrorReqList);
        
        window.addEventListener('keydown',e=>{ if(e.key==='F2'){ e.preventDefault(); toggleRightPanel(); } });
        dom.globalErrorCard.addEventListener('click',openGlobalErrorModal);
        dom.globalErrorModalClose.onclick=()=>dom.globalErrorModal.classList.remove('active');
        dom.globalErrorModal.addEventListener('click',e=>{ if(e.target===dom.globalErrorModal) dom.globalErrorModal.classList.remove('active'); });
        dom.orderModalClose.onclick=()=>dom.orderModal.classList.remove('active');
        dom.orderModal.addEventListener('click',e=>{ if(e.target===dom.orderModal) dom.orderModal.classList.remove('active'); });
        
        document.querySelectorAll('#tableHeader th').forEach(th=>{
            th.onclick=()=>{
                let field = th.getAttribute('data-field');
                if(!field) return;
                if(currentSort.field === field){
                    currentSort.order = currentSort.order === 'asc' ? 'desc' : 'asc';
                } else {
                    currentSort.field = field;
                    currentSort.order = 'asc';
                }
                renderTable();
                saveState();
            };
        });
    }
    
    loadState();
    bindEvents();
})();
</script>
</body>
</html>