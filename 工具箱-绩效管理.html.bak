<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>武汉市新华书店·集团供应中心绩效考核系统</title>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            background: #eef2ff;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .login-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #0b3b5f;
            z-index: 1000;
        }
        .login-card {
            background: white;
            border-radius: 32px;
            padding: 40px 32px;
            width: 380px;
            text-align: center;
            box-shadow: 0 20px 35px rgba(0,0,0,0.2);
        }
        .login-card h2 {
            color: #0b3b5f;
            margin-bottom: 8px;
        }
        .login-card input {
            width: 100%;
            padding: 12px;
            margin: 12px 0;
            border-radius: 40px;
            border: 1px solid #cbd5e1;
        }
        .login-card button {
            width: 100%;
            background: #1e5a7d;
            color: white;
            padding: 12px;
            border-radius: 40px;
            font-weight: bold;
            cursor: pointer;
            border: none;
        }
        .login-card .copyright {
            margin-top: 20px;
            font-size: 0.7rem;
            color: #64748b;
        }

        .main-app {
            display: none;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .top-nav {
            background: #0b3b5f;
            padding: 8px 28px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
            border-bottom: 3px solid #ffc107;
            flex-shrink: 0;
        }
        .top-nav h2 { font-size: 1.1rem; }
        .user-area { display: flex; gap: 16px; align-items: center; }
        button {
            background: #1e5a7d;
            color: white;
            border: none;
            padding: 4px 12px;
            border-radius: 40px;
            cursor: pointer;
            font-weight: 500;
            font-size: 0.75rem;
        }
        button.small { padding: 2px 8px; font-size: 0.7rem; }
        button.danger { background: #dc2626; }
        button.warning { background: #f59e0b; }
        .app-body {
            display: flex;
            flex: 1;
            overflow: hidden;
            position: relative;
        }
        .sidebar {
            width: 240px;
            background: #0f2b3d;
            color: #e0e7ff;
            padding: 16px 0;
            transition: width 0.2s;
            overflow-y: auto;
            flex-shrink: 0;
        }
        .sidebar.collapsed { width: 0; padding: 0; overflow: hidden; }
        .menu-item {
            padding: 8px 20px;
            margin: 4px 12px;
            border-radius: 40px;
            cursor: pointer;
            white-space: nowrap;
            font-size: 0.85rem;
        }
        .menu-item.active { background: #1e5a7d; color: white; }
        .menu-item:hover:not(.active) { background: #1e4a6e; }
        .collapse-trigger {
            width: 5px;
            background: #3b82f6;
            cursor: pointer;
            transition: background 0.2s;
            flex-shrink: 0;
            opacity: 0.7;
        }
        .collapse-trigger:hover { background: #60a5fa; opacity: 1; }
        .main-panel {
            flex: 1;
            background: #f0f4fa;
            padding: 12px 20px;
            overflow-y: auto;
            overflow-x: auto;
        }
        .footer-bar {
            background: #0f2b3d;
            color: #a0c4e2;
            padding: 4px 28px;
            font-size: 0.7rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-shrink: 0;
            border-top: 1px solid #1e5a7d;
        }
        .footer-left, .footer-right { width: 120px; }
        .footer-center { flex: 1; text-align: center; }
        .footer-center .copyright { color: #ffc107; }
        .page-title {
            font-size: 1.2rem;
            font-weight: 600;
            color: #0b3b5f;
            border-left: 4px solid #ffc107;
            padding-left: 14px;
            margin-bottom: 12px;
        }
        .card {
            background: white;
            border-radius: 20px;
            padding: 12px 16px;
            margin-bottom: 16px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }
        .flex-between {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 10px;
        }
        .filter-bar {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: center;
            margin-bottom: 10px;
        }
        .filter-bar select, .filter-bar input {
            padding: 4px 10px;
            border-radius: 40px;
            border: 1px solid #cbd5e1;
            background: white;
            font-size: 0.75rem;
        }
        .table-wrapper {
            overflow-x: auto;
            overflow-y: auto;
            border-radius: 16px;
            border: 1px solid #e2e8f0;
            max-height: calc(100vh - 200px);
        }
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.75rem;
            min-width: 1000px;
        }
        .data-table th, .data-table td {
            border: 1px solid #cbd5e1;
            padding: 4px 6px;
            text-align: center;
            background: white;
            vertical-align: middle;
        }
        .data-table th {
            background: #eef2ff;
            font-weight: 600;
            padding: 6px 4px;
        }
        .badge {
            background: #e6f7ff;
            padding: 2px 8px;
            border-radius: 40px;
            font-size: 0.65rem;
        }
        .modal {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0,0,0,0.5);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }
        .modal-content {
            background: white;
            border-radius: 24px;
            padding: 20px;
            width: 480px;
            max-width: 90%;
            max-height: 80%;
            overflow-y: auto;
        }
        .form-group { margin-bottom: 12px; }
        .form-group label { display: block; font-weight: 500; margin-bottom: 4px; font-size: 0.8rem; }
        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            padding: 6px 10px;
            border-radius: 40px;
            border: 1px solid #cbd5e1;
            font-size: 0.8rem;
        }
        .big-number { font-size: 1rem; font-weight: bold; margin: 0 2px; }
        .action-bar { margin-top: 10px; display: flex; justify-content: flex-end; gap: 8px; }
        .month-badge {
            font-size: 0.9rem;
            background: #e6f7ff;
            display: inline-block;
            padding: 2px 12px;
            border-radius: 40px;
        }
        .multi-month-group {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            align-items: center;
            margin-bottom: 10px;
        }
        .multi-month-group label {
            background: #eef2ff;
            padding: 2px 8px;
            border-radius: 40px;
            cursor: pointer;
            font-size: 0.7rem;
        }
        .detail-list {
            font-size: 0.7rem;
            text-align: left;
            max-width: 140px;
            word-break: break-all;
            line-height: 1.4;
        }
        .config-row {
            display: flex;
            gap: 16px;
            align-items: center;
            margin-bottom: 12px;
            flex-wrap: wrap;
        }
        .category-limits-row {
            display: flex;
            gap: 20px;
            align-items: center;
            background: #f8fafc;
            padding: 8px 12px;
            border-radius: 40px;
            margin-bottom: 12px;
            flex-wrap: wrap;
        }
        .category-limits-row span {
            font-weight: 500;
        }
    </style>
</head>
<body>
<div class="login-container" id="loginContainer">
    <div class="login-card">
        <h2>📚 武汉市新华书店集团</h2>
        <p>集团供应中心 · 绩效考核系统</p>
        <input type="text" id="loginUsername" placeholder="用户编号">
        <input type="password" id="loginPassword" placeholder="密码">
        <button id="loginBtn">登录</button>
        <div class="copyright">© 武汉市新华书店 集团供应中心</div>
    </div>
</div>

<div class="main-app" id="mainApp">
    <div class="top-nav">
        <div><h2>📖 武汉市新华书店 · 集团供应中心</h2></div>
        <div class="user-area"><span>欢迎，<span id="currentUserName"></span></span><button id="logoutBtn">退出</button></div>
    </div>
    <div class="app-body">
        <div class="sidebar" id="sidebar">
            <div class="menu-item active" data-page="project">📐 绩效项目</div>
            <div class="menu-item" data-page="monthsConfig">📆 考核月份</div>
            <div class="menu-item" data-page="performance">📊 绩效考核</div>
            <div class="menu-item" data-page="rewards">🏅 奖惩记录</div>
            <div class="menu-item" data-page="statistics">📈 绩效统计</div>
            <div class="menu-item" data-page="users">👥 用户管理</div>
            <div class="menu-item" data-page="backup">💾 数据维护</div>
        </div>
        <div class="collapse-trigger" id="collapseTrigger"></div>
        <div class="main-panel" id="mainPanel"></div>
    </div>
    <div class="footer-bar">
        <div class="footer-left">当前用户：<span id="footerUserName"></span></div>
        <div class="footer-center"><span class="copyright">© 武汉市新华书店 集团供应中心 2026</span></div>
        <div class="footer-right">当前日期：<span id="footerDate"></span></div>
    </div>
</div>

<script>
    // ======================== 全局配置 ========================
    let GlobalConfig = {
        baseSalary: 700,          // 绩效基数（元）
        reservePercent: 20,       // 年底预留比例（%），平时考核满分 = 100 - reservePercent
        categoryLimits: {          // 各大类单次加减分上限（绝对值）
            virtue: 20,
            ability: 30,
            diligence: 30
        }
    };

    // ======================== 全局数据模型 ========================
    let DB = {
        items: [
            { id: "i1", cat: "virtue", name: "职业道德", minScore: -5, maxScore: 5 },
            { id: "i2", cat: "virtue", name: "廉洁自律", minScore: -5, maxScore: 5 },
            { id: "i3", cat: "ability", name: "业务技能", minScore: -10, maxScore: 10 },
            { id: "i4", cat: "ability", name: "创新意识", minScore: -8, maxScore: 8 },
            { id: "i5", cat: "diligence", name: "迟到早退", minScore: -5, maxScore: 0 },
            { id: "i6", cat: "diligence", name: "全勤奖励", minScore: 0, maxScore: 5 },
            { id: "i7", cat: "diligence", name: "加班奉献", minScore: 0, maxScore: 10 }
        ],
        cats: [
            { id: "virtue", name: "德", order: 1 },
            { id: "ability", name: "能", order: 2 },
            { id: "diligence", name: "勤", order: 3 }
        ],
        monthList: [],
        monthsData: {},     // { monthId: { items, details: { empId: { itemId: [分值数组] } } } }
        persons: [],
        groups: [],
        users: [
            { no: "admin", pwd: "admin", role: "系统管理员", realName: "系统管理员", empId: null },
            { no: "1000", pwd: "1000", role: "总经理", realName: "陈新华", empId: "p1" }
        ],
        logs: [],
        curUser: null,
        curMonthId: "",
        curPage: "project"
    };

    function getCatName(catId) { let c = DB.cats.find(c => c.id === catId); return c ? c.name : ""; }
    function getPersonById(id) { return DB.persons.find(p => p.id === id); }
    function getPersonName(id) { let p = getPersonById(id); return p ? p.name : ""; }
    function getAllEmpIds() { return DB.persons.map(p => p.id); }
    function canEdit(empId) {
        if (!DB.curUser) return false;
        if (DB.curUser.role === "系统管理员" || DB.curUser.role === "经理") return true;
        if (DB.curUser.role === "主任") {
            let curPerson = DB.persons.find(p => p.name === DB.curUser.realName);
            if (!curPerson || curPerson.position !== "主任") return false;
            let target = DB.persons.find(p => p.id === empId);
            return target && target.position === "员工" && target.groupId === curPerson.groupId;
        }
        return false;
    }

    // 计算平时考核满分（由预留比例决定）
    function getMaxMonthlyScore() {
        return 100 - GlobalConfig.reservePercent;
    }

    // 获取员工某月某项目的累计分值
    function getItemTotal(eid, monthId, itemId) {
        let month = DB.monthsData[monthId];
        if (!month) return 0;
        let arr = month.details[eid]?.[itemId];
        if (!arr || !arr.length) return 0;
        return arr.reduce((a,b) => a + b, 0);
    }

    // 获取员工某月平时考核得分（基础满分 = maxMonthlyScore，得分不能超过该满分）
    function getMonthlyScore(eid, monthId) {
        let month = DB.monthsData[monthId];
        if (!month) return 0;
        let total = 0;
        for (let i of month.items) {
            total += getItemTotal(eid, monthId, i.id);
        }
        let maxScore = getMaxMonthlyScore();
        let score = maxScore + total;   // 总分为满分加上加减分（加减分可为负）
        return Math.min(Math.max(score, 0), maxScore);
    }

    // 检查是否可以添加一条明细（只校验单次分值是否超过大类上限，累计暂不限制）
    function canAddDetail(monthId, empId, itemId, newValue) {
        let month = DB.monthsData[monthId];
        if (!month) return false;
        let item = month.items.find(i => i.id === itemId);
        if (!item) return false;
        if (newValue < item.minScore || newValue > item.maxScore) return false;

        // 单次分值不能超过大类上限（绝对值）
        let limit = GlobalConfig.categoryLimits[item.cat];
        if (Math.abs(newValue) > limit) return false;

        // 先扣后加：当前净调整分必须为负才能加正分
        let currentTotal = 0;
        for (let i of month.items) {
            currentTotal += getItemTotal(empId, monthId, i.id);
        }
        if (newValue > 0 && currentTotal >= 0) return false;

        // 总分不能低于0（平时考核得分不能为负）
        let afterTotal = currentTotal + newValue;
        let maxScore = getMaxMonthlyScore();
        if (maxScore + afterTotal < 0) return false;

        return true;
    }

    function createMonth(monthId, name, year, quarter, srcId = null) {
        let src = srcId && DB.monthsData[srcId] ? DB.monthsData[srcId] : null;
        let itemsSnap = src ? JSON.parse(JSON.stringify(src.items)) : JSON.parse(JSON.stringify(DB.items));
        let details = {};
        for (let e of getAllEmpIds()) {
            let empDetails = {};
            for (let i of itemsSnap) {
                empDetails[i.id] = src ? (src.details[e]?.[i.id] ? [...src.details[e][i.id]] : []) : [];
            }
            details[e] = empDetails;
        }
        DB.monthsData[monthId] = { items: itemsSnap, details };
        DB.monthList.push({ id: monthId, name, year, quarter });
    }

    function save() {
        let data = {
            items: DB.items, monthList: DB.monthList, monthsData: DB.monthsData,
            persons: DB.persons, groups: DB.groups, users: DB.users, logs: DB.logs, curMonthId: DB.curMonthId,
            config: GlobalConfig
        };
        localStorage.setItem("perfSystem", JSON.stringify(data));
    }

    function load() {
        let raw = localStorage.getItem("perfSystem");
        if (raw) {
            try {
                let d = JSON.parse(raw);
                DB.items = d.items || DB.items;
                DB.monthList = d.monthList || [];
                DB.monthsData = d.monthsData || {};
                DB.persons = d.persons || [];
                DB.groups = d.groups || [];
                DB.users = d.users || DB.users;
                DB.logs = d.logs || [];
                DB.curMonthId = d.curMonthId || "";
                if (d.config) {
                    GlobalConfig.baseSalary = d.config.baseSalary || 700;
                    GlobalConfig.reservePercent = d.config.reservePercent || 20;
                    if (d.config.categoryLimits) GlobalConfig.categoryLimits = d.config.categoryLimits;
                }
            } catch (e) {}
        }
        if (DB.persons.length === 0) initDefaultData();
        if (DB.monthList.length === 0) initDefaultMonths();
        if (!DB.curMonthId || !DB.monthsData[DB.curMonthId]) DB.curMonthId = DB.monthList[0]?.id || "";
        if (!DB.users.find(u => u.no === "admin")) DB.users.unshift({ no: "admin", pwd: "admin", role: "系统管理员", realName: "系统管理员", empId: null });
        if (!DB.users.find(u => u.no === "1000")) DB.users.push({ no: "1000", pwd: "1000", role: "总经理", realName: "陈新华", empId: "p1" });
        let next = 1001;
        for (let p of DB.persons) {
            if (!DB.users.find(u => u.empId === p.id)) {
                let role = p.position === "经理" ? "经理" : (p.position === "主任" ? "主任" : "员工");
                DB.users.push({ no: String(next++), pwd: String(next-1), role: role, realName: p.name, empId: p.id });
            }
        }
        if (!DB.logs || DB.logs.length === 0) {
            initSampleLogs();
        }
        save();
    }

    function initDefaultMonths() {
        if (DB.monthList.length === 0) {
            for (let i = 1; i <= 12; i++) {
                let mName = `2026-${String(i).padStart(2, '0')}`;
                let quarter = Math.ceil(i / 3).toString();
                createMonth("m" + i, mName, "2026", quarter);
            }
            DB.curMonthId = DB.monthList[0].id;
        }
    }

    function initSampleLogs() {
        DB.logs = [];
        let reasons = ["迟到1次", "全勤奖励", "加班奉献", "职业道德优秀", "廉洁自律问题", "业务技能突出", "创新意识加分", "违反流程扣分"];
        let items = ["i5","i6","i7","i1","i2","i3","i4","i5"];
        let vals = [-3,5,4,2,-2,3,4,-2];
        for (let i = 0; i < 24; i++) {
            let emp = DB.persons[i % DB.persons.length];
            let monthIdx = i % DB.monthList.length;
            let monthId = DB.monthList[monthIdx].id;
            let itemId = items[i % items.length];
            let item = DB.items.find(it => it.id === itemId);
            let val = vals[i % vals.length];
            let ts = `2026-${String(monthIdx+1).padStart(2,'0')}-${String(15 + (i % 10)).padStart(2,'0')} 10:00:00`;
            DB.logs.push({
                id: Date.now() + i,
                employeeId: emp.id,
                employeeName: emp.name,
                itemId: item.id,
                itemName: item.name,
                changeValue: val,
                oldValue: 0,
                newValue: val,
                reason: reasons[i % reasons.length],
                timestamp: ts,
                monthKey: monthId
            });
        }
    }

    function initDefaultData() {
        DB.groups = [
            { id: "g1", name: "馆配组" }, { id: "g2", name: "教材组" }, { id: "g3", name: "收发组" }
        ];
        DB.persons = [
            { id: "p2", name: "张建国", groupId: "g1", position: "主任" }, { id: "p3", name: "张莉", groupId: "g1", position: "员工" },
            { id: "p4", name: "李强", groupId: "g1", position: "员工" }, { id: "p5", name: "陈敏", groupId: "g1", position: "员工" },
            { id: "p6", name: "赵敏", groupId: "g1", position: "员工" }, { id: "p7", name: "刘卫东", groupId: "g2", position: "主任" },
            { id: "p8", name: "孙丽", groupId: "g2", position: "员工" }, { id: "p9", name: "周华", groupId: "g2", position: "员工" },
            { id: "p10", name: "吴迪", groupId: "g2", position: "员工" }, { id: "p11", name: "郑爽", groupId: "g2", position: "员工" },
            { id: "p12", name: "徐红", groupId: "g3", position: "主任" }, { id: "p13", name: "林晨", groupId: "g3", position: "员工" },
            { id: "p14", name: "郭峰", groupId: "g3", position: "员工" }, { id: "p15", name: "唐雅", groupId: "g3", position: "员工" },
            { id: "p16", name: "宋阳", groupId: "g3", position: "员工" }
        ];
        initDefaultMonths();
        let firstMonthId = DB.monthList[0].id;
        let month = DB.monthsData[firstMonthId];
        month.details["p3"]["i5"] = [-3];
        month.details["p8"]["i6"] = [5];
        month.details["p10"]["i7"] = [4];
        month.details["p4"]["i1"] = [2];
        month.details["p5"]["i2"] = [-2];
        initSampleLogs();
        save();
    }

    function exportExcel(data, filename) {
        const ws = XLSX.utils.json_to_sheet(data);
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Sheet1");
        XLSX.writeFile(wb, filename);
    }
    function importExcel(file, callback) {
        let reader = new FileReader();
        reader.onload = e => {
            let wb = XLSX.read(new Uint8Array(e.target.result), { type: "array" });
            let ws = wb.Sheets[wb.SheetNames[0]];
            callback(XLSX.utils.sheet_to_json(ws));
        };
        reader.readAsArrayBuffer(file);
    }

    function render() {
        const container = document.getElementById("mainPanel");
        const pages = {
            project: () => renderProjectPage(container),
            monthsConfig: () => renderMonthsConfig(container),
            performance: () => renderPerformancePage(container),
            rewards: () => renderRewardsPage(container),
            statistics: () => renderStatisticsPage(container),
            users: () => renderUsersPage(container),
            backup: () => renderBackupPage(container)
        };
        pages[DB.curPage]();
        updateFooter();
    }

    function updateFooter() {
        if (DB.curUser) document.getElementById("footerUserName").innerText = DB.curUser.realName;
        const now = new Date();
        document.getElementById("footerDate").innerText = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
    }

    // ======================== 页面渲染 ========================

    function renderProjectPage(container) {
        let maxPossible = getMaxMonthlyScore();
        let h = `<div class="page-title">📐 绩效项目</div>
        <div class="card">
            <div class="category-limits-row">
                <span>大类单次分值上限（总和不能超过平时满分 ${maxPossible} 分）:</span>
                <label>德: <input type="number" id="limitVirtue" value="${GlobalConfig.categoryLimits.virtue}" step="1" style="width:60px;"> 分</label>
                <label>能: <input type="number" id="limitAbility" value="${GlobalConfig.categoryLimits.ability}" step="1" style="width:60px;"> 分</label>
                <label>勤: <input type="number" id="limitDiligence" value="${GlobalConfig.categoryLimits.diligence}" step="1" style="width:60px;"> 分</label>
                <button id="saveLimitsBtn" class="small">保存</button>
            </div>
            <div class="flex-between"><h3>项目列表</h3><div><button id="expItems">导出</button><button id="impItemsBtn">导入</button><input type="file" id="impItemsFile" style="display:none"></div></div>
            <div class="table-wrapper"><table class="data-table"><thead><tr><th>大类</th><th>项目名</th><th>分值范围</th><th>操作</th></table></thead><tbody>${DB.items.map(i => `</td><td style="background:#f8fafc;">${getCatName(i.cat)}</td><td style="background:#f8fafc;">${i.name}</td><td style="background:#f8fafc;">${i.minScore} ~ ${i.maxScore}</td><td style="background:#f8fafc;"><button class="editItem" data-id="${i.id}" style="background:#f59e0b;">修改</button> <button class="delItem" data-id="${i.id}" style="background:#dc2626;">删除</button></td>`).join('')}</tbody></table></div>
            <div style="margin-top:12px"><h4>新增/修改</h4><div style="display:flex; gap:8px; flex-wrap:wrap"><select id="catId"><option value="">大类</option>${DB.cats.map(c => `<option value="${c.id}">${c.name}</option>`).join('')}</select><input id="itemName" placeholder="项目名"><input id="minScore" type="number" placeholder="最小分"><input id="maxScore" type="number" placeholder="最大分"><button id="addItem">新增</button><button id="updItem" style="background:#f59e0b;">修改</button></div><span id="selId"></span><div class="badge">分值区间：若最小=最大则为固定分，每次录入分值需在区间内。</div></div>
        </div>`;
        container.innerHTML = h;
        document.getElementById('saveLimitsBtn').onclick = () => {
            let newVirtue = parseInt(document.getElementById('limitVirtue').value) || 0;
            let newAbility = parseInt(document.getElementById('limitAbility').value) || 0;
            let newDiligence = parseInt(document.getElementById('limitDiligence').value) || 0;
            let total = newVirtue + newAbility + newDiligence;
            let maxLimit = getMaxMonthlyScore();
            if (total > maxLimit) {
                alert(`大类分值上限总和不能超过平时考核满分 ${maxLimit} 分！当前总和为 ${total} 分。`);
                return;
            }
            GlobalConfig.categoryLimits = { virtue: newVirtue, ability: newAbility, diligence: newDiligence };
            save();
            alert("大类单次分值上限已保存");
            render();
        };
        let selId = null;
        document.querySelectorAll('.editItem').forEach(btn => btn.onclick = () => { selId = btn.dataset.id; let it = DB.items.find(x => x.id === selId); if (it) { document.getElementById('catId').value = it.cat; document.getElementById('itemName').value = it.name; document.getElementById('minScore').value = it.minScore; document.getElementById('maxScore').value = it.maxScore; } });
        document.querySelectorAll('.delItem').forEach(btn => btn.onclick = () => { DB.items = DB.items.filter(x => x.id !== btn.dataset.id); save(); render(); });
        document.getElementById('addItem').onclick = () => { let cat = document.getElementById('catId').value, name = document.getElementById('itemName').value.trim(), min = parseInt(document.getElementById('minScore').value) || 0, max = parseInt(document.getElementById('maxScore').value) || 0; if (cat && name && min <= max) { DB.items.push({ id: "i" + Date.now(), cat, name, minScore: min, maxScore: max }); save(); render(); } else alert("请正确填写"); };
        document.getElementById('updItem').onclick = () => { if (selId) { let it = DB.items.find(x => x.id === selId); if (it) { it.cat = document.getElementById('catId').value; it.name = document.getElementById('itemName').value.trim(); it.minScore = parseInt(document.getElementById('minScore').value) || 0; it.maxScore = parseInt(document.getElementById('maxScore').value) || 0; save(); render(); } } };
        document.getElementById('expItems').onclick = () => exportExcel(DB.items, "绩效项目.xlsx");
        document.getElementById('impItemsBtn').onclick = () => document.getElementById('impItemsFile').click();
        document.getElementById('impItemsFile').onchange = e => importExcel(e.target.files[0], rows => { if (rows.length) { DB.items = rows.map(r => ({ id: "i"+Date.now()+Math.random(), cat: r.cat || "diligence", name: r.name, minScore: r.minScore || 0, maxScore: r.maxScore || 0 })); save(); render(); } });
    }

    function renderMonthsConfig(container) {
        let h = `<div class="page-title">📆 考核月份</div><div class="card"><div class="flex-between"><h3>月份列表</h3></div><div class="table-wrapper"><table class="data-table"><thead><tr><th>月份名称</th><th>年份</th><th>季度</th><th>操作</th></tr></thead><tbody>${DB.monthList.map(m => `<tr><td style="background:#f8fafc;"><input type="text" class="month-name" data-id="${m.id}" value="${m.name}"></td><td style="background:#f8fafc;"><input type="text" class="month-year" data-id="${m.id}" value="${m.year}"></td><td style="background:#f8fafc;"><select class="month-quarter" data-id="${m.id}"><option ${m.quarter==="1"?"selected":""}>1</option><option ${m.quarter==="2"?"selected":""}>2</option><option ${m.quarter==="3"?"selected":""}>3</option><option ${m.quarter==="4"?"selected":""}>4</option></select></td><td style="background:#f8fafc;"><button class="delMonthBtn" data-id="${m.id}" style="background:#dc2626;">删除</button></td>`).join('')}</tbody></table></div><div style="display:flex; gap:8px; margin-top:12px; align-items:flex-end"><div><label>月份名称</label><input id="newMonthName" placeholder="例: 2026-01"></div><div><label>年份</label><input id="newMonthYear" placeholder="例: 2026"></div><div><label>季度</label><select id="newMonthQuarter"><option>1</option><option>2</option><option>3</option><option>4</option></select></div><button id="addMonthBtn">➕新增</button></div><div class="badge">修改后请点击其他位置保存。删除月份会删除所有考核数据。</div></div>`;
        container.innerHTML = h;
        document.querySelectorAll('.month-name').forEach(inp => inp.onchange = () => { let m = DB.monthList.find(x => x.id === inp.dataset.id); if (m) m.name = inp.value; save(); });
        document.querySelectorAll('.month-year').forEach(inp => inp.onchange = () => { let m = DB.monthList.find(x => x.id === inp.dataset.id); if (m) m.year = inp.value; save(); });
        document.querySelectorAll('.month-quarter').forEach(sel => sel.onchange = () => { let m = DB.monthList.find(x => x.id === sel.dataset.id); if (m) m.quarter = sel.value; save(); });
        document.querySelectorAll('.delMonthBtn').forEach(btn => btn.onclick = () => { let id = btn.dataset.id; if (DB.monthList.length <= 1) { alert("至少保留一个月"); return; } if (confirm(`删除月份“${DB.monthList.find(m => m.id === id)?.name}”及其所有考核数据？`)) { DB.monthList = DB.monthList.filter(m => m.id !== id); delete DB.monthsData[id]; if (DB.curMonthId === id) DB.curMonthId = DB.monthList[0].id; save(); render(); } });
        document.getElementById('addMonthBtn').onclick = () => {
            let name = document.getElementById('newMonthName').value.trim(), year = document.getElementById('newMonthYear').value.trim(), quarter = document.getElementById('newMonthQuarter').value;
            if (!name || !year) { alert("月份名称和年份不能为空"); return; }
            if (DB.monthList.find(m => m.name === name)) { alert("月份名称已存在"); return; }
            let newId = "m" + Date.now();
            let srcId = DB.monthList.length ? DB.monthList[DB.monthList.length-1].id : null;
            createMonth(newId, name, year, quarter, srcId);
            save(); render();
        };
    }

    // 绩效考核页面（只读展示）
    function renderPerformancePage(container) {
        if (DB.monthList.length === 0) { container.innerHTML = `<div class="card">请先在“考核月份”中配置月份</div>`; return; }
        let monthOpts = DB.monthList.map(m => `<option value="${m.id}" ${m.id===DB.curMonthId?'selected':''}>${m.name} (${m.year}年Q${m.quarter})</option>`).join('');
        let groupFilter = `<select id="groupFilter"><option value="all">全部组</option>${DB.groups.map(g => `<option value="${g.id}">${g.name}</option>`).join('')}</select>`;
        let posFilter = `<select id="posFilter"><option value="all">全部职位</option><option value="主任">主任</option><option value="员工">员工</option></select>`;
        let month = DB.monthsData[DB.curMonthId];
        if (!month) { container.innerHTML = `<div class="card">月份数据不存在</div>`; return; }
        let currentMonthName = DB.monthList.find(m => m.id === DB.curMonthId)?.name || '';
        let sortedItems = [...month.items].sort((a,b) => (DB.cats.find(c=>c.id===a.cat)?.order||99) - (DB.cats.find(c=>c.id===b.cat)?.order||99));
        let groupOrder = { g2:0, g1:1, g3:2 };
        let sortedPersons = [...DB.persons].sort((a,b) => (groupOrder[a.groupId]??99) - (groupOrder[b.groupId]??99) || a.name.localeCompare(b.name));
        let filterGroup = document.getElementById('groupFilter')?.value || 'all';
        let filterPos = document.getElementById('posFilter')?.value || 'all';
        let filtered = sortedPersons.filter(p => (filterGroup==='all'||p.groupId===filterGroup) && (filterPos==='all'||p.position===filterPos));
        let maxScore = getMaxMonthlyScore();

        let h = `<div class="page-title">📊 绩效考核（只读）</div>
        <div class="card">
            <div class="flex-between">
                <div><span class="month-badge">📌 当前考核月份：${currentMonthName}</span></div>
                <div><button id="exportMonthExcel">导出Excel</button> <button id="importMonthBtn">导入Excel</button> <input type="file" id="importMonthFile" style="display:none"></div>
            </div>
            <div class="flex-between">
                <div>考核月份切换：<select id="monSel">${monthOpts}</select></div>
                <div>组筛选：${groupFilter} 职位筛选：${posFilter}</div>
            </div>
            <div class="table-wrapper">
                <table class="data-table" style="min-width: 1000px;">
                    <thead><tr><th>组</th><th>姓名</th>${sortedItems.map(i => `<th>${i.name}<br><span class="badge">(${getCatName(i.cat)})<br>区间:${i.minScore}~${i.maxScore}</span></th>`).join('')}<th>平时得分(满分${maxScore})</th></tr></thead>
                    <tbody>${filtered.map(p => {
                        let eid = p.id;
                        let row = `<td style="background:#f8fafc;">${DB.groups.find(g=>g.id===p.groupId)?.name||''}</td><td style="background:#f8fafc;">${p.name}</td>`;
                        for (let i of sortedItems) {
                            let arr = month.details[eid]?.[i.id] || [];
                            let detailStr = arr.map(v => (v>0?`+${v}`:v)).join(', ');
                            let total = arr.reduce((a,b)=>a+b,0);
                            row += `<td><div class="detail-list">${detailStr || '无'}<br><strong>总分:${total}</strong></div></td>`;
                        }
                        let score = getMonthlyScore(eid, DB.curMonthId);
                        row += `<td>${score} / ${maxScore}</td>`;
                        return `<td>${row}</tr>`;
                    }).join('')}</tbody>
                </table>
            </div>
        </div>`;
        container.innerHTML = h;
        document.getElementById('monSel').onchange = e => { DB.curMonthId = e.target.value; render(); };
        document.getElementById('groupFilter').onchange = () => renderPerformancePage(container);
        document.getElementById('posFilter').onchange = () => renderPerformancePage(container);
        document.getElementById('exportMonthExcel').onclick = () => {
            let month = DB.monthsData[DB.curMonthId];
            let items = month.items;
            let monthName = DB.monthList.find(m=>m.id===DB.curMonthId)?.name;
            let data = [];
            for (let p of DB.persons) {
                let row = { 考核月份: monthName, 姓名: p.name, 组: DB.groups.find(g=>g.id===p.groupId)?.name || '' };
                for (let i of items) {
                    let arr = month.details[p.id]?.[i.id] || [];
                    row[`${i.name}_明细`] = arr.join(',');
                    row[`${i.name}_总分`] = arr.reduce((a,b)=>a+b,0);
                }
                data.push(row);
            }
            exportExcel(data, `绩效考核_${monthName}.xlsx`);
        };
        document.getElementById('importMonthBtn').onclick = () => document.getElementById('importMonthFile').click();
        document.getElementById('importMonthFile').onchange = e => importExcel(e.target.files[0], rows => {
            if (rows.length) {
                let month = DB.monthsData[DB.curMonthId];
                let items = month.items;
                let currentMonthName = DB.monthList.find(m=>m.id===DB.curMonthId)?.name;
                for (let r of rows) {
                    let importMonth = r['考核月份'];
                    if (importMonth && importMonth !== currentMonthName && !confirm(`导入文件的考核月份为“${importMonth}”，当前月份为“${currentMonthName}”。是否仍要继续导入？`)) continue;
                    let emp = DB.persons.find(p => p.name === r.姓名);
                    if (!emp) continue;
                    for (let i of items) {
                        let detailStr = r[`${i.name}_明细`];
                        if (detailStr) {
                            let details = detailStr.split(',').map(v => parseInt(v.trim())).filter(v => !isNaN(v));
                            details = details.filter(v => v >= i.minScore && v <= i.maxScore);
                            month.details[emp.id][i.id] = details;
                        }
                    }
                }
                save(); render();
            }
        });
    }

    // 奖惩记录（完整功能）
    function renderRewardsPage(container) {
        let monthOpts = `<select id="filterMon"><option value="all">全部月份</option>${DB.monthList.slice().reverse().map(m => `<option value="${m.id}">${m.name}</option>`).join('')}</select>`;
        let filterHtml = `<div class="filter-bar"><span>考核月份：${monthOpts}</span><input type="text" id="filterName" placeholder="员工姓名"><select id="filterGroup"><option value="all">全部组</option>${DB.groups.map(g => `<option value="${g.id}">${g.name}</option>`).join('')}</select><select id="filterPos"><option value="all">全部职位</option><option value="主任">主任</option><option value="员工">员工</option></select><button id="searchBtn">筛选</button> <button id="resetFilter">重置</button><button id="addRew">新增记录</button><button id="expRew">导出Excel</button><button id="impRewBtn">导入</button><input type="file" id="impRewFile" style="display:none"></div>`;
        let html = `<div class="page-title">🏅 奖惩记录</div><div class="card">${filterHtml}<div class="table-wrapper"><div id="rewList"></div></div></div>`;
        container.innerHTML = html;
        function renderLogs() {
            let fMon = document.getElementById('filterMon')?.value || 'all';
            let nameF = document.getElementById('filterName')?.value.trim().toLowerCase() || '';
            let groupF = document.getElementById('filterGroup')?.value || 'all';
            let posF = document.getElementById('filterPos')?.value || 'all';
            let flt = fMon === 'all' ? [...DB.logs] : DB.logs.filter(l => l.monthKey === fMon);
            if (nameF) flt = flt.filter(l => l.employeeName.toLowerCase().includes(nameF));
            if (groupF !== 'all') { let eids = DB.persons.filter(p => p.groupId === groupF).map(p => p.id); flt = flt.filter(l => eids.includes(l.employeeId)); }
            if (posF !== 'all') { let eids = DB.persons.filter(p => p.position === posF).map(p => p.id); flt = flt.filter(l => eids.includes(l.employeeId)); }
            flt.sort((a,b) => new Date(b.timestamp) - new Date(a.timestamp));
            let tbl = `<table class="data-table"><thead><tr><th>时间</th><th>员工</th><th>组</th><th>职位</th><th>项目</th><th>分值</th><th>事由</th><th>考核月份</th><th>操作</th></tr></thead><tbody>${flt.map(l => {
                let p = DB.persons.find(pp => pp.id === l.employeeId);
                let groupName = p ? DB.groups.find(g => g.id === p.groupId)?.name : '';
                let monthName = DB.monthList.find(m => m.id === l.monthKey)?.name || '';
                return `<tr><td style="white-space:nowrap;">${l.timestamp}</td><td style="background:#f8fafc;">${l.employeeName}</td><td style="background:#f8fafc;">${groupName||''}</td><td style="background:#f8fafc;">${p?.position||''}</td><td style="background:#f8fafc;">${l.itemName||''}</td><td style="background:#f8fafc;">${l.changeValue>0?`+${l.changeValue}`:l.changeValue}</td><td style="background:#f8fafc;">${l.reason}</td><td style="background:#f8fafc;">${monthName}</td><td style="background:#f8fafc;"><button class="editLogBtn" data-id="${l.id}" style="background:#f59e0b;">编辑</button> <button class="delLogBtn" data-id="${l.id}" style="background:#dc2626;">删除</button></td>`);
            }).join('')}</tbody></table>`;
            if (flt.length === 0) tbl = `<div class="badge" style="margin:12px;">暂无数据，请点击“新增记录”添加</div>`;
            document.getElementById('rewList').innerHTML = tbl;
            document.querySelectorAll('.editLogBtn').forEach(btn => btn.onclick = () => { let lid = btn.dataset.id; let log = DB.logs.find(x => x.id == lid); if (log) openRewardModal(log); });
            document.querySelectorAll('.delLogBtn').forEach(btn => btn.onclick = () => { if (confirm("删除记录？")) { DB.logs = DB.logs.filter(x => x.id != btn.dataset.id); save(); renderLogs(); } });
        }
        renderLogs();
        document.getElementById('filterMon').onchange = renderLogs;
        document.getElementById('searchBtn').onclick = renderLogs;
        document.getElementById('resetFilter').onclick = () => { document.getElementById('filterName').value = ''; document.getElementById('filterGroup').value = 'all'; document.getElementById('filterPos').value = 'all'; renderLogs(); };
        document.getElementById('addRew').onclick = () => openRewardModal(null);
        document.getElementById('expRew').onclick = () => exportExcel(DB.logs, "奖惩记录.xlsx");
        document.getElementById('impRewBtn').onclick = () => document.getElementById('impRewFile').click();
        document.getElementById('impRewFile').onchange = e => importExcel(e.target.files[0], rows => { DB.logs = rows; save(); render(); });
    }

    function openRewardModal(editLog) {
        let isEdit = !!editLog;
        let modal = document.createElement('div'); modal.className = 'modal';
        let monthHtml = `<div class="form-group"><label>生效月份</label><select id="logMonth">${DB.monthList.map(m => `<option value="${m.id}" ${m.id===DB.curMonthId?'selected':''}>${m.name}</option>`).join('')}</select></div>`;
        let groupedOpts = '';
        for (let cat of DB.cats) {
            let catItems = DB.items.filter(i => i.cat === cat.id);
            if (catItems.length) {
                groupedOpts += `<optgroup label="${cat.name}类">${catItems.map(i => `<option value="${i.id}">${i.name} (区间:${i.minScore}~${i.maxScore})</option>`).join('')}</optgroup>`;
            }
        }
        let itemSelect = `<select id="itemSelect" style="width:100%">${groupedOpts}</select>`;
        let scoreDiv = `<div id="scoreDiv" style="display:block"><div class="form-group"><label>分值（需在项目区间内）</label><input type="number" id="scoreValue" step="1" value="0"></div></div>`;
        modal.innerHTML = `<div class="modal-content"><h3>${isEdit?'编辑':'新增'}奖惩记录</h3>${monthHtml}<div class="form-group"><label>时间</label><input type="datetime-local" id="logTime" value="${new Date().toISOString().slice(0,16)}"></div><div class="form-group"><label>员工</label><select id="logEmp">${DB.persons.map(p => `<option value="${p.id}">${p.name}</option>`).join('')}</select></div><div class="form-group"><label>考核项目</label>${itemSelect}</div>${scoreDiv}<div class="form-group"><label>事由</label><textarea id="logReason" rows="2"></textarea></div><div class="flex-between"><button id="confirmRew">确认</button><button id="cancelRew">取消</button></div></div>`;
        document.body.appendChild(modal);
        let itemSel = document.getElementById('itemSelect');
        itemSel.onchange = () => {
            let val = itemSel.value;
            if (val) {
                let item = DB.items.find(i => i.id === val);
                if (item) document.getElementById('scoreValue').placeholder = `区间 ${item.minScore}~${item.maxScore}`;
            }
        };
        if (isEdit) {
            itemSel.value = editLog.itemId;
            document.getElementById('scoreValue').value = editLog.changeValue;
            document.getElementById('logReason').value = editLog.reason;
            document.getElementById('logTime').value = editLog.timestamp.replace(' ', 'T').slice(0,16);
            document.getElementById('logEmp').value = editLog.employeeId;
            document.getElementById('logMonth').value = editLog.monthKey;
        }
        document.getElementById('confirmRew').onclick = () => {
            let time = document.getElementById('logTime').value.replace('T', ' ') + ':00';
            let empId = document.getElementById('logEmp').value;
            let selVal = itemSel.value;
            let reason = document.getElementById('logReason').value;
            let monthId = document.getElementById('logMonth').value;
            if (!empId || !selVal || !monthId) return;
            let month = DB.monthsData[monthId];
            if (!month) { alert("月份数据不存在"); return; }
            let empName = getPersonName(empId);
            let it = DB.items.find(i => i.id === selVal);
            if (!it) return;
            let newScore = parseInt(document.getElementById('scoreValue').value) || 0;
            if (newScore < it.minScore || newScore > it.maxScore) {
                alert(`分值必须在 ${it.minScore} ~ ${it.maxScore} 之间`);
                return;
            }
            if (!canAddDetail(monthId, empId, it.id, newScore)) {
                alert("添加失败：违反了单次分值上限或先扣后加原则！");
                return;
            }
            if (!month.details[empId]) month.details[empId] = {};
            if (!month.details[empId][it.id]) month.details[empId][it.id] = [];
            month.details[empId][it.id].push(newScore);
            DB.logs.unshift({ id: Date.now(), employeeId: empId, employeeName: empName, itemId: it.id, itemName: it.name, changeValue: newScore, oldValue: 0, newValue: newScore, reason, timestamp: time, monthKey: monthId });
            save(); modal.remove(); render();
        };
        document.getElementById('cancelRew').onclick = () => modal.remove();
    }

    // 绩效统计
    function renderStatisticsPage(container) {
        if (DB.monthList.length === 0) { container.innerHTML = `<div class="card">请先在“考核月份”中配置月份</div>`; return; }
        let monthsList = [...DB.monthList].sort((a,b)=>a.name.localeCompare(b.name));
        let defaultSelected = monthsList.slice(0, Math.min(6, monthsList.length)).map(m => m.id);
        let checkboxes = `<div class="multi-month-group"><div><button id="selectAllMonths">全选</button> <button id="clearAllMonths">全不选</button></div>${monthsList.map(m => `<label><input type="checkbox" class="monthChk" value="${m.id}" ${defaultSelected.includes(m.id) ? 'checked' : ''}> ${m.name}</label>`).join('')}</div>`;
        let groupFilter = `<select id="statGroup"><option value="all">全部组</option>${DB.groups.map(g => `<option value="${g.id}">${g.name}</option>`).join('')}</select>`;
        let posFilter = `<select id="statPos"><option value="all">全部职位</option><option value="主任">主任</option><option value="员工">员工</option></select>`;
        let h = `<div class="page-title">📈 绩效统计（多选月份累计）</div>
        <div class="card">
            <div class="multi-month-group" style="margin-bottom:10px;">${checkboxes}</div>
            <div class="filter-bar" style="justify-content: space-between;">
                <div><span>组筛选：${groupFilter}</span> <span>职位筛选：${posFilter}</span></div>
                <div><button id="exportStatExcel">导出Excel</button></div>
            </div>
            <div class="table-wrapper" id="statTableWrap"></div>
        </div>`;
        container.innerHTML = h;
        function renderStatTable() {
            let selected = Array.from(document.querySelectorAll('.monthChk:checked')).map(cb => cb.value);
            if (selected.length === 0) { document.getElementById('statTableWrap').innerHTML = '<div class="badge">请至少选择一个月份</div>'; return; }
            let groupVal = document.getElementById('statGroup').value, posVal = document.getElementById('statPos').value;
            let filteredPersons = DB.persons.filter(p => (groupVal==='all'||p.groupId===groupVal) && (posVal==='all'||p.position===posVal));
            let groupOrder = { g2:0, g1:1, g3:2 };
            let sortedPersons = filteredPersons.sort((a,b) => (groupOrder[a.groupId]??99) - (groupOrder[b.groupId]??99) || a.name.localeCompare(b.name));
            let firstMonth = DB.monthsData[selected[0]];
            if (!firstMonth) return;
            let sortedItems = [...firstMonth.items].sort((a,b) => (DB.cats.find(c=>c.id===a.cat)?.order||99) - (DB.cats.find(c=>c.id===b.cat)?.order||99));
            let baseSalary = GlobalConfig.baseSalary;
            let reserveRatio = GlobalConfig.reservePercent / 100;
            let maxMonthlyScore = getMaxMonthlyScore();
            let thead = `<thead><tr><th>员工</th><th>组</th>${sortedItems.map(i => `<th>${i.name}<br><span class="badge">(${getCatName(i.cat)})<br>累计总分</span></th>`).join('')}<th>累计平时得分</th><th>累计实发(平时奖金)</th><th>累计预留(年底固定)</th><th>总绩效</th></tr></thead>`;
            let tbody = '';
            for (let p of sortedPersons) {
                let groupName = DB.groups.find(g => g.id === p.groupId)?.name || '';
                let row = `<td style="background:#f8fafc;">${p.name}</td><td style="background:#f8fafc;">${groupName}</td>`;
                let totalItemScores = 0;
                for (let item of sortedItems) {
                    let totalItem = 0;
                    for (let mid of selected) totalItem += getItemTotal(p.id, mid, item.id);
                    row += `<td>${totalItem}</td>`;
                    totalItemScores += totalItem;
                }
                let totalMonthlyScore = 0;
                for (let mid of selected) {
                    totalMonthlyScore += getMonthlyScore(p.id, mid);
                }
                let totalRealSalary = 0;
                let totalReserveSalary = 0;
                for (let mid of selected) {
                    let monthlyScore = getMonthlyScore(p.id, mid);
                    let coeff = monthlyScore / maxMonthlyScore;
                    let monthlyBase = baseSalary * (1 - reserveRatio);
                    totalRealSalary += monthlyBase * coeff;
                    totalReserveSalary += baseSalary * reserveRatio;
                }
                let totalPay = totalRealSalary + totalReserveSalary;
                row += `<td>${totalMonthlyScore.toFixed(1)} (满分${selected.length*maxMonthlyScore})</td>`;
                row += `<td>${totalRealSalary.toFixed(2)}</td>`;
                row += `<td>${totalReserveSalary.toFixed(2)}</td>`;
                row += `<td>${totalPay.toFixed(2)}</td>`;
                tbody += `<tr>${row}</tr>`;
            }
            document.getElementById('statTableWrap').innerHTML = `<table class="data-table">${thead}${tbody}</table>`;
        }
        renderStatTable();
        document.getElementById('selectAllMonths').onclick = () => { document.querySelectorAll('.monthChk').forEach(cb => cb.checked = true); renderStatTable(); };
        document.getElementById('clearAllMonths').onclick = () => { document.querySelectorAll('.monthChk').forEach(cb => cb.checked = false); renderStatTable(); };
        document.querySelectorAll('.monthChk').forEach(cb => cb.onchange = renderStatTable);
        document.getElementById('statGroup').onchange = renderStatTable;
        document.getElementById('statPos').onchange = renderStatTable;
        document.getElementById('exportStatExcel').onclick = () => {
            let selected = Array.from(document.querySelectorAll('.monthChk:checked')).map(cb => cb.value);
            if (selected.length === 0) return;
            let groupVal = document.getElementById('statGroup').value, posVal = document.getElementById('statPos').value;
            let filtered = DB.persons.filter(p => (groupVal==='all'||p.groupId===groupVal) && (posVal==='all'||p.position===posVal));
            let firstMonth = DB.monthsData[selected[0]];
            let sortedItems = [...firstMonth.items].sort((a,b) => (DB.cats.find(c=>c.id===a.cat)?.order||99) - (DB.cats.find(c=>c.id===b.cat)?.order||99));
            let baseSalary = GlobalConfig.baseSalary;
            let reserveRatio = GlobalConfig.reservePercent / 100;
            let maxMonthlyScore = getMaxMonthlyScore();
            let exportData = [];
            for (let p of filtered) {
                let row = { 员工: p.name, 组: DB.groups.find(g=>g.id===p.groupId)?.name||'' };
                for (let item of sortedItems) {
                    let totalItem = 0;
                    for (let mid of selected) totalItem += getItemTotal(p.id, mid, item.id);
                    row[`${item.name}_总分`] = totalItem;
                }
                let totalMonthlyScore = 0;
                for (let mid of selected) totalMonthlyScore += getMonthlyScore(p.id, mid);
                let totalRealSalary = 0, totalReserveSalary = 0;
                for (let mid of selected) {
                    let monthlyScore = getMonthlyScore(p.id, mid);
                    let coeff = monthlyScore / maxMonthlyScore;
                    let monthlyBase = baseSalary * (1 - reserveRatio);
                    totalRealSalary += monthlyBase * coeff;
                    totalReserveSalary += baseSalary * reserveRatio;
                }
                row['累计平时得分'] = totalMonthlyScore.toFixed(1);
                row['累计实发(平时奖金)'] = totalRealSalary.toFixed(2);
                row['累计预留(年底固定)'] = totalReserveSalary.toFixed(2);
                row['总绩效'] = (totalRealSalary + totalReserveSalary).toFixed(2);
                exportData.push(row);
            }
            exportExcel(exportData, `绩效统计_累计.xlsx`);
        };
    }

    function renderUsersPage(container) {
        let h = `<div class="page-title">👥 用户管理</div><div class="card"><div class="flex-between"><h3>系统用户</h3><button id="addUser">➕新增用户</button></div><div class="table-wrapper"><table class="data-table" style="min-width: 600px;"><thead><tr><th style="min-width:100px;">用户编号</th><th style="min-width:100px;">真实姓名</th><th style="min-width:80px;">密码</th><th style="min-width:100px;">角色</th><th style="min-width:120px;">操作</th></tr></thead><tbody>${DB.users.map(u => `<tr><td style="min-width:100px;">${u.no}</td><td style="min-width:100px;">${u.realName}</td><td style="min-width:80px;">${u.pwd}</td><td style="min-width:100px;">${u.role}</td><td style="min-width:120px;"><button class="editUser" data-no="${u.no}" style="background:#f59e0b;">编辑</button> ${u.no !== "admin" ? `<button class="delUser" data-no="${u.no}" style="background:#dc2626;">删除</button>` : ''}</td>`).join('')}</tbody></table></div></div>`;
        container.innerHTML = h;
        document.querySelectorAll('.editUser').forEach(btn => btn.onclick = () => {
            let no = btn.dataset.no;
            let user = DB.users.find(u => u.no === no);
            if (!user) return;
            let modal = document.createElement('div'); modal.className = 'modal';
            modal.innerHTML = `<div class="modal-content"><h3>编辑用户</h3><div class="form-group"><label>真实姓名</label><input id="editName" value="${user.realName}"></div><div class="form-group"><label>角色</label><select id="editRole"><option ${user.role==='系统管理员'?'selected':''}>系统管理员</option><option ${user.role==='总经理'?'selected':''}>总经理</option><option ${user.role==='经理'?'selected':''}>经理</option><option ${user.role==='主任'?'selected':''}>主任</option><option ${user.role==='员工'?'selected':''}>员工</option></select></div><div class="form-group"><label>密码</label><input id="editPwd" value="${user.pwd}"></div><div class="flex-between"><button id="saveEdit">保存</button><button id="cancelEdit">取消</button></div></div>`;
            document.body.appendChild(modal);
            document.getElementById('saveEdit').onclick = () => {
                user.realName = document.getElementById('editName').value;
                user.role = document.getElementById('editRole').value;
                user.pwd = document.getElementById('editPwd').value;
                save(); render(); modal.remove();
            };
            document.getElementById('cancelEdit').onclick = () => modal.remove();
        });
        document.querySelectorAll('.delUser').forEach(btn => btn.onclick = () => {
            let no = btn.dataset.no;
            if (no !== "admin") { DB.users = DB.users.filter(u => u.no !== no); save(); render(); }
            else alert("不能删除管理员");
        });
        document.getElementById('addUser').onclick = () => {
            let modal = document.createElement('div'); modal.className = 'modal';
            modal.innerHTML = `<div class="modal-content"><h3>新增用户</h3><div class="form-group"><label>用户编号</label><input id="newNo"></div><div class="form-group"><label>真实姓名</label><input id="newName"></div><div class="form-group"><label>密码</label><input id="newPwd" type="password"></div><div class="form-group"><label>角色</label><select id="newRole"><option>员工</option><option>主任</option><option>经理</option><option>总经理</option></select></div><div class="flex-between"><button id="confirmAdd">确认</button><button id="cancelAdd">取消</button></div></div>`;
            document.body.appendChild(modal);
            document.getElementById('confirmAdd').onclick = () => {
                let no = document.getElementById('newNo').value.trim(), name = document.getElementById('newName').value.trim(), pwd = document.getElementById('newPwd').value, role = document.getElementById('newRole').value;
                if (!no || !name || !pwd) { alert("请完整填写"); return; }
                if (DB.users.find(u => u.no === no)) { alert("编号已存在"); return; }
                DB.users.push({ no, pwd, role, realName: name, empId: null });
                save(); render(); modal.remove();
            };
            document.getElementById('cancelAdd').onclick = () => modal.remove();
        };
    }

    function renderBackupPage(container) {
        let h = `<div class="page-title">💾 数据维护</div>
        <div class="card">
            <div class="config-row"><label>绩效基数（元/月）:</label><input type="number" id="baseSalaryInput" value="${GlobalConfig.baseSalary}" step="50"> <button id="saveConfigBtn">保存配置</button></div>
            <div class="config-row"><label>年底预留比例（%）：</label><input type="number" id="reservePercentInput" value="${GlobalConfig.reservePercent}" step="5"> <span class="badge">平时考核满分 = 100 - 预留比例</span></div>
            <hr style="margin:12px 0;">
            <button id="fullExport" style="width:100%;margin-bottom:12px;">📤 导出全部数据</button>
            <button id="fullImportBtn" style="width:100%;margin-bottom:12px;">📂 导入备份</button>
            <input type="file" id="fullImportFile" style="display:none">
            <hr>
            <button id="formatBtn" class="danger" style="width:100%;margin-bottom:12px;">🗑️ 格式化（清空）</button>
            <button id="initBtn" class="warning" style="width:100%;">🔄 初始化（测试数据）</button>
        </div>`;
        container.innerHTML = h;
        document.getElementById('saveConfigBtn').onclick = () => {
            let newBase = parseInt(document.getElementById('baseSalaryInput').value) || 700;
            let newReserve = parseInt(document.getElementById('reservePercentInput').value) || 20;
            GlobalConfig.baseSalary = newBase;
            GlobalConfig.reservePercent = newReserve;
            save();
            alert("配置已保存");
            render();
        };
        document.getElementById('fullExport').onclick = () => exportExcel({ users: DB.users, persons: DB.persons, groups: DB.groups, items: DB.items, monthList: DB.monthList, monthsData: DB.monthsData, logs: DB.logs, curMonthId: DB.curMonthId, config: GlobalConfig }, "完整备份.xlsx");
        document.getElementById('fullImportBtn').onclick = () => document.getElementById('fullImportFile').click();
        document.getElementById('fullImportFile').onchange = e => importExcel(e.target.files[0], rows => { if (rows.length) { let d = rows[0]; if (d.users) DB.users = d.users; if (d.persons) DB.persons = d.persons; if (d.groups) DB.groups = d.groups; if (d.items) DB.items = d.items; if (d.monthList) DB.monthList = d.monthList; if (d.monthsData) DB.monthsData = d.monthsData; if (d.logs) DB.logs = d.logs; if (d.curMonthId) DB.curMonthId = d.curMonthId; if (d.config) { GlobalConfig.baseSalary = d.config.baseSalary || 700; GlobalConfig.reservePercent = d.config.reservePercent || 20; } save(); render(); } });
        document.getElementById('formatBtn').onclick = () => { if (confirm("格式化将删除所有数据！")) { localStorage.removeItem("perfSystem"); DB.users = [{ no:"admin", pwd:"admin", role:"系统管理员", realName:"系统管理员", empId:null }]; DB.persons = []; DB.groups = []; DB.items = []; DB.monthList = []; DB.monthsData = {}; DB.logs = []; DB.curMonthId = ""; GlobalConfig.baseSalary = 700; GlobalConfig.reservePercent = 20; save(); load(); render(); } };
        document.getElementById('initBtn').onclick = () => { if (confirm("初始化恢复默认测试数据")) { localStorage.removeItem("perfSystem"); initDefaultData(); load(); render(); } };
    }

    function initLogin() {
        const username = document.getElementById('loginUsername');
        const password = document.getElementById('loginPassword');
        const loginBtn = document.getElementById('loginBtn');
        username.addEventListener('keypress', (e) => { if (e.key === 'Enter') password.focus(); });
        password.addEventListener('keypress', (e) => { if (e.key === 'Enter') loginBtn.click(); });
        loginBtn.onclick = () => {
            let no = username.value.trim();
            let pwd = password.value;
            let user = DB.users.find(u => u.no === no && u.pwd === pwd);
            if (user) {
                DB.curUser = user;
                document.getElementById('currentUserName').innerText = user.realName;
                document.getElementById('loginContainer').style.display = 'none';
                document.getElementById('mainApp').style.display = 'flex';
                load(); render();
            } else alert("用户编号或密码错误");
        };
        document.getElementById('logoutBtn').onclick = () => { DB.curUser = null; document.getElementById('loginContainer').style.display = 'flex'; document.getElementById('mainApp').style.display = 'none'; };
    }

    function bindMenu() {
        document.querySelectorAll('.menu-item').forEach(item => item.addEventListener('click', () => {
            document.querySelectorAll('.menu-item').forEach(m => m.classList.remove('active'));
            item.classList.add('active');
            DB.curPage = item.dataset.page;
            render();
        }));
    }
    function initCollapse() {
        const trigger = document.getElementById('collapseTrigger');
        trigger.onclick = () => document.getElementById('sidebar').classList.toggle('collapsed');
    }

    load(); initLogin(); bindMenu(); initCollapse();
</script>
</body>
</html>