<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>武汉市新华书店 · 集团供应中心工具箱</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            min-height: 100vh;
            background: radial-gradient(circle at 20% 30%, #0a0f1e, #03060c);
            font-family: 'Segoe UI', 'Inter', system-ui, sans-serif;
            padding: 2rem;
            position: relative;
        }
        .orb {
            position: fixed;
            width: 60vmax;
            height: 60vmax;
            border-radius: 50%;
            filter: blur(80px);
            animation: float 20s infinite alternate ease-in-out;
            pointer-events: none;
            z-index: 0;
        }
        .orb1 { top: -20vh; left: -20vw; background: radial-gradient(circle, rgba(0, 200, 255, 0.2), transparent 80%); }
        .orb2 { bottom: -30vh; right: -10vw; width: 70vmax; height: 70vmax; background: radial-gradient(circle, rgba(150, 0, 255, 0.15), transparent 70%); animation-duration: 25s; }
        @keyframes float {
            0% { transform: translate(0, 0) scale(1); opacity: 0.6; }
            100% { transform: translate(5%, 5%) scale(1.1); opacity: 0.9; }
        }
        .container { position: relative; z-index: 2; max-width: 1400px; margin: 0 auto; }
        .hero { text-align: center; margin-bottom: 3rem; }
        .hero h1 { font-size: 3rem; font-weight: 800; background: linear-gradient(135deg, #FFFFFF, #A0D8FF, #7AA2F7); background-clip: text; -webkit-background-clip: text; color: transparent; }
        .hero p { color: #9aaec7; font-size: 1rem; margin-top: 0.5rem; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem; margin: 2rem 0; }
        .card {
            background: rgba(20, 28, 40, 0.65);
            backdrop-filter: blur(12px);
            border-radius: 2rem;
            border: 1px solid rgba(72, 187, 255, 0.3);
            padding: 1.5rem;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            cursor: pointer;
        }
        .card:hover { transform: translateY(-6px); border-color: #00b4ff; background: rgba(25, 35, 55, 0.8); box-shadow: 0 20px 30px -12px black; }
        .icon { font-size: 3rem; margin-bottom: 0.8rem; }
        .card h3 { font-size: 1.4rem; font-weight: 600; color: #eef5ff; margin-bottom: 0.5rem; }
        .card p { color: #b9c8f0; font-size: 0.85rem; line-height: 1.5; flex: 1; margin-bottom: 1rem; }
        .badge { background: rgba(0, 180, 255, 0.2); border-radius: 40px; padding: 0.2rem 1rem; font-size: 0.7rem; color: #7bc5ff; width: fit-content; }
        .card-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 0.5rem; }
        .btn-launch {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(0, 212, 255, 0.5);
            color: #cae9ff;
            padding: 0.3rem 1rem;
            border-radius: 40px;
            font-size: 0.75rem;
            cursor: pointer;
            transition: 0.2s;
        }
        .btn-launch:hover { background: rgba(0, 160, 255, 0.3); border-color: cyan; }
        .footer-note { text-align: center; color: #62748c; border-top: 1px solid rgba(72, 120, 184, 0.3); padding-top: 2rem; margin-top: 1rem; font-size: 0.8rem; }
        @media (max-width: 700px) { .hero h1 { font-size: 2rem; } }
    </style>
</head>
<body>
<div class="orb orb1"></div>
<div class="orb orb2"></div>

<div class="container">
    <div class="hero">
        <h1>📚 武汉市新华书店 · 集团供应中心工具箱</h1>
        <p>导航自动同步云端 | 断网自动兜底</p>
    </div>

    <div class="grid" id="toolsGrid"></div>

    <div class="footer-note">
        💡 网络正常时读取云端导航，断网时自动加载内置工具，永不掉线。
    </div>
</div>

<script>
const DEFAULT_TOOLS = [
    { id: "entry", name: "📝 数据录入", desc: "快速扫码/手动录入图书，支持三种模式，自动合并重复书号，生成发货单与汇总单。", icon: "📚", url: "工具箱-数据录入.html" },
    { id: "review", name: "✅ 数据复核", desc: "导入Excel数据复核，自动识别ISBN列，过滤空列，支持双击编辑和ISBN快速定位。", icon: "🔍", url: "工具箱-数据复核.html" },
    { id: "transfer", name: "🔄 批销直转", desc: "将供货商Excel转换为标准批销格式，按包号分组打包ZIP，智能列映射。", icon: "📦", url: "工具箱-数据直转.html" },
    { id: "dd", name: "🧾 订单大屏", desc: "通过大屏展示订单的到货情况批销情况。", icon: "📈", url: "工具箱-订单大屏.html" },
    { id: "dd-jd", name: "📑 订单大屏简单版", desc: "通过大屏展示订单的简单到货情况。", icon: "📉", url: "工具箱-订单大屏简单版.html" },
    { id: "jh", name: "💡 鲲鹏计划", desc: "一个简单的计划展示大屏幕。", icon: "💎", url: "工具箱-鲲鹏计划AI版.html" },
    { id: "jxkh", name: "⌚绩效考核", desc: "一个简单的绩效记录工具", icon: "📆", url: "工具箱-绩效管理.html" },
    { id: "fh-jq", name: "🎡数据复核-加强版", desc: "数据复核功能的加强版本，能对比订单批销数据的差异", icon: "🎡", url: "工具箱-数据复核(加强版).html" },
    { id: "jxkh-jq", name: "🎒工具箱-绩效管理（持久数据版）", desc: "绩效管理工具，能做简单的绩效打分，数据能持久化", icon: "⚽", url: "工具箱-绩效管理(持久数据版).html" }
];

async function load() {
    //let list = DEFAULT_TOOLS;
	let list = '';
    try {
        const r = await fetch('/api/tools', { signal: AbortSignal.timeout(3000) });
        if (r.ok) {
            const data = await r.json();
            if (Array.isArray(data) && data.length > 0) list = data;
        }
    } catch (e) {}
    render(list);
}

function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>"]/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[m]));
}

function render(list) {
    const dom = document.getElementById('toolsGrid');
    dom.innerHTML = list.map(t => `
    <div class="card" onclick="window.open('${escapeHtml(t.url)}','_blank')">
        <div class="icon">${escapeHtml(t.icon || '📄')}</div>
        <h3>${escapeHtml(t.name)}</h3>
        <p>${escapeHtml(t.desc || '无描述')}</p>
        <div class="card-footer">
            <span class="badge">⚙️ 工具</span>
            <button class="btn-launch" onclick="event.stopPropagation();window.open('${escapeHtml(t.url)}','_blank')">🚀 启动</button>
        </div>
    </div>
    `).join('');	
}

load();
</script>
</body>
</html>