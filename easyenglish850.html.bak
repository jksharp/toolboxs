<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>Basic English 850 · 关联例句 · 三引擎发音学习卡</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }
        body {
            background: #f4fafd;
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            padding: 20px 16px 40px;
            color: #1a3a4f;
        }
        .app-container {
            max-width: 720px;
            margin: 0 auto;
        }
        .header-area {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
            flex-wrap: wrap;
            gap: 12px;
        }
        .hero h1 {
            font-size: 1.6rem;
            font-weight: 700;
            background: linear-gradient(135deg, #1f6d5c, #0e5a6b);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }
        .badge {
            background: #e1eff5;
            padding: 5px 14px;
            border-radius: 40px;
            font-size: 0.7rem;
            color: #1f6d6a;
            display: inline-block;
            margin-top: 4px;
        }
        .settings-icon {
            background: white;
            border-radius: 60px;
            padding: 8px 18px;
            font-size: 0.85rem;
            font-weight: 500;
            color: #2c7da0;
            border: 1px solid #d0e2ef;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .modal-mask {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(3px);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
            visibility: hidden;
            opacity: 0;
            transition: 0.2s;
        }
        .modal-mask.active {
            visibility: visible;
            opacity: 1;
        }
        .modal-card {
            background: white;
            width: 85%;
            max-width: 340px;
            border-radius: 40px;
            padding: 24px 22px;
            box-shadow: 0 25px 40px rgba(0,0,0,0.2);
            text-align: center;
        }
        .modal-card h3 {
            font-size: 1.3rem;
            margin-bottom: 18px;
            color: #1f5e76;
        }
        .group-size-control {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #eff5f9;
            padding: 10px 16px;
            border-radius: 60px;
            margin: 12px 0;
        }
        .modal-option {
            margin: 16px 0;
            text-align: left;
        }
        .modal-option label {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 0;
            font-size: 0.9rem;
        }
        .cache-status-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 12px;
            background: #eef2f6;
            padding: 10px 16px;
            border-radius: 60px;
        }
        .cache-btn {
            background: #2c7da0;
            border: none;
            color: white;
            padding: 8px 14px;
            border-radius: 40px;
            cursor: pointer;
            font-size: 0.75rem;
        }
        .close-modal {
            background: #2c7da0;
            border: none;
            color: white;
            padding: 10px 0;
            width: 100%;
            border-radius: 60px;
            font-weight: 500;
            margin-top: 16px;
            cursor: pointer;
        }
        .progress-card {
            background: white;
            border-radius: 28px;
            padding: 16px 18px;
            margin-bottom: 20px;
        }
        .stats-row {
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 10px;
        }
        .group-info {
            background: #eef3f8;
            border-radius: 40px;
            padding: 4px 14px;
            font-size: 0.8rem;
        }
        .daily-progress {
            font-size: 0.75rem;
            background: #edf2f6;
            border-radius: 40px;
            padding: 4px 12px;
        }
        .progress-bar {
            background: #e2eaf0;
            border-radius: 20px;
            height: 8px;
            margin: 10px 0 6px;
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #2b9b7e, #1f6e8a);
            border-radius: 20px;
            width: 0%;
            transition: width 0.25s;
        }
        .tiny-stats {
            font-size: 0.7rem;
            text-align: right;
            color: #7c97ad;
        }
        .cards-grid {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }
        .word-card {
            background: white;
            border-radius: 32px;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            border: 1px solid #e5f0f7;
        }
        .card-header {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: baseline;
            gap: 8px;
            margin-bottom: 10px;
        }
        .word-main {
            font-size: 1.6rem;
            font-weight: 700;
            color: #1e5c73;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .speaker-btn {
            background: #eef3fc;
            border: none;
            border-radius: 50%;
            width: 36px;
            height: 36px;
            font-size: 1rem;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .pronounce, .pos {
            font-size: 0.7rem;
            background: #eef2f7;
            padding: 3px 10px;
            border-radius: 30px;
        }
        .meaning {
            font-size: 0.95rem;
            font-weight: 500;
            margin: 10px 0 8px;
        }
        .example-area {
            background: #fafeff;
            border-radius: 20px;
            padding: 12px 14px;
            margin: 12px 0 8px;
            border-left: 3px solid #8bc6db;
        }
        .example-en {
            font-size: 0.9rem;
            color: #1e4c61;
            font-style: italic;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }
        .example-zh {
            font-size: 0.85rem;
            background: #fef7e0;
            padding: 6px 10px;
            border-radius: 16px;
            display: none;
            margin-top: 10px;
        }
        .example-zh.show {
            display: block;
        }
        .example-actions {
            margin-top: 8px;
        }
        .icon-btn {
            background: #f0f5fa;
            border: none;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 0.7rem;
            cursor: pointer;
        }
        .mark-btn {
            background: #f0f5fb;
            border: none;
            padding: 7px 20px;
            border-radius: 40px;
            font-size: 0.75rem;
            margin-top: 12px;
            float: right;
            cursor: pointer;
        }
        .mark-btn.learned {
            background: #dff0e6;
            color: #24775c;
        }
        .list-view {
            background: white;
            border-radius: 28px;
            overflow: hidden;
        }
        .list-item {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            padding: 12px 16px;
            border-bottom: 1px solid #e8f0f5;
            gap: 8px;
        }
        .nav-buttons {
            display: flex;
            gap: 12px;
            margin: 20px 0;
        }
        .nav-btn {
            flex: 1;
            background: white;
            border: 1px solid #cde0ea;
            padding: 10px 0;
            border-radius: 50px;
            font-weight: 500;
            text-align: center;
            cursor: pointer;
        }
        .nav-btn.disabled {
            opacity: 0.4;
            pointer-events: none;
        }
        .reset-btn {
            background: #fff1e2;
            border-color: #e2cba3;
        }
        .footer-note {
            text-align: center;
            font-size: 0.7rem;
            color: #94b1c2;
            margin-top: 30px;
        }
        @media (max-width: 550px) {
            .word-main { font-size: 1.4rem; }
        }
    </style>
</head>
<body>
<div class="app-container">
    <div class="header-area">
        <div class="hero">
            <h1>📘 Basic English 850</h1>
            <div class="badge">关联例句 · 完整音标 · 三引擎发音</div>
        </div>
        <div class="settings-icon" id="settingsBtn">⚙️ 设置</div>
    </div>

    <!-- 弹窗设置 -->
    <div id="modalOverlay" class="modal-mask">
        <div class="modal-card">
            <h3>⚙️ 学习与发音设置</h3>
            <div class="group-size-control">
                <span>📚 每组数量</span>
                <input type="number" id="modalGroupSize" min="5" max="40" value="10" style="width:70px; padding:6px; border-radius:30px; border:1px solid #ccc; text-align:center;">
            </div>
            <div class="modal-option">
                <div style="margin-bottom:6px; font-weight:600;">🔊 发音引擎</div>
                <label><input type="radio" name="ttsEngine" value="browser" checked> 🌐 浏览器原生语音 (离线/免费)</label>
                <label><input type="radio" name="ttsEngine" value="youdao"> 📡 有道API (网络/支持句子)</label>
                <label><input type="radio" name="ttsEngine" value="offline"> 💾 离线缓存 (需预下载单词)</label>
                <div style="font-size:0.7rem; color:#6f98b0; margin-top:6px;">* 离线模式仅支持已下载的单词，例句仍走浏览器或有道</div>
            </div>
            <div class="cache-status-row">
                <span>🎧 离线包状态</span>
                <button id="downloadOfflineBtn" class="cache-btn">📥 下载全部单词</button>
            </div>
            <div style="font-size:0.7rem; color:#6f98b0; text-align:left; margin-top:6px;" id="cacheStatusText">未下载</div>
            <button id="clearOfflineBtn" class="cache-btn" style="background:#b5651e; margin-top:8px;">🗑️ 清除离线缓存</button>
            <button id="modalApplyBtn" class="close-modal">✔️ 保存并关闭</button>
        </div>
    </div>

    <div class="progress-card">
        <div class="stats-row">
            <span class="group-info" id="groupLabel">第1组 / 共?组</span>
            <span class="daily-progress" id="groupCompleteLabel">📖 已掌握 0 / 0</span>
        </div>
        <div class="progress-bar"><div class="progress-fill" id="globalProgressFill"></div></div>
        <div class="tiny-stats">✅ 总进度: <span id="totalLearnedSpan">0</span> / 850 词 · 例句包含当前单词</div>
    </div>

    <div id="dynamicContainer"></div>

    <div class="nav-buttons">
        <button id="prevGroupBtn" class="nav-btn">◀ 上一组</button>
        <button id="resetAllBtn" class="nav-btn reset-btn">🔄 重置标记</button>
        <button id="nextGroupBtn" class="nav-btn">下一组 ▶</button>
    </div>
    <div class="footer-note">
        💡 三种发音模式自由切换：浏览器(离线免流量) / 有道(网络高质量) / 离线(预下载后完全离线)<br>
        📖 每个单词的例句都包含该单词本身，帮助理解用法。
    </div>
</div>

<script>
    // ======================= 1. 完整850词库 (字母排序) =======================
    const rawWords = [
        "a","able","about","account","acid","across","act","addition","adjustment","advertisement",
        "after","again","against","agreement","air","all","almost","among","amount","amusement",
        "and","angle","angry","animal","answer","ant","any","apparatus","apple","approval",
        "arch","argument","arm","army","art","as","at","attack","attempt","attention",
        "attraction","authority","automatic","awake","baby","back","bad","bag","balance","ball",
        "band","base","basin","basket","bath","be","beautiful","because","bed","bee",
        "before","behavior","belief","bell","bent","berry","between","bird","birth","bit",
        "bite","bitter","black","blade","blood","blow","blue","board","boat","body",
        "boiling","bone","book","boot","bottle","box","boy","brain","brake","branch",
        "brass","bread","break","breath","brick","bridge","bright","broken","brother","brown",
        "brush","bucket","building","bulb","burn","burst","business","but","butter","button",
        "by","cake","camera","canvas","card","care","carriage","cart","cat","cause",
        "certain","chain","chalk","chance","change","cheap","cheese","chemical","chest","chief",
        "chin","church","circle","clean","clear","clock","cloth","cloud","coal","coat",
        "cold","collar","color","comb","come","comfort","committee","common","company","comparison",
        "competition","complete","complex","condition","connection","conscious","control","cook","copper","copy",
        "cord","cork","cotton","cough","country","cover","cow","crack","credit","crime",
        "cruel","crush","cry","cup","current","curtain","curve","cushion","damage","danger",
        "dark","daughter","day","dead","dear","death","debt","decision","deep","degree",
        "delicate","dependent","design","desire","destruction","detail","development","different","digestion","direction",
        "dirty","discovery","discussion","disease","disgust","distance","distribution","division","do","dog",
        "door","doubt","down","drain","drawer","dress","drink","driving","drop","dry",
        "dust","ear","early","earth","east","edge","education","effect","egg","elastic",
        "electric","end","engine","enough","equal","error","even","event","ever","every",
        "example","exchange","existence","expansion","experience","expert","eye","face","fact","fall",
        "false","family","far","farm","fat","father","fear","feather","feeble","feeling",
        "female","fertile","fiction","field","fight","finger","fire","first","fish","fixed",
        "flag","flame","flat","flight","floor","flower","fly","fold","food","foolish",
        "foot","for","force","fork","form","forward","fowl","frame","free","frequent",
        "friend","from","front","fruit","full","future","garden","general","get","girl",
        "give","glass","glove","go","goat","gold","good","government","grain","grass",
        "great","green","grey","grip","group","growth","guide","gun","hair","hammer",
        "hand","hanging","happy","harbor","hard","harmony","hat","hate","have","he",
        "head","healthy","hearing","heart","heat","help","here","high","history","hole",
        "hollow","hook","hope","horn","horse","hospital","hour","house","how","humor",
        "I","ice","idea","if","ill","important","impulse","in","increase","industry",
        "ink","insect","instrument","insurance","interest","invention","iron","island","jelly","jewel",
        "join","journey","judge","jump","keep","kettle","key","kick","kind","kiss",
        "knee","knife","knot","knowledge","land","language","last","late","laugh","law",
        "lead","leaf","learning","leather","left","leg","let","letter","level","library",
        "lift","light","like","limit","line","linen","lip","liquid","list","little",
        "living","lock","long","look","loose","loss","loud","love","low","machine",
        "make","male","man","manager","map","mark","market","married","match","material",
        "may","meal","measure","meat","medical","meeting","memory","metal","middle","military",
        "milk","mind","mine","minute","mist","mixed","money","monkey","month","moon",
        "morning","mother","motion","mountain","mouth","move","much","muscle","music","nail",
        "name","narrow","nation","natural","near","necessary","neck","need","needle","nerve",
        "net","new","news","night","no","noise","normal","north","nose","not",
        "note","now","number","nut","observation","of","off","offer","office","oil",
        "old","on","only","open","operation","opinion","opposite","or","orange","order",
        "organization","ornament","other","out","oven","over","owner","page","pain","paint",
        "paper","parallel","parcel","part","past","paste","payment","peace","pen","pencil",
        "person","physical","picture","pig","pin","pipe","place","plane","plant","plate",
        "play","please","pleasure","plough","pocket","point","poison","polish","political","poor",
        "porter","position","possible","pot","potato","powder","power","present","price","print",
        "prison","private","probable","process","produce","profit","property","prose","protest","public",
        "pull","pump","punishment","purpose","push","put","quality","question","quick","quiet",
        "quite","rail","rain","range","rat","rate","ray","reaction","reading","ready",
        "reason","receipt","record","red","regret","relation","religion","representative","request","respect",
        "responsible","rest","reward","rhythm","rice","right","ring","river","road","rod",
        "roll","roof","room","root","rough","round","rub","rule","run","sad",
        "safe","sail","salt","same","sand","say","scale","school","science","scissors",
        "screw","sea","seat","second","secret","secretary","see","seed","seem","selection",
        "self","send","sense","separate","serious","servant","sex","shade","shake","shame",
        "sharp","sheep","shelf","ship","shirt","shock","shoe","short","shut","side",
        "sign","silk","silver","simple","sister","size","skin","skirt","sky","sleep",
        "slip","slope","slow","small","smash","smell","smile","smoke","smooth","snake",
        "sneeze","snow","so","soap","society","sock","soft","solid","son","song",
        "sort","sound","soup","space","spade","special","sponge","spoon","spring","square",
        "stamp","stage","star","start","statement","station","steam","stem","steel","step",
        "stick","sticky","still","stitch","stocking","stomach","stone","stop","store","story",
        "strange","street","stretch","stiff","straight","strong","structure","substance","such","sudden",
        "sugar","suggestion","summer","sun","support","surprise","sweet","swim","system","table",
        "tail","take","talk","tall","taste","tax","teaching","tendency","test","than",
        "that","the","then","theory","there","thick","thin","thing","this","though",
        "thought","thread","throat","through","thumb","thunder","ticket","tight","till","time",
        "tin","tired","to","toe","together","tomorrow","tongue","tooth","top","touch",
        "town","trade","train","transport","tray","tree","trick","trouble","trousers","true",
        "turn","twist","umbrella","under","unit","up","use","value","verse","very",
        "vessel","view","violent","voice","waiting","walk","wall","war","warm","wash",
        "waste","watch","water","wave","wax","way","weather","week","weight","well",
        "west","wet","wheel","when","where","while","whip","whistle","white","who",
        "why","wide","will","wind","window","wine","wing","winter","wire","wise",
        "with","woman","wood","wool","word","work","worm","wound","writing","wrong",
        "year","yellow","yes","yesterday","you","young"
    ];
    let unique = [...new Set(rawWords)].sort((a,b)=>a.localeCompare(b));
    while(unique.length < 850) unique.push(`word${unique.length}`);
    const TOTAL = 850;

    // 获取词性
    const getPos = (w) => {
        if(w.match(/^(a|an|the|this|that|these|those)$/)) return "det.";
        if(w.match(/(ly|ful|less|able|ive)$/i)) return "adj.";
        if(w.match(/(ize|ise|ate)$/i)) return "v.";
        if(w.length<=3 && !w.match(/[aeiou]/i)) return "conj./prep.";
        return "n.";
    };
    
    // ======================= 音标映射（850词完整）=======================
    const ipaMap = {
        "a": "/ə/ (或 /eɪ/)", "able": "/ˈeɪbəl/", "about": "/əˈbaʊt/", "account": "/əˈkaʊnt/", "acid": "/ˈæsɪd/",
        "across": "/əˈkrɔːs/", "act": "/ækt/", "addition": "/əˈdɪʃən/", "adjustment": "/əˈdʒʌstmənt/", "advertisement": "/ədˈvɜːrtɪsmənt/",
        "after": "/ˈæftər/", "again": "/əˈɡen/", "against": "/əˈɡenst/", "agreement": "/əˈɡriːmənt/", "air": "/er/",
        "all": "/ɔːl/", "almost": "/ˈɔːlmoʊst/", "among": "/əˈmʌŋ/", "amount": "/əˈmaʊnt/", "amusement": "/əˈmjuːzmənt/",
        "and": "/ənd/", "angle": "/ˈæŋɡəl/", "angry": "/ˈæŋɡri/", "animal": "/ˈænɪməl/", "answer": "/ˈænsər/",
        "ant": "/ænt/", "any": "/ˈeni/", "apparatus": "/ˌæpəˈrætəs/", "apple": "/ˈæpəl/", "approval": "/əˈpruːvəl/",
        "arch": "/ɑːrtʃ/", "argument": "/ˈɑːrɡjʊmənt/", "arm": "/ɑːrm/", "army": "/ˈɑːrmi/", "art": "/ɑːrt/",
        "as": "/æz/", "at": "/æt/", "attack": "/əˈtæk/", "attempt": "/əˈtempt/", "attention": "/əˈtenʃən/",
        "attraction": "/əˈtrækʃən/", "authority": "/əˈθɔːrəti/", "automatic": "/ˌɔːtəˈmætɪk/", "awake": "/əˈweɪk/",
        "baby": "/ˈbeɪbi/", "back": "/bæk/", "bad": "/bæd/", "bag": "/bæɡ/", "balance": "/ˈbæləns/", "ball": "/bɔːl/",
        "band": "/bænd/", "base": "/beɪs/", "basin": "/ˈbeɪsən/", "basket": "/ˈbæskɪt/", "bath": "/bæθ/", "be": "/biː/",
        "beautiful": "/ˈbjuːtɪfəl/", "because": "/bɪˈkɔːz/", "bed": "/bed/", "bee": "/biː/", "before": "/bɪˈfɔːr/",
        "behavior": "/bɪˈheɪvjər/", "belief": "/bɪˈliːf/", "bell": "/bel/", "bent": "/bent/", "berry": "/ˈberi/",
        "between": "/bɪˈtwiːn/", "bird": "/bɜːrd/", "birth": "/bɜːrθ/", "bit": "/bɪt/", "bite": "/baɪt/", "bitter": "/ˈbɪtər/",
        "black": "/blæk/", "blade": "/bleɪd/", "blood": "/blʌd/", "blow": "/bloʊ/", "blue": "/bluː/", "board": "/bɔːrd/",
        "boat": "/boʊt/", "body": "/ˈbɑːdi/", "boiling": "/ˈbɔɪlɪŋ/", "bone": "/boʊn/", "book": "/bʊk/", "boot": "/buːt/",
        "bottle": "/ˈbɑːtl/", "box": "/bɑːks/", "boy": "/bɔɪ/", "brain": "/breɪn/", "brake": "/breɪk/", "branch": "/bræntʃ/",
