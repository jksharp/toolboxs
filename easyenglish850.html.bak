    // ======================= 为每个单词生成关联例句（包含当前单词）=======================
    function makeExampleForWord(word) {
        // 使用模板，替换占位符，确保句子长度5-10词且其他单词来自基础词表
        const templates = [
            `I have a ${word}.`,
            `This ${word} is good.`,
            `Can you see the ${word}?`,
            `We need a new ${word}.`,
            `She likes the ${word} very much.`,
            `He gave me a ${word} yesterday.`,
            `The ${word} is on the table.`,
            `Please take the ${word} with you.`,
            `My friend has a ${word}.`,
            `Do you want this ${word}?`,
            `I found a ${word} in the garden.`,
            `The ${word} looks very nice.`,
            `We will use the ${word} tomorrow.`,
            `Is that your ${word}?`,
            `The ${word} is mine, not yours.`
        ];
        // 对于冠词、介词等特殊处理
        if(word === "a" || word === "an") return `I have ${word} pen.`;
        if(word === "the") return `The book is on the table.`;
        if(word === "and") return `I like tea and coffee.`;
        if(word === "but") return `I am tired but happy.`;
        if(word === "for") return `This gift is for you.`;
        if(word === "with") return `I go to school with my friend.`;
        if(word === "to") return `I want to go home.`;
        if(word === "be") return `I want to be a doctor.`;
        if(word === "have") return `I have a new car.`;
        if(word === "do") return `Do you like music?`;
        if(word === "say") return `I say hello to everyone.`;
        if(word === "make") return `She can make a cake.`;
        if(word === "go") return `Let's go to the park.`;
        if(word === "get") return `I will get the book.`;
        if(word === "see") return `I see a bird in the sky.`;
        if(word === "come") return `Please come to my party.`;
        if(word === "use") return `May I use your phone?`;
        // 通用模板
        let template = templates[Math.floor(Math.random() * templates.length)];
        // 确保单词正确插入（词性匹配）
        if(getPos(word).startsWith("v")) {
            template = `I often ${word} my work.`;
        }
        if(getPos(word) === "adj.") {
            template = `This is a ${word} day.`;
        }
        // 最终格式化
        let sentence = template.replace(/\${word}/g, word);
        if(!sentence.includes(word)) sentence = template.replace(/a /g, `a ${word} `).replace(/the /g, `the ${word} `);
        if(sentence.length < 15) sentence = `The ${word} is very useful.`;
        return sentence;
    }
    
    // 构建最终词库
    const VOCAB = unique.slice(0,TOTAL).map(w => {
        let exampleEn = makeExampleForWord(w);
        // 简单中文翻译（占位，用户可点击查看）
        let exampleZh = `例句：${exampleEn.replace(/[A-Za-z]+/g, (m) => meaningMap[m.toLowerCase()] || m)}`;
        return { 
            word: w, 
            ipa: getIpa(w), 
            pos: getPos(w), 
            meaning: meaningMap[w] || "常用词", 
            example_en: exampleEn, 
            example_zh: exampleZh 
        };
    });

    // ======================= 2. 发音引擎与离线缓存 =======================
    let ttsEngine = "browser";
    let db = null;
    const DB_NAME = "Basic850MultiEngine", STORE = "wordAudio";
    function initDB() {
        return new Promise((res,rej)=>{
            const req = indexedDB.open(DB_NAME,1);
            req.onupgradeneeded = e => { let db = e.target.result; if(!db.objectStoreNames.contains(STORE)) db.createObjectStore(STORE); };
            req.onsuccess = e => { db = e.target.result; res(); };
            req.onerror = rej;
        });
    }
    async function cacheAudio(key, blob) { if(!db) await initDB(); let tx = db.transaction(STORE,"readwrite"); tx.objectStore(STORE).put(blob,key); return new Promise(r=>tx.oncomplete=r); }
    async function getCachedAudio(key) { if(!db) await initDB(); return new Promise(r=>{ let req = db.transaction(STORE).objectStore(STORE).get(key); req.onsuccess = ()=>r(req.result); req.onerror = ()=>r(null); }); }
    async function clearOfflineCache() { if(!db) await initDB(); let tx = db.transaction(STORE,"readwrite"); tx.objectStore(STORE).clear(); return new Promise(r=>tx.oncomplete=r); }
    async function downloadFullOffline() {
        if(!confirm("下载全部850个单词的离线音频（约80-120MB），之后可完全离线发音。确定吗？")) return;
        const statusSpan = document.getElementById("cacheStatusText");
        statusSpan.innerText = "⏳ 下载中 0/850 ...";
        for(let i=0;i<TOTAL;i++){
            const w = VOCAB[i].word;
            const key = `word_${w}`;
            let cached = await getCachedAudio(key);
            if(!cached) {
                try {
                    const url = `https://dict.youdao.com/dictvoice?audio=${encodeURIComponent(w)}&type=2`;
                    const resp = await fetch(url);
                    if(resp.ok) {
                        const blob = await resp.blob();
                        await cacheAudio(key, blob);
                    }
                } catch(e) { console.warn(`下载${w}失败`,e); }
            }
            if((i+1)%50===0) statusSpan.innerText = `📥 下载中 ${i+1}/${TOTAL}`;
        }
        statusSpan.innerText = `✅ 离线包就绪！${TOTAL}个单词可离线发音`;
        setTimeout(()=>updateCacheStatusUI(),500);
    }
    async function updateCacheStatusUI() {
        if(!db) { document.getElementById("cacheStatusText").innerText = "未初始化"; return; }
        const tx = db.transaction(STORE,"readonly");
        const count = await new Promise(r=>{ let req=tx.objectStore(STORE).count(); req.onsuccess=()=>r(req.result); });
        document.getElementById("cacheStatusText").innerText = `已缓存 ${count} / 850 单词`;
    }
    // 统一发音调度
    async function speakWord(word) {
        if(ttsEngine === "browser") {
            if(!window.speechSynthesis) { alert("浏览器不支持语音"); return; }
            const utter = new SpeechSynthesisUtterance(word);
            utter.lang = "en-US";
            utter.rate = 0.9;
            window.speechSynthesis.cancel();
            window.speechSynthesis.speak(utter);
        } else if(ttsEngine === "youdao") {
            const audio = new Audio(`https://dict.youdao.com/dictvoice?audio=${encodeURIComponent(word)}&type=2`);
            audio.play().catch(e=>alert("有道发音失败，请检查网络"));
        } else if(ttsEngine === "offline") {
            const blob = await getCachedAudio(`word_${word}`);
            if(blob) {
                const url = URL.createObjectURL(blob);
                const audio = new Audio(url);
                audio.play();
                audio.onended = () => URL.revokeObjectURL(url);
            } else {
                alert("未下载离线包，请先下载单词离线包");
            }
        }
    }
    async function speakSentence(sentence) {
        if(ttsEngine === "browser" || ttsEngine === "offline") {
            if(window.speechSynthesis) {
                const utter = new SpeechSynthesisUtterance(sentence);
                utter.lang = "en-US";
                utter.rate = 0.9;
                window.speechSynthesis.cancel();
                window.speechSynthesis.speak(utter);
            } else {
                alert("浏览器不支持语音，请切换至有道模式");
            }
        } else {
            const audio = new Audio(`https://dict.youdao.com/dictvoice?audio=${encodeURIComponent(sentence)}&type=2`);
            audio.play().catch(e=>alert("有道发音失败"));
        }
    }

    // ======================= 3. 学习状态与渲染 =======================
    let learned = new Array(TOTAL).fill(false);
    let currentGroup = 0, groupSize = 10, viewMode = "card";
    function loadLearned() { const stored = localStorage.getItem("basic850_learned_v10"); if(stored) try{ let arr=JSON.parse(stored); if(arr.length===TOTAL) learned=arr; }catch(e){} }
    function saveLearned() { localStorage.setItem("basic850_learned_v10", JSON.stringify(learned)); }
    function loadGroupSize() { let sz = localStorage.getItem("basic850_groupSize_v10"); if(sz) groupSize=parseInt(sz); document.getElementById("modalGroupSize").value=groupSize; }
    function saveGroupSize() { localStorage.setItem("basic850_groupSize_v10", groupSize); }
    function getTotalGroups() { return Math.ceil(TOTAL/groupSize); }
    function getCurrentRange() { let start=currentGroup*groupSize, end=Math.min(start+groupSize,TOTAL); return {start,end, words:VOCAB.slice(start,end)}; }
    function render() {
        let {start,end,words} = getCurrentRange();
        let totalGroups = getTotalGroups();
        let groupCompleted = words.filter((_,i)=>learned[start+i]).length;
        document.getElementById("groupLabel").innerHTML = `第${currentGroup+1}组 / 共${totalGroups}组`;
        document.getElementById("groupCompleteLabel").innerHTML = `📖 已掌握 ${groupCompleted}/${words.length}`;
        let totalLearned = learned.filter(v=>v).length;
        document.getElementById("totalLearnedSpan").innerText = totalLearned;
        document.getElementById("globalProgressFill").style.width = (totalLearned/TOTAL)*100+"%";
        let container = document.getElementById("dynamicContainer");
        if(viewMode==="card"){
            let html="";
            for(let i=0;i<words.length;i++){
                let w=words[i], gid=start+i, isLearned=learned[gid];
                html+=`<div class="word-card"><div class="card-header"><div class="word-main">${w.word}<button class="speaker-word" data-word="${w.word}">🔊</button></div><div><span class="pronounce">${w.ipa}</span> <span class="pos">${w.pos}</span></div></div><div class="meaning">📖 ${w.meaning}</div><div class="example-area"><div class="example-en">💬 ${w.example_en}<button class="speaker-example" data-sentence="${w.example_en.replace(/"/g,'&quot;')}">🔊</button></div><div class="example-zh" id="zh-${gid}">📝 ${w.example_zh}</div><div class="example-actions"><button class="icon-btn translate-btn" data-id="${gid}">🌐 查看翻译</button></div></div><button class="mark-btn ${isLearned?'learned':''}" data-global="${gid}">${isLearned?'✅ 已掌握':'📌 标记掌握'}</button></div>`;
            }
            container.innerHTML=html;
            document.querySelectorAll('.speaker-word').forEach(btn=>btn.addEventListener('click',e=>{ e.stopPropagation(); speakWord(btn.dataset.word); }));
            document.querySelectorAll('.speaker-example').forEach(btn=>btn.addEventListener('click',e=>{ e.stopPropagation(); speakSentence(btn.dataset.sentence); }));
            document.querySelectorAll('.translate-btn').forEach(btn=>btn.addEventListener('click',e=>{ let zhDiv=document.getElementById(`zh-${btn.dataset.id}`); if(zhDiv) zhDiv.classList.toggle('show'); }));
            document.querySelectorAll('.mark-btn').forEach(btn=>btn.addEventListener('click',e=>{ let gid=parseInt(btn.dataset.global); learned[gid]=!learned[gid]; saveLearned(); render(); }));
        } else {
            let listHtml=`<div class="list-view">`;
            for(let i=0;i<words.length;i++){ let w=words[i], gid=start+i; listHtml+=`<div class="list-item"><div><strong>${w.word}</strong> ${w.ipa}</div><div>${w.meaning}</div><div><button class="list-speaker-word" data-word="${w.word}">🔊</button><button class="list-speaker-ex" data-sentence="${w.example_en.replace(/"/g,'&quot;')}">例句🔊</button></div><div class="list-mark" data-global="${gid}">${learned[gid]?'✔️':'○'}</div></div>`; }
            listHtml+=`</div>`; container.innerHTML=listHtml;
            document.querySelectorAll('.list-speaker-word').forEach(btn=>btn.addEventListener('click',e=>{ speakWord(btn.dataset.word); }));
            document.querySelectorAll('.list-speaker-ex').forEach(btn=>btn.addEventListener('click',e=>{ speakSentence(btn.dataset.sentence); }));
            document.querySelectorAll('.list-mark').forEach(mark=>mark.addEventListener('click',e=>{ let gid=parseInt(mark.dataset.global); learned[gid]=!learned[gid]; saveLearned(); render(); }));
        }
        let prevBtn=document.getElementById("prevGroupBtn"), nextBtn=document.getElementById("nextGroupBtn");
        if(prevBtn) { if(currentGroup===0) prevBtn.classList.add("disabled"); else prevBtn.classList.remove("disabled"); }
        if(nextBtn) { if(currentGroup===totalGroups-1) nextBtn.classList.add("disabled"); else nextBtn.classList.remove("disabled"); }
    }
    function changeGroup(delta){ let ng=currentGroup+delta; if(ng>=0 && ng<getTotalGroups()){ currentGroup=ng; render(); window.scrollTo(0,0); } }
    function applyModalSettings(){
        let newSize = parseInt(document.getElementById("modalGroupSize").value);
        if(newSize>=5 && newSize<=40) { groupSize=newSize; saveGroupSize(); currentGroup=0; }
        let selected = document.querySelector('input[name="ttsEngine"]:checked').value;
        ttsEngine = selected;
        localStorage.setItem("basic850_ttsEngine", ttsEngine);
        render();
        document.getElementById("modalOverlay").classList.remove("active");
    }
    function resetAllMark(){ if(confirm("重置所有掌握标记?")){ learned.fill(false); saveLearned(); render(); } }
    function setViewMode(mode){ viewMode=mode; document.getElementById("cardViewBtn").classList.toggle("active",mode==="card"); document.getElementById("listViewBtn").classList.toggle("active",mode==="list"); render(); }
    (async function init(){
        await initDB();
        loadLearned(); loadGroupSize();
        let savedEngine = localStorage.getItem("basic850_ttsEngine");
        if(savedEngine && ["browser","youdao","offline"].includes(savedEngine)) ttsEngine = savedEngine;
        document.querySelector(`input[name="ttsEngine"][value="${ttsEngine}"]`).checked = true;
        render();
        updateCacheStatusUI();
        document.getElementById("settingsBtn").onclick = ()=>document.getElementById("modalOverlay").classList.add("active");
        document.getElementById("modalApplyBtn").onclick = applyModalSettings;
        document.getElementById("modalOverlay").onclick = (e)=>{ if(e.target===document.getElementById("modalOverlay")) document.getElementById("modalOverlay").classList.remove("active"); };
        document.getElementById("downloadOfflineBtn").onclick = downloadFullOffline;
        document.getElementById("clearOfflineBtn").onclick = async ()=>{ await clearOfflineCache(); updateCacheStatusUI(); alert("离线缓存已清除"); };
        document.getElementById("prevGroupBtn").onclick = ()=>changeGroup(-1);
        document.getElementById("nextGroupBtn").onclick = ()=>changeGroup(1);
        document.getElementById("resetAllBtn").onclick = resetAllMark;
        document.getElementById("cardViewBtn").onclick = ()=>setViewMode("card");
        document.getElementById("listViewBtn").onclick = ()=>setViewMode("list");
    })();
</script>
</body>
</html>