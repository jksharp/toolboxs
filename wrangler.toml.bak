name = "toolboxs"
compatibility_date = "2026-05-23"
pages_build_output_dir = "./"

[[kv_namespaces]]
binding = "MY_KV"
id = "b4e04b3f55904a018aec459dd412cd05"
preview_id = "b4e04b3f55904a018aec459dd412cd05"

# 添加 D1 数据库绑定
[[d1_databases]]
binding = "DB"               # 代码中使用的变量名
database_name = "erp_db"     # 您的 D1 数据库名称
database_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # 需要填写实际的数据库 ID