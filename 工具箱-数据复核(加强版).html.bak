<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>数据复核 · 新华书店工具箱</title>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #eef2f7; font-family: 'Segoe UI', Roboto, sans-serif; height: 100vh; overflow: hidden; font-size: 13px; }
        .app-container { display: flex; flex-direction: column; height: 100vh; background: white; }
        .global-header { background: linear-gradient(135deg, #1e3c72, #2a4b7a); color: white; padding: 8px 20px; flex-shrink: 0; }
        .global-header h1 { font-size: 1.2rem; font-weight: 500; }
        .mode-bar { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 8px 20px; display: flex; gap: 24px; align-items: center; flex-shrink: 0; }
        .mode-radio-group { display: flex; gap: 20px; background: white; padding: 4px 16px; border-radius: 40px; box-shadow: 0 0 0 1px #e2e8f0; }
        .mode-radio-group label { display: flex; align-items: center; gap: 8px; cursor: pointer; font-weight: 500; color: #1e293b; }
        .mode-radio-group input { accent-color: #2b4c7c; width: 16px; height: 16px; margin: 0; }
        .mode-tip { font-size: 0.7rem; color: #4b6b8f; background: #f1f5f9; padding: 4px 12px; border-radius: 24px; }
        .review-panel { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .panel-hidden { display: none !important; }
        /* 普通复核样式 */
        .module { display: flex; flex-direction: column; height: 100%; background: white; }
        .toolbar { background: #fefefe; padding: 6px 16px; border-bottom: 1px solid #e2e8f0; display: flex; flex-wrap: wrap; gap: 8px; align-items: center; flex-shrink: 0; }
        button { border: none; background: #eef2f7; padding: 5px 14px; border-radius: 20px; font-size: 0.75rem; font-weight: 500; cursor: pointer; font-family: inherit; transition: 0.1s; }
        button.primary { background: #2b4c7c; color: white; }
        button.success { background: #e3f7ec; color: #2b6e3c; }
        button.danger { background: #fee2e2; color: #b91c1c; }
        .table-wrap { flex: 1; overflow: auto; padding: 0 12px 6px 12px; }
        .review-table { width: max-content; min-width: 100%; border-collapse: collapse; font-size: 0.75rem; }
        .review-table th, .review-table td { padding: 6px 10px; border-bottom: 1px solid #ecf3f9; }
        .review-table th { background: #f1f5f9; position: sticky; top: 0; }
        .result-panel { background: white; border-top: 1px solid #e2e8f0; flex-shrink: 0; max-height: 200px; overflow-y: auto; }
        .highlight-row { background-color: #fff3bf !important; }
        .search-group { display: flex; gap: 6px; align-items: center; background: #f1f5f9; padding: 2px 16px; border-radius: 32px; margin-left: auto; }
        .footer-note { padding: 4px 16px; font-size: 0.65rem; color: #5b6e8c; background: #fefefe; border-top: 1px solid #ecf3f9; flex-shrink: 0; }
        /* 多文件对比样式 */
        .base-file-area { background: #ffffff; border-bottom: 1px solid #ecf3f9; padding: 12px 20px; display: flex; gap: 24px; flex-wrap: wrap; flex-shrink: 0; }
        .file-card { flex: 1; min-width: 260px; background: #f9fbfd; border: 1px solid #e2edf7; border-radius: 16px; padding: 10px 16px; }
        .file-card h4 { font-size: 0.85rem; margin-bottom: 8px; }
        .file-status { font-size: 0.7rem; margin-top: 6px; color: #2c5a2e; }
        .target-files-container { flex: 1; overflow-y: auto; padding: 12px 20px; background: #fefefe; }
        .target-card { background: #f8fafc; border-radius: 16px; margin-bottom: 16px; padding: 12px 16px; border: 1px solid #e2edf7; }
        .target-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; flex-wrap: wrap; gap: 8px; }
        .target-name { font-weight: 600; font-size: 0.8rem; background: #eef2ff; padding: 4px 12px; border-radius: 30px; }
        .remove-file { color: #b91c1c; cursor: pointer; background: #fee2e2; padding: 2px 8px; border-radius: 20px; font-size: 0.65rem; }
        .section-title { font-weight: 600; font-size: 0.7rem; margin: 8px 0 4px 0; color: #2c5a2e; }
        .mapping-row { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-top: 6px; background: white; padding: 6px 10px; border-radius: 12px; }
        .mapping-row select { padding: 4px 8px; border-radius: 30px; border: 1px solid #cbd5e1; font-size: 0.7rem; min-width: 130px; }
        .tag-list { display: flex; flex-wrap: wrap; gap: 8px; margin: 6px 0 0 0; }
        .tag { background: #eef2ff; border-radius: 20px; padding: 2px 10px; font-size: 0.7rem; display: inline-flex; align-items: center; gap: 6px; }
        .tag button { background: none; border: none; color: #b91c1c; cursor: pointer; font-size: 0.9rem; line-height: 1; }
        .compare-actions { display: flex; gap: 12px; margin: 12px 20px; flex-shrink: 0; }
        .toast-tip { position: fixed; top: 40%; left: 50%; transform: translate(-50%,-50%); background: #333333ee; color: #ffdd99; padding: 12px 24px; border-radius: 40px; font-size: 1rem; z-index: 2000; pointer-events: none; border-left: 4px solid #f5a623; white-space: nowrap; }
        .empty-placeholder { text-align: center; color: #8ba0bc; padding: 30px; font-size: 0.8rem; }
        button.small { padding: 2px 8px; font-size: 0.65rem; }
    </style>
</head>
<body>
<div class="app-container">
    <div class="global-header">
        <h1>📚 数据复核 · 新华书店工具箱</h1>
        <p>普通复核 | 多文件对比 (基准文件 + 多个被对比文件，独立配置组合主键/对比字段)</p>
    </div>
    <div class="mode-bar">
        <div class="mode-radio-group">
            <label><input type="radio" name="reviewMode" value="normal" checked> 📋 普通复核</label>
            <label><input type="radio" name="reviewMode" value="compare"> 🔄 多文件对比复核 (一拖N)</label>
        </div>
        <div class="mode-tip" id="modeTip">普通模式：导入Excel，ISBN搜索/双击编辑</div>
    </div>
    <!-- 普通复核面板 -->
    <div id="normalPanel" class="review-panel">
        <div class="module">
            <div class="toolbar">
                <button id="importExcelBtn" class="primary">📂 导入Excel</button>
                <button id="exportReviewBtn" class="success">📎 导出Excel</button>
                <button id="clearReviewBtn" class="danger">🗑 清空数据</button>
                <div class="search-group"><span>🔍 ISBN/书号</span><input type="text" id="searchKeywordInput" placeholder="输入ISBN或书号"><button id="searchBtn">查找</button></div>
            </div>
            <div class="table-wrap"><table class="review-table"><thead id="reviewThead"></thead><tbody id="reviewTbody"></tbody></table></div>
            <div class="result-panel" id="resultPanel"><div class="result-header">🔍 查找结果</div><div>输入ISBN后按回车或点击查找</div></div>
            <div class="footer-note">💡 双击单元格编辑 | 点击表头排序 | 查找基于ISBN列</div>
        </div>
    </div>

    <!-- 多文件对比复核面板 -->
    <div id="comparePanel" class="review-panel panel-hidden">
        <div class="base-file-area">
            <div class="file-card">
                <h4>📁 基准文件 (对比文件 A)</h4>
                <input type="file" id="baseFileInput" accept=".xlsx,.xls,.csv" style="display:none">
                <button id="uploadBaseBtn" class="primary" style="background:#eef2f7; color:#1e3c72;">选择基准文件A</button>
                <div id="baseFileStatus" class="file-status">未加载</div>
            </div>
        </div>
        <div style="background:#f1f5f9; padding:6px 20px; display: flex; justify-content: space-between; align-items: center; flex-shrink: 0;">
            <span>📎 被对比文件列表 (每个文件独立配置组合主键 + 对比字段)</span>
            <button id="addTargetFileBtn" class="success">+ 添加被对比文件</button>
        </div>
        <div id="targetFilesContainer" class="target-files-container" style="overflow-y: auto; min-height: 150px;"></div>
        <div class="compare-actions">
            <button id="batchCompareBtn" class="primary">🔍 批量对比并导出 (ZIP包)</button>
        </div>
        <div class="footer-note">💡 每个被对比文件可配置多组主键（组合主键）和多组对比字段。导出Excel始终包含4个Sheet（匹配成功/仅在A/仅在B/字段不一致），无数据时显示提示。</div>
    </div>
</div>

<script>
(function(){
    let toastTimer = null;
    function showTip(msg, isErr = true, dur = 2500) {
        let tip = document.getElementById('globalTip');
        if(!tip){ tip = document.createElement('div'); tip.id = 'globalTip'; tip.className = 'toast-tip'; document.body.appendChild(tip); }
        tip.style.opacity = '1'; tip.innerText = msg;
        if(toastTimer) clearTimeout(toastTimer);
        toastTimer = setTimeout(() => { tip.style.opacity = '0'; }, dur);
    }
    function escapeHtml(str){ return String(str).replace(/[&<>]/g, function(m){ if(m==='&') return '&amp;'; if(m==='<') return '&lt;'; if(m==='>') return '&gt;'; return m;}); }
    function escapeAttr(str){ return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }

    // 智能比对
    function isValueEqual(v1, v2) {
        if (v1 === v2) return true;
        let s1 = String(v1 == null ? "" : v1).trim();
        let s2 = String(v2 == null ? "" : v2).trim();
        if (s1 === s2) return true;
        let n1 = parseFloat(s1);
        let n2 = parseFloat(s2);
        if (!isNaN(n1) && !isNaN(n2) && n1 === n2) return true;
        if (s1.toLowerCase() === s2.toLowerCase()) return true;
        return false;
    }

    // ---------- 普通复核逻辑 (保留) ----------
    const REVIEW_KEY = 'ReviewData_Final';
    let reviewCols = [], reviewRows = [], currentSort = { col: null, dir: null };
    let lastSearchKeyword = '', searchResults = [], currentHighlightIdx = -1, isbnColumn = null;
    function autoDetectIsbnColumn(cols) { const keys=['isbn','isbn号','书号','bookid']; for(let k of keys) if(cols.find(c=>c.toLowerCase().includes(k))) return cols.find(c=>c.toLowerCase().includes(k)); return cols[0]; }
    function renderReviewTable(){ 
        const thead = document.getElementById('reviewThead'), tbody = document.getElementById('reviewTbody');
        if(!thead || !tbody) return;
        if(!reviewCols.length){ thead.innerHTML = '<tr><th>暂无数据，请导入Excel</th><\/tr>'; tbody.innerHTML = ''; return; }
        let headerHtml = '<tr>';
        reviewCols.forEach(col => { let sortClass = (currentSort.col===col) ? (currentSort.dir==='asc'?' ▲':' ▼'):' ↕️'; let isbnBadge = (col===isbnColumn) ? ' <span style="background:#2b4c7c20; padding:2px 6px; border-radius:12px;">ISBN</span>' : ''; headerHtml += `<th>${escapeHtml(col)}${isbnBadge}<span class="sort-btn" data-col="${escapeAttr(col)}">${sortClass}</span><\/th>`; });
        headerHtml += '<\/tr>'; thead.innerHTML = headerHtml;
        document.querySelectorAll('#reviewThead .sort-btn').forEach(btn => { btn.onclick = (e) => { e.stopPropagation(); const colName = btn.getAttribute('data-col'); let newDir = 'asc'; if(currentSort.col === colName && currentSort.dir === 'asc') newDir = 'desc'; sortReview(colName, newDir); }; });
        let bodyHtml = ''; for(let idx=0; idx<reviewRows.length; idx++){ const row = reviewRows[idx]; bodyHtml += '<tr data-row-idx="'+idx+'">'; for(let ci=0; ci<reviewCols.length; ci++){ const col = reviewCols[ci]; const val = row[col] !== undefined ? row[col] : ''; bodyHtml += `<td ondblclick="window.editCell(${idx}, '${escapeAttr(col)}')">${escapeHtml(val)}<\/td>`; } bodyHtml += '<\/tr>'; }
        tbody.innerHTML = bodyHtml; if(lastSearchKeyword) applyHighlightNormal();
    }
    function applyHighlightNormal(){ const tbody = document.getElementById('reviewTbody'); if(!tbody) return; for(let i=0;i<tbody.rows.length;i++){ const rowIdx = parseInt(tbody.rows[i].getAttribute('data-row-idx')); if(searchResults.includes(rowIdx)) tbody.rows[i].classList.add('highlight-row'); else tbody.rows[i].classList.remove('highlight-row'); } if(currentHighlightIdx !== -1 && tbody.rows[currentHighlightIdx]) tbody.rows[currentHighlightIdx].classList.add('highlight-row'); }
    function sortReview(colName, dir){ const multiplier = dir === 'asc' ? 1 : -1; reviewRows.sort((a,b) => { let av = String(a[colName]||''), bv = String(b[colName]||''); let aNum = parseFloat(av), bNum = parseFloat(bv); if(!isNaN(aNum) && !isNaN(bNum)) return (aNum - bNum) * multiplier; return av.localeCompare(bv,'zh') * multiplier; }); currentSort = { col: colName, dir: dir }; lastSearchKeyword = ''; searchResults = []; currentHighlightIdx = -1; document.getElementById('searchKeywordInput').value = ''; renderReviewTable(); updateResultPanelNormal(); }
    function searchByIsbn(keyword){ const kw=keyword.trim().toLowerCase(); if(!kw){ searchResults=[]; currentHighlightIdx=-1; lastSearchKeyword=''; applyHighlightNormal(); updateResultPanelNormal(); return; } if(!isbnColumn || !reviewCols.includes(isbnColumn)){ showTip('未识别到 ISBN列'); return; } const results=[]; for(let i=0;i<reviewRows.length;i++) if(String(reviewRows[i][isbnColumn]||'').toLowerCase().includes(kw)) results.push(i); searchResults=results; lastSearchKeyword=kw; if(results.length===0){ showTip('未找到包含 '+keyword+' 的记录'); currentHighlightIdx=-1; applyHighlightNormal(); updateResultPanelNormal(); return; } currentHighlightIdx=results[0]; applyHighlightNormal(); const tbody=document.getElementById('reviewTbody'); if(tbody&&tbody.rows[currentHighlightIdx]) tbody.rows[currentHighlightIdx].scrollIntoView({behavior:'smooth',block:'center'}); updateResultPanelNormal(); }
    function updateResultPanelNormal(){ const panel=document.getElementById('resultPanel'); if(!panel) return; if(!lastSearchKeyword||searchResults.length===0){ panel.innerHTML='<div class="result-header">🔍 查找结果</div><div>输入ISBN后按回车或点击查找</div>'; return; } let html=`<div class="result-header">🔍 找到 ${searchResults.length} 条记录</div>`; for(let i=0;i<Math.min(searchResults.length,50);i++){ const rowIdx=searchResults[i]; let preview=`第${rowIdx+1}行: ${String(reviewRows[rowIdx][isbnColumn]||'').slice(0,50)}`; const activeClass=(currentHighlightIdx===rowIdx)?'active':''; html+=`<div class="result-item ${activeClass}" data-idx="${rowIdx}">📍 ${escapeHtml(preview)}</div>`; } panel.innerHTML=html; document.querySelectorAll('#resultPanel .result-item').forEach(el=>{ el.onclick=()=>{ const idx=parseInt(el.dataset.idx); if(!isNaN(idx)){ currentHighlightIdx=idx; applyHighlightNormal(); const tbody=document.getElementById('reviewTbody'); if(tbody&&tbody.rows[idx]) tbody.rows[idx].scrollIntoView({behavior:'smooth',block:'center'}); updateResultPanelNormal(); } }; }); }
    function importExcelReview(){ const input=document.createElement('input'); input.type='file'; input.accept='.xlsx,.xls,.csv'; input.onchange=e=>{ const file=e.target.files[0]; if(!file) return; const reader=new FileReader(); reader.onload=evt=>{ try{ const data=new Uint8Array(evt.target.result); const wb=XLSX.read(data,{type:'array'}); const sheet=wb.Sheets[wb.SheetNames[0]]; const raw=XLSX.utils.sheet_to_json(sheet,{header:1,defval:""}); if(!raw||raw.length<2) throw new Error("至少需要表头+数据"); let rawHeaders=raw[0].map(cell=>cell===undefined||cell===null?"":String(cell).trim()); let dataRows=raw.slice(1).filter(row=>row.some(cell=>cell!==undefined&&cell!==null&&cell!=="")); if(dataRows.length===0) throw new Error("无有效数据行"); const nonEmptyColIndices=[]; for(let colIdx=0;colIdx<rawHeaders.length;colIdx++){ let hasValue=false; for(let row of dataRows){ let val=(colIdx<row.length)?row[colIdx]:""; if(val!==undefined&&val!==null&&String(val).trim()!==""){ hasValue=true; break;} } if(hasValue) nonEmptyColIndices.push(colIdx); } if(nonEmptyColIndices.length===0) throw new Error("无非空列"); const finalHeaders=nonEmptyColIndices.map(i=>rawHeaders[i]||`列${i+1}`); const normalizedRows=dataRows.map(row=>{ const obj={}; for(let j=0;j<nonEmptyColIndices.length;j++){ const colIdx=nonEmptyColIndices[j]; let val=(colIdx<row.length)?row[colIdx]:""; obj[finalHeaders[j]]=(val!==undefined&&val!==null)?String(val):""; } return obj; }); reviewCols=finalHeaders; reviewRows=normalizedRows; isbnColumn=autoDetectIsbnColumn(reviewCols); currentSort={col:null,dir:null}; lastSearchKeyword=''; searchResults=[]; currentHighlightIdx=-1; document.getElementById('searchKeywordInput').value=''; renderReviewTable(); updateResultPanelNormal(); saveReview(); showTip(`导入成功: ${reviewRows.length}行`, false, 2500); }catch(err){ alert("导入失败:"+err.message); } }; reader.readAsArrayBuffer(file); }; input.click(); }
    function exportReviewExcel(){ if(!reviewRows.length||!reviewCols.length){ alert("无数据"); return; } const sheetData=[reviewCols]; reviewRows.forEach(row=>{ sheetData.push(reviewCols.map(col=>row[col]!==undefined?row[col]:"")); }); const ws=XLSX.utils.aoa_to_sheet(sheetData); const wb=XLSX.utils.book_new(); XLSX.utils.book_append_sheet(wb,ws,"复核数据"); XLSX.writeFile(wb,`复核数据_${new Date().toISOString().slice(0,19).replace(/:/g,'-')}.xlsx`); showTip("导出成功",false); }
    function clearReviewAll(){ if(reviewRows.length&&confirm("清空所有复核数据？不可恢复")){ reviewCols=[]; reviewRows=[]; lastSearchKeyword=''; searchResults=[]; currentHighlightIdx=-1; localStorage.removeItem(REVIEW_KEY); renderReviewTable(); updateResultPanelNormal(); showTip("已清空",false); } }
    function saveReview(){ localStorage.setItem(REVIEW_KEY,JSON.stringify({cols:reviewCols,rows:reviewRows})); }
    function loadReview(){ try{ const raw=localStorage.getItem(REVIEW_KEY); if(raw){ const data=JSON.parse(raw); reviewCols=data.cols||[]; reviewRows=data.rows||[]; } else{ reviewCols=[]; reviewRows=[]; } isbnColumn=autoDetectIsbnColumn(reviewCols); }catch(e){ reviewCols=[]; reviewRows=[]; isbnColumn=null; } }
    window.editCell = function(rowIdx, colName){ const td = event.target; const oldVal = reviewRows[rowIdx][colName] || ''; const input = document.createElement('input'); input.value = oldVal; input.style.width = (td.clientWidth - 10) + 'px'; input.style.fontSize = '0.75rem'; td.innerText = ''; td.appendChild(input); input.focus(); input.onblur = () => { const newVal = input.value; reviewRows[rowIdx][colName] = newVal; saveReview(); renderReviewTable(); if(lastSearchKeyword) searchByIsbn(lastSearchKeyword); }; input.onkeypress = (e) => { if(e.key === 'Enter') input.blur(); }; };
    
    // ---------- 多文件对比核心逻辑 ----------
    let baseFileData = null;
    let targetFileItems = [];      // 每个元素: { id, fileData, fileName, pkPairs, comparePairs, element }
    let nextId = 1;
    
    // 解析Excel，处理重复列名
    function normalizeHeaders(headers) {
        const headerCount = {};
        return headers.map((h, idx) => {
            let base = (h && h.trim() !== "") ? h.trim() : `列_${idx+1}`;
            let final = base;
            let count = headerCount[base] || 0;
            if (count > 0) final = `${base}_${count}`;
            headerCount[base] = count + 1;
            return final;
        });
    }
    async function parseExcelFile(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    const data = new Uint8Array(e.target.result);
                    const wb = XLSX.read(data, { type: 'array' });
                    const sheet = wb.Sheets[wb.SheetNames[0]];
                    const raw = XLSX.utils.sheet_to_json(sheet, { header: 1, defval: "" });
                    if (!raw || raw.length < 2) reject("文件至少需要表头+数据");
                    let rawHeaders = raw[0].map(cell => cell===undefined||cell===null?"":String(cell));
                    let headers = normalizeHeaders(rawHeaders);
                    let dataRows = raw.slice(1).filter(row => row.some(cell=>cell!==undefined && cell!==null && cell!==""));
                    const normalized = dataRows.map(row => {
                        const obj = {};
                        headers.forEach((h, idx) => {
                            let val = (idx < row.length && row[idx] !== undefined && row[idx] !== null) ? String(row[idx]) : "";
                            obj[h] = val;
                        });
                        return obj;
                    });
                    resolve({ cols: headers, rows: normalized, fileName: file.name });
                } catch(err) { reject(err.message); }
            };
            reader.onerror = () => reject("读取失败");
            reader.readAsArrayBuffer(file);
        });
    }
    
    // 刷新所有目标卡片的字段下拉框（基准文件变化时调用）
    function refreshAllTargetFieldOptions() {
        const baseCols = baseFileData ? baseFileData.cols : [];
        const baseOptions = baseCols.map(c=>`<option value="${escapeAttr(c)}">${escapeHtml(c)}</option>`).join('');
        for(let item of targetFileItems){
            const basePkSelects = item.element.querySelectorAll('.basePkSelect');
            const baseCmpSelects = item.element.querySelectorAll('.baseCmpSelect');
            basePkSelects.forEach(sel => sel.innerHTML = baseOptions);
            baseCmpSelects.forEach(sel => sel.innerHTML = baseOptions);
        }
    }
    
    // 添加被对比文件卡片（仅添加配置界面，不上传文件）
    function addTargetFileCard() {
        const id = nextId++;
        const container = document.getElementById('targetFilesContainer');
        const cardDiv = document.createElement('div');
        cardDiv.className = 'target-card';
        cardDiv.dataset.id = id;
        // 初始无文件，显示上传按钮
        cardDiv.innerHTML = `
            <div class="target-header">
                <span class="target-name">📄 未上传文件</span>
                <span class="remove-file" data-id="${id}">🗑 删除</span>
            </div>
            <div style="margin:8px 0;">
                <input type="file" accept=".xlsx,.xls,.csv" class="targetFileInput" style="font-size:0.7rem;">
                <div class="file-status" style="margin-top:4px;">未加载</div>
            </div>
            <div class="section-title">🔑 组合主键 (可多组)</div>
            <div class="pkPairsContainer"></div>
            <div class="mapping-row">
                <select class="basePkSelect" style="width:140px"><option value="">—基准字段—</option></select>
                <span>➔</span>
                <select class="targetPkSelect" style="width:140px"><option value="">—本文件字段—</option></select>
                <button class="addPkBtn" style="padding:2px 8px;">添加主键</button>
            </div>
            <div class="section-title">📊 对比字段 (可多组)</div>
            <div class="cmpPairsContainer"></div>
            <div class="mapping-row">
                <select class="baseCmpSelect" style="width:140px"><option value="">—基准字段—</option></select>
                <span>➔</span>
                <select class="targetCmpSelect" style="width:140px"><option value="">—本文件字段—</option></select>
                <button class="addCmpBtn" style="padding:2px 8px;">添加对比字段</button>
            </div>
        `;
        container.appendChild(cardDiv);
        
        const item = { id, fileData: null, fileName: '', pkPairs: [], comparePairs: [], element: cardDiv };
        
        // 文件上传
        const fileInput = cardDiv.querySelector('.targetFileInput');
        fileInput.onchange = async (e) => {
            const file = e.target.files[0];
            if(!file) return;
            try {
                const parsed = await parseExcelFile(file);
                item.fileData = parsed;
                item.fileName = file.name;
                item.pkPairs = [];
                item.comparePairs = [];
                // 更新显示
                cardDiv.querySelector('.target-name').innerHTML = `📄 ${escapeHtml(file.name)}`;
                cardDiv.querySelector('.file-status').innerHTML = `已加载 ${parsed.rows.length}行`;
                // 刷新本卡片的字段下拉框
                const cols = parsed.cols;
                const options = cols.map(c=>`<option value="${escapeAttr(c)}">${escapeHtml(c)}</option>`).join('');
                cardDiv.querySelectorAll('.targetPkSelect, .targetCmpSelect').forEach(sel => sel.innerHTML = options);
                // 清空现有列表
                renderPkList(item);
                renderCmpList(item);
                showTip(`${file.name} 加载成功`, false);
            } catch(err) { showTip(`加载失败: ${err}`); }
        };
        
        // 添加主键对
        const addPkBtn = cardDiv.querySelector('.addPkBtn');
        addPkBtn.onclick = () => {
            const baseSelect = cardDiv.querySelector('.basePkSelect');
            const targetSelect = cardDiv.querySelector('.targetPkSelect');
            const baseField = baseSelect.value;
            const targetField = targetSelect.value;
            if(!baseField || !targetField){ showTip("请完整选择主键字段对"); return; }
            if(item.pkPairs.some(p => p.baseField === baseField && p.targetField === targetField)){
                showTip("该主键对已存在"); return;
            }
            item.pkPairs.push({ baseField, targetField });
            renderPkList(item);
        };
        
        // 添加对比字段对
        const addCmpBtn = cardDiv.querySelector('.addCmpBtn');
        addCmpBtn.onclick = () => {
            const baseSelect = cardDiv.querySelector('.baseCmpSelect');
            const targetSelect = cardDiv.querySelector('.targetCmpSelect');
            const baseField = baseSelect.value;
            const targetField = targetSelect.value;
            if(!baseField || !targetField){ showTip("请完整选择对比字段对"); return; }
            if(item.comparePairs.some(p => p.baseField === baseField && p.targetField === targetField)){
                showTip("该对比对已存在"); return;
            }
            item.comparePairs.push({ baseField, targetField });
            renderCmpList(item);
        };
        
        // 删除卡片
        cardDiv.querySelector('.remove-file').onclick = () => {
            const idx = targetFileItems.findIndex(i => i.id === id);
            if(idx !== -1) targetFileItems.splice(idx,1);
            cardDiv.remove();
            if(targetFileItems.length === 0){
                const container = document.getElementById('targetFilesContainer');
                const emptyMsg = document.createElement('div');
                emptyMsg.className = 'empty-placeholder';
                emptyMsg.innerText = '暂无被对比文件，请点击上方“添加被对比文件”按钮';
                container.appendChild(emptyMsg);
                setTimeout(() => { if(container.querySelector('.empty-placeholder')) container.querySelector('.empty-placeholder').remove(); }, 100);
            }
        };
        
        targetFileItems.push(item);
        renderPkList(item);
        renderCmpList(item);
        // 刷新基准字段下拉框（如果基准已加载）
        if(baseFileData){
            const baseOptions = baseFileData.cols.map(c=>`<option value="${escapeAttr(c)}">${escapeHtml(c)}</option>`).join('');
            cardDiv.querySelectorAll('.basePkSelect, .baseCmpSelect').forEach(sel => sel.innerHTML = baseOptions);
        }
        return item;
    }
    
    function renderPkList(item) {
        const container = item.element.querySelector('.pkPairsContainer');
        if(!container) return;
        if(item.pkPairs.length === 0){
            container.innerHTML = '<span style="color:#8ba0bc; font-size:0.7rem;">暂无主键，请添加组合主键</span>';
            return;
        }
        let html = '<div class="tag-list">';
        item.pkPairs.forEach((pair, idx) => {
            html += `<div class="tag">🔑 ${escapeHtml(pair.baseField)} ➔ ${escapeHtml(pair.targetField)} <button data-idx="${idx}" class="removePk">✖</button></div>`;
        });
        html += '</div>';
        container.innerHTML = html;
        container.querySelectorAll('.removePk').forEach(btn => {
            btn.onclick = (e) => {
                let idx = parseInt(btn.dataset.idx);
                if(!isNaN(idx)) { item.pkPairs.splice(idx,1); renderPkList(item); }
            };
        });
    }
    
    function renderCmpList(item) {
        const container = item.element.querySelector('.cmpPairsContainer');
        if(!container) return;
        if(item.comparePairs.length === 0){
            container.innerHTML = '<span style="color:#8ba0bc; font-size:0.7rem;">暂无对比字段，请添加</span>';
            return;
        }
        let html = '<div class="tag-list">';
        item.comparePairs.forEach((pair, idx) => {
            html += `<div class="tag">📊 ${escapeHtml(pair.baseField)} ➔ ${escapeHtml(pair.targetField)} <button data-idx="${idx}" class="removeCmp">✖</button></div>`;
        });
        html += '</div>';
        container.innerHTML = html;
        container.querySelectorAll('.removeCmp').forEach(btn => {
            btn.onclick = (e) => {
                let idx = parseInt(btn.dataset.idx);
                if(!isNaN(idx)) { item.comparePairs.splice(idx,1); renderCmpList(item); }
            };
        });
    }
    
    // 执行单个对比（基准 + 单个目标）
    function performOneCompare(targetItem) {
        if(!baseFileData) throw new Error("基准文件未加载");
        if(!targetItem.fileData) throw new Error("目标文件未加载");
        if(targetItem.pkPairs.length === 0) throw new Error("未配置任何主键对");
        
        const targetData = targetItem.fileData;
        // 构建目标文件的复合键索引（使用所有主键对拼接）
        const mapB = new Map();
        for(let row of targetData.rows){
            let keys = targetItem.pkPairs.map(pair => String(row[pair.targetField]||"").trim());
            if(keys.some(k => k === "")) continue;
            let compositeKey = keys.join('|');
            mapB.set(compositeKey, row);
        }
        
        let matchedB = [], onlyA = [], onlyB = [], mismatchRecords = [];
        const processedKeys = new Set();
        for(let rowA of baseFileData.rows){
            let keysA = targetItem.pkPairs.map(pair => String(rowA[pair.baseField]||"").trim());
            if(keysA.some(k => k === "")){ onlyA.push(rowA); continue; }
            let compositeKey = keysA.join('|');
            if(mapB.has(compositeKey)){
                processedKeys.add(compositeKey);
                const rowB = mapB.get(compositeKey);
                let diffFields = [];
                for(let pair of targetItem.comparePairs){
                    let valA = String(rowA[pair.baseField]||"").trim();
                    let valB = String(rowB[pair.targetField]||"").trim();
                    if(!isValueEqual(valA, valB)){
                        diffFields.push({ baseField: pair.baseField, targetField: pair.targetField, valA, valB });
                    }
                }
                if(diffFields.length === 0) matchedB.push(rowB);
                else mismatchRecords.push({ rowA, rowB, diffFields });
            } else {
                onlyA.push(rowA);
            }
        }
        for(let rowB of targetData.rows){
            let keysB = targetItem.pkPairs.map(pair => String(rowB[pair.targetField]||"").trim());
            if(keysB.some(k => k === "")) continue;
            let compositeKey = keysB.join('|');
            if(!processedKeys.has(compositeKey)) onlyB.push(rowB);
        }
        return { matchedB, onlyA, onlyB, mismatchRecords };
    }
    
    // 导出单个对比结果为Excel Blob (始终生成4个sheet)
    function exportOneCompareResult(targetItem, result) {
        const { matchedB, onlyA, onlyB, mismatchRecords } = result;
        const wb = XLSX.utils.book_new();
        
        // Sheet1: 匹配成功
        const sheet1Data = matchedB.length ? [targetItem.fileData.cols, ...matchedB.map(r => targetItem.fileData.cols.map(c=>r[c]||''))] : [["提示"], ["无匹配成功的数据"]];
        XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(sheet1Data), "匹配成功_B数据");
        
        // Sheet2: 仅在基准A
        const sheet2Data = onlyA.length ? [baseFileData.cols, ...onlyA.map(r => baseFileData.cols.map(c=>r[c]||''))] : [["提示"], ["无仅在基准文件A的数据"]];
        XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(sheet2Data), "仅在对比文件A存在");
        
        // Sheet3: 仅在目标B
        const sheet3Data = onlyB.length ? [targetItem.fileData.cols, ...onlyB.map(r => targetItem.fileData.cols.map(c=>r[c]||''))] : [["提示"], ["无仅在被对比文件B的数据"]];
        XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(sheet3Data), "仅在被对比文件B存在");
        
        // Sheet4: 字段不一致 (双表全字段 + 差异说明前置)
        if(mismatchRecords.length){
            const aColsRaw = baseFileData.cols;
            const bColsRaw = targetItem.fileData.cols;
            const headers = ["⚠️ 差异说明", ...aColsRaw.map(c => `${c} (A)`), ...bColsRaw.map(c => `${c} (B)`)];
            let sheetData = [headers];
            for(let item of mismatchRecords){
                let aRowVals = aColsRaw.map(c => item.rowA[c] || "");
                let bRowVals = bColsRaw.map(c => item.rowB[c] || "");
                let diffDesc = item.diffFields.map(d => `${d.baseField} (A)="${d.valA}"  vs  ${d.targetField} (B)="${d.valB}"`).join("; ");
                sheetData.push([diffDesc, ...aRowVals, ...bRowVals]);
            }
            XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(sheetData), "字段不一致记录_双表对比");
        } else {
            XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet([["提示"], ["无不一致的记录"]]), "字段不一致记录_双表对比");
        }
        const excelData = XLSX.write(wb, { type: 'array', bookType: 'xlsx' });
        return new Blob([excelData], {type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'});
    }
    
    async function batchCompareAndExport() {
        if(!baseFileData){ showTip("请先上传基准文件A"); return; }
        const validTargets = targetFileItems.filter(t => t.fileData && t.pkPairs.length > 0);
        if(validTargets.length === 0){
            showTip("没有有效的被对比文件（需已上传文件且至少配置一组主键）");
            return;
        }
        const zip = new JSZip();
        let successCount = 0;
        for(let target of validTargets){
            try {
                const result = performOneCompare(target);
                const blob = exportOneCompareResult(target, result);
                const safeName = target.fileName.replace(/[\\/:*?"<>|]/g, '_');
                zip.file(`${safeName}_对比报告.xlsx`, blob);
                successCount++;
            } catch(e){
                showTip(`${target.fileName} 对比失败: ${e.message}`, true);
            }
        }
        if(successCount === 0){
            showTip("没有成功生成任何报告", true);
            return;
        }
        const content = await zip.generateAsync({ type: "blob" });
        const link = document.createElement('a');
        link.href = URL.createObjectURL(content);
        link.download = `批量对比报告_${new Date().toISOString().slice(0,19).replace(/:/g,'-')}.zip`;
        link.click();
        URL.revokeObjectURL(link.href);
        showTip(`成功导出 ${successCount} 个对比报告`, false);
    }
    
    // 初始化多文件对比
    function initCompare() {
        document.getElementById('uploadBaseBtn').onclick = () => { document.getElementById('baseFileInput').click(); };
        document.getElementById('baseFileInput').onchange = async (e) => {
            if(e.target.files[0]){
                try{
                    baseFileData = await parseExcelFile(e.target.files[0]);
                    document.getElementById('baseFileStatus').innerHTML = `✅ ${baseFileData.fileName} (${baseFileData.rows.length}行)`;
                    refreshAllTargetFieldOptions();
                } catch(err){ showTip(`基准文件加载失败: ${err}`); }
            }
        };
        document.getElementById('addTargetFileBtn').onclick = () => { addTargetFileCard(); };
        document.getElementById('batchCompareBtn').onclick = batchCompareAndExport;
    }
    
    // 模式切换
    const radioNormal = document.querySelector('input[value="normal"]');
    const radioCompare = document.querySelector('input[value="compare"]');
    const normalPanel = document.getElementById('normalPanel');
    const comparePanel = document.getElementById('comparePanel');
    const modeTipSpan = document.getElementById('modeTip');
    function switchMode(mode){
        if(mode === 'normal'){
            normalPanel.classList.remove('panel-hidden');
            comparePanel.classList.add('panel-hidden');
            modeTipSpan.innerText = '普通模式：导入Excel，ISBN搜索/双击编辑';
        } else {
            normalPanel.classList.add('panel-hidden');
            comparePanel.classList.remove('panel-hidden');
            modeTipSpan.innerText = '多文件对比模式：基准文件 + 多个被对比文件，每个独立配置组合主键和对比字段';
        }
    }
    radioNormal.onchange = () => switchMode('normal');
    radioCompare.onchange = () => switchMode('compare');
    
    function startup(){
        loadReview(); renderReviewTable(); updateResultPanelNormal();
        document.getElementById('importExcelBtn').onclick = importExcelReview;
        document.getElementById('exportReviewBtn').onclick = exportReviewExcel;
        document.getElementById('clearReviewBtn').onclick = clearReviewAll;
        const searchInput = document.getElementById('searchKeywordInput'), searchBtn = document.getElementById('searchBtn');
        const doSearch = () => searchByIsbn(searchInput.value);
        searchBtn.onclick = doSearch; searchInput.onkeypress = (e) => { if(e.key === 'Enter') doSearch(); };
        initCompare();
        switchMode('normal');
    }
    startup();
})();
</script>
</body>
</html>