<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>数据复核 · 新华书店工具箱</title>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #eef2f7; font-family: 'Segoe UI', Roboto, sans-serif; height: 100vh; overflow: hidden; font-size: 13px; }
        .app-container { display: flex; flex-direction: column; height: 100vh; background: white; }
        .global-header { background: linear-gradient(135deg, #1e3c72, #2a4b7a); color: white; padding: 8px 20px; flex-shrink: 0; }
        .global-header h1 { font-size: 1.2rem; font-weight: 500; letter-spacing: 1px; }
        .global-header p { font-size: 0.7rem; opacity: 0.85; margin-top: 2px; }
        .mode-bar { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 8px 20px; display: flex; gap: 24px; align-items: center; flex-shrink: 0; flex-wrap: wrap; }
        .mode-radio-group { display: flex; gap: 20px; background: white; padding: 4px 16px; border-radius: 40px; box-shadow: 0 0 0 1px #e2e8f0; }
        .mode-radio-group label { display: flex; align-items: center; gap: 8px; cursor: pointer; font-weight: 500; color: #1e293b; }
        .mode-radio-group input { accent-color: #2b4c7c; width: 16px; height: 16px; margin: 0; }
        .mode-tip { font-size: 0.7rem; color: #4b6b8f; background: #f1f5f9; padding: 4px 12px; border-radius: 24px; }
        .review-panel { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .panel-hidden { display: none !important; }
        /* 普通复核样式 */
        .module { display: flex; flex-direction: column; height: 100%; background: white; }
        .toolbar { background: #fefefe; padding: 6px 16px; border-bottom: 1px solid #e2e8f0; display: flex; flex-wrap: wrap; gap: 8px; align-items: center; flex-shrink: 0; }
        button { border: none; background: #eef2f7; padding: 5px 14px; border-radius: 20px; font-size: 0.75rem; font-weight: 500; cursor: pointer; font-family: inherit; transition: 0.1s; }
        button.primary { background: #2b4c7c; color: white; }
        button.danger { background: #fee2e2; color: #b91c1c; }
        button.success { background: #e3f7ec; color: #2b6e3c; }
        .table-wrap { flex: 1; overflow: auto; padding: 0 12px 6px 12px; }
        .review-table { width: max-content; min-width: 100%; border-collapse: collapse; font-size: 0.75rem; }
        .review-table th, .review-table td { padding: 6px 10px; border-bottom: 1px solid #ecf3f9; white-space: normal; word-break: break-word; max-width: 250px; }
        .review-table th { background: #f1f5f9; position: sticky; top: 0; }
        .result-panel { background: white; border-top: 1px solid #e2e8f0; flex-shrink: 0; max-height: 120px; overflow-y: auto; font-size: 0.7rem; }
        .result-header { background: #f1f5f9; padding: 4px 12px; font-weight: bold; position: sticky; top: 0; }
        .result-item { padding: 4px 12px; cursor: pointer; border-bottom: 1px solid #ecf3f9; }
        .result-item.active { background: #fff3bf; font-weight: bold; }
        .highlight-row { background-color: #fff3bf !important; }
        .search-group { display: flex; gap: 6px; align-items: center; background: #f1f5f9; padding: 2px 16px; border-radius: 32px; margin-left: auto; }
        .footer-note { padding: 4px 16px; font-size: 0.65rem; color: #5b6e8c; background: #fefefe; border-top: 1px solid #ecf3f9; flex-shrink: 0; }
        .field-selector { display: inline-flex; align-items: center; gap: 6px; background: white; padding: 2px 10px; border-radius: 30px; border: 1px solid #cbd5e1; margin-left: 8px; }
        .field-selector select { border: none; background: transparent; font-size: 0.7rem; padding: 4px 0; outline: none; max-width: 120px; }
        .toast-tip { position: fixed; top: 40%; left: 50%; transform: translate(-50%,-50%); background: #333333ee; color: #ffdd99; padding: 12px 24px; border-radius: 40px; font-size: 1rem; z-index: 2000; pointer-events: none; border-left: 4px solid #f5a623; white-space: nowrap; }
        /* 多文件对比样式 (保留) */
        .base-file-area, .target-files-container { background: #ffffff; }
        .file-card { flex: 1; min-width: 260px; background: #f9fbfd; border: 1px solid #e2edf7; border-radius: 16px; padding: 10px 16px; }
        .file-card h4 { font-size: 0.85rem; margin-bottom: 8px; }
        .file-status { font-size: 0.7rem; margin-top: 6px; color: #2c5a2e; display: flex; justify-content: space-between; align-items: center; }
        .target-card { background: #f8fafc; border-radius: 16px; margin-bottom: 16px; padding: 12px 16px; border: 1px solid #e2edf7; }
        .target-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .target-name { font-weight: 600; font-size: 0.8rem; background: #eef2ff; padding: 4px 12px; border-radius: 30px; }
        .remove-file { color: #b91c1c; cursor: pointer; background: #fee2e2; padding: 2px 8px; border-radius: 20px; font-size: 0.65rem; }
        .mapping-row { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-top: 6px; background: white; padding: 6px 10px; border-radius: 12px; }
        .mapping-row select { padding: 4px 8px; border-radius: 30px; border: 1px solid #cbd5e1; font-size: 0.7rem; min-width: 130px; }
        .tag-list { display: flex; flex-wrap: wrap; gap: 8px; margin: 6px 0 0 0; }
        .tag { background: #eef2ff; border-radius: 20px; padding: 2px 10px; font-size: 0.7rem; display: inline-flex; align-items: center; gap: 6px; }
        .tag button { background: none; border: none; color: #b91c1c; cursor: pointer; font-size: 0.9rem; line-height: 1; }
        .compare-actions { display: flex; gap: 12px; margin: 12px 20px; flex-shrink: 0; }
        /* 到货复核样式 - 修复详情表格高度 */
        .arrival-area { display: flex; gap: 24px; padding: 12px 20px; background: #ffffff; border-bottom: 1px solid #ecf3f9; flex-wrap: wrap; flex-shrink: 0; }
        .data-card { flex: 1; background: #f9fbfd; border: 1px solid #e2edf7; border-radius: 16px; padding: 12px 16px; }
        .data-card h4 { font-size: 0.85rem; margin-bottom: 8px; }
        .filter-row { display: flex; align-items: center; gap: 12px; margin: 8px 20px 0 20px; flex-wrap: wrap; flex-shrink: 0; }
        .filter-row select, .filter-row button { padding: 4px 12px; border-radius: 30px; border: 1px solid #cbd5e1; background: white; font-size: 0.7rem; cursor: pointer; }
        .filter-row button.primary { background: #2b4c7c; color: white; border: none; }
        .stats-info { background: #eef2ff; margin: 8px 20px; padding: 6px 12px; border-radius: 20px; font-size: 0.7rem; display: inline-block; flex-shrink: 0; }
        .analysis-wrapper { margin: 8px 20px; display: flex; gap: 20px; flex-wrap: wrap; flex-shrink: 0; max-height: 180px; overflow-y: auto; border: 1px solid #e2edf7; border-radius: 12px; background: #f8fafc; padding: 8px; }
        .analysis-card { flex: 1; background: transparent; }
        .analysis-card h4 { font-size: 0.75rem; margin-bottom: 4px; color: #1e3c72; }
        .analysis-table { width: 100%; border-collapse: collapse; font-size: 0.7rem; }
        .analysis-table th, .analysis-table td { padding: 4px 6px; border-bottom: 1px solid #e2e8f0; text-align: left; }
        .match-table-wrapper { flex: 1; overflow: auto; margin: 0 20px 12px 20px; border: 1px solid #e2e8f0; border-radius: 12px; background: white; min-height: 0; }
        .match-table { width: 100%; border-collapse: collapse; font-size: 0.7rem; }
        .match-table th, .match-table td { padding: 8px 10px; border-bottom: 1px solid #ecf3f9; text-align: left; vertical-align: top; }
        .match-table th { background: #f8fafc; position: sticky; top: 0; }
        .matched-orders { white-space: pre-line; line-height: 1.4; }
        .mapping-section { background: #fefefe; border-top: 1px solid #e9eef3; padding: 12px 20px; flex-shrink: 0; }
        .mapping-section .section-title { font-weight: 600; font-size: 0.75rem; margin: 0 0 8px 0; }
    </style>
</head>
<body>
<div class="app-container">
    <div class="global-header">
        <h1>📚 数据复核 · 新华书店工具箱</h1>
        <p>普通复核 | 多文件对比 | 到货复核</p>
    </div>
    <div class="mode-bar">
        <div class="mode-radio-group">
            <label><input type="radio" name="reviewMode" value="normal" checked> 📋 普通复核</label>
            <label><input type="radio" name="reviewMode" value="compare"> 🔄 多文件对比</label>
            <label><input type="radio" name="reviewMode" value="arrival"> 📦 到货复核</label>
        </div>
        <div class="mode-tip" id="modeTip">普通模式：导入Excel，自动匹配三列，按回车或按钮查找，未找到弹窗提示</div>
    </div>
    <!-- 普通复核面板 (简化，完整功能) -->
    <div id="normalPanel" class="review-panel">
        <div class="module">
            <div class="toolbar">
                <button id="importExcelBtn" class="primary">📂 导入Excel</button>
                <button id="clearReviewBtn" class="danger">🗑 清空数据</button>
                <div class="field-selector"><span>📖 书号列：</span><select id="isbnColSelect"><option value="">—请选择—</option></select></div>
                <div class="field-selector"><span>📘 书名列：</span><select id="titleColSelect"><option value="">—请选择—</option></select></div>
                <div class="field-selector"><span>🔢 订数列：</span><select id="qtyColSelect"><option value="">—请选择—</option></select></div>
                <div class="search-group">
                    <span>🔍 书号</span>
                    <input type="text" id="searchKeywordInput" placeholder="输入ISBN或书号" style="width:260px">
                    <button id="searchBtn">查找</button>
                </div>
            </div>
            <div class="table-wrap"><table class="review-table"><thead id="reviewThead"></thead><tbody id="reviewTbody"></tbody></table></div>
            <div class="result-panel" id="resultPanel"><div class="result-header">🔍 查找结果</div><div style="color:#8ba0bc; padding:4px 8px;">输入书号后按回车或点击查找</div></div>
            <div class="footer-note">💡 自动匹配三列 | 按订数升序，背景色随订数加深 | 查找后自动全选，未找到弹窗提示</div>
        </div>
    </div>

    <!-- 多文件对比面板 (完整功能，此处简化界面但保留基本按钮) -->
    <div id="comparePanel" class="review-panel panel-hidden">
        <div class="base-file-area">
            <div class="file-card"><h4>📁 基准文件 (对比文件 A)</h4><input type="file" id="baseFileInput" accept=".xlsx,.xls,.csv" style="display:none"><button id="uploadBaseBtn" class="primary">选择基准文件A</button><div id="baseFileStatus" class="file-status">未加载</div></div>
        </div>
        <div style="background:#f1f5f9; padding:6px 20px; display: flex; justify-content: space-between;"><span>📎 被对比文件列表</span><button id="addTargetFileBtn" class="success">+ 添加被对比文件</button></div>
        <div id="targetFilesContainer" class="target-files-container"></div>
        <div class="compare-actions"><button id="batchCompareBtn" class="primary">批量对比并导出 (ZIP)</button></div>
        <div class="footer-note">每个被对比文件独立配置组合主键和对比字段，导出四Sheet报告。</div>
    </div>

    <!-- 到货复核面板 (修复列表高度) -->
    <div id="arrivalPanel" class="review-panel panel-hidden">
        <div class="arrival-area">
            <div class="data-card">
                <h4>📋 订单文件 (必须包含：书号、客户名称、馆配需求单名称)</h4>
                <input type="file" id="orderFileInput" accept=".xlsx,.xls,.csv" style="display:none">
                <button id="uploadOrderBtn" class="primary">选择订单文件</button>
                <div id="orderFileStatus" class="file-status">未加载</div>
            </div>
            <div class="data-card">
                <h4>📦 到货文件 (供应商清单，自动跳过说明行)</h4>
                <input type="file" id="arrivalFileInput" accept=".xlsx,.xls,.csv" style="display:none">
                <button id="uploadArrivalBtn" class="primary">选择到货文件</button>
                <div id="arrivalFileStatus" class="file-status">未加载</div>
            </div>
        </div>
        <div class="mapping-section">
            <div class="section-title">🔗 字段映射配置 (至少一组)</div>
            <div class="mapping-row" style="margin-bottom: 8px;">
                <select id="orderFieldSelect" style="width:150px"><option value="">—订单字段—</option></select>
                <span>➔</span>
                <select id="arrivalFieldSelect" style="width:150px"><option value="">—到货字段—</option></select>
                <button id="addMappingBtn" class="primary">➕ 添加映射</button>
            </div>
            <div id="mappingTagsContainer" class="tag-list" style="margin-top: 4px;"></div>
        </div>
        <div class="filter-row">
            <span>🔍 客户筛选：</span>
            <select id="customerFilterSelect"><option value="">— 全部客户 —</option></select>
            <button id="matchBtn" class="primary">🔗 开始匹配并分析归属</button>
            <button id="exportMatchBtn" class="success" disabled>📎 导出匹配结果</button>
        </div>
        <div id="matchStats" class="stats-info"></div>
        <!-- 分析结果区域：限制最大高度，超出滚动 -->
        <div class="analysis-wrapper" id="analysisWrapper" style="display:none;">
            <div class="analysis-card">
                <h4>📊 订单归属分析 (按匹配条目数排序)</h4>
                <table class="analysis-table" id="analysisTable"><thead><tr><th>排名</th><th>客户名称</th><th>馆配需求单名称</th><th>匹配条目数</th><th>置信度</th></tr></thead><tbody></tbody></table>
            </div>
        </div>
        <!-- 匹配详情表格：占据剩余所有空间 -->
        <div class="match-table-wrapper">
            <table class="match-table" id="matchResultTable"><thead id="matchThead"></thead><tbody id="matchTbody"></tbody></table>
        </div>
        <div class="footer-note">📌 按书号匹配订单，分析整批到货最可能的订单归属。</div>
    </div>
</div>

<script>
(function(){
    let toastTimer = null;
    function showTip(msg, isErr = true, dur = 2500) {
        let tip = document.getElementById('globalTip');
        if(!tip){ tip = document.createElement('div'); tip.id = 'globalTip'; tip.className = 'toast-tip'; document.body.appendChild(tip); }
        tip.style.opacity = '1'; tip.innerText = msg;
        if(toastTimer) clearTimeout(toastTimer);
        toastTimer = setTimeout(() => { tip.style.opacity = '0'; }, dur);
    }
    function escapeHtml(str){ return String(str).replace(/[&<>]/g, function(m){ if(m==='&') return '&amp;'; if(m==='<') return '&lt;'; if(m==='>') return '&gt;'; return m;}); }
    function escapeAttr(str){ return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }

    // ---------- 普通复核核心（无任何自动触发，仅手动查找）----------
    let reviewRows = [], displayRows = [], allColumns = [];
    let currentMapping = { isbnCol: null, titleCol: null, qtyCol: null };
    let lastSearchKeyword = '', searchResultsIndices = [], currentHighlightRowIdx = -1;

    function smartMatchColumns(headers) {
        const isbnKw = ['书号','isbn','条码','bookid','标准书号'];
        const titleKw = ['书名','品名','名称','title'];
        const qtyKw = ['订数','数量','册数','qty','num'];
        let isbn=null, title=null, qty=null;
        for(let h of headers){
            let low = h.toLowerCase();
            if(!isbn && isbnKw.some(k=>low.includes(k))) isbn = h;
            if(!title && titleKw.some(k=>low.includes(k))) title = h;
            if(!qty && qtyKw.some(k=>low.includes(k))) qty = h;
        }
        return { isbnCol: isbn, titleCol: title, qtyCol: qty };
    }

    async function parseExcelFileEnhanced(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    const data = new Uint8Array(e.target.result);
                    const wb = XLSX.read(data, { type: 'array' });
                    const sheet = wb.Sheets[wb.SheetNames[0]];
                    const raw = XLSX.utils.sheet_to_json(sheet, { header: 1, defval: "" });
                    if (!raw || raw.length === 0) reject("文件为空");
                    const headerKeywords = ['书号','isbn','书名','出版社','定价','数量','码洋'];
                    let headerRowIndex = -1;
                    for (let i = 0; i < Math.min(raw.length, 50); i++) {
                        const row = raw[i];
                        if (!row || row.length === 0) continue;
                        const rowStr = row.map(cell => String(cell||"").toLowerCase()).join(' ');
                        let match = headerKeywords.filter(kw => rowStr.includes(kw.toLowerCase())).length;
                        if (match >= 2) { headerRowIndex = i; break; }
                    }
                    if (headerRowIndex === -1) headerRowIndex = 0;
                    let rawHeaders = raw[headerRowIndex].map(cell => cell===undefined||cell===null?"":String(cell).trim());
                    let headers = [];
                    const headerCount = {};
                    for (let h of rawHeaders) {
                        let base = (h && h.trim() !== "") ? h.trim() : `列_${headers.length+1}`;
                        let final = base;
                        let cnt = headerCount[base] || 0;
                        if (cnt > 0) final = `${base}_${cnt}`;
                        headerCount[base] = cnt + 1;
                        headers.push(final);
                    }
                    let dataRows = raw.slice(headerRowIndex+1);
                    const exclude = ['合计','汇总','总计','记录数','册数','码洋','实洋','Subtotal','Total'];
                    const filtered = [];
                    for(let row of dataRows){
                        if(!row.some(cell=>cell!==undefined&&cell!==null&&String(cell).trim()!=="")) continue;
                        const rowStr = row.map(cell=>String(cell||"").toLowerCase()).join(' ');
                        let skip = exclude.some(kw => rowStr.includes(kw.toLowerCase()));
                        if(!skip) filtered.push(row);
                    }
                    const normalized = filtered.map(row => {
                        const obj = {};
                        headers.forEach((h, idx) => {
                            obj[h] = (idx < row.length && row[idx]!==undefined && row[idx]!==null) ? String(row[idx]) : "";
                        });
                        return obj;
                    });
                    resolve({ cols: headers, rows: normalized, fileName: file.name });
                } catch(err) { reject(err.message); }
            };
            reader.onerror = () => reject("读取失败");
            reader.readAsArrayBuffer(file);
        });
    }

    async function importExcelReview(){
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = '.xlsx,.xls,.csv';
        input.onchange = async (e) => {
            const file = e.target.files[0];
            if(!file) return;
            try {
                const parsed = await parseExcelFileEnhanced(file);
                allColumns = parsed.cols;
                reviewRows = parsed.rows;
                const matched = smartMatchColumns(allColumns);
                const colOpts = allColumns.map(c => `<option value="${escapeAttr(c)}">${escapeHtml(c)}</option>`).join('');
                document.getElementById('isbnColSelect').innerHTML = '<option value="">—请选择—</option>' + colOpts;
                document.getElementById('titleColSelect').innerHTML = '<option value="">—请选择—</option>' + colOpts;
                document.getElementById('qtyColSelect').innerHTML = '<option value="">—请选择—</option>' + colOpts;
                if(matched.isbnCol) document.getElementById('isbnColSelect').value = matched.isbnCol;
                if(matched.titleCol) document.getElementById('titleColSelect').value = matched.titleCol;
                if(matched.qtyCol) document.getElementById('qtyColSelect').value = matched.qtyCol;
                currentMapping = {
                    isbnCol: document.getElementById('isbnColSelect').value,
                    titleCol: document.getElementById('titleColSelect').value,
                    qtyCol: document.getElementById('qtyColSelect').value
                };
                sortAndDisplay();
                lastSearchKeyword = '';
                searchResultsIndices = [];
                currentHighlightRowIdx = -1;
                document.getElementById('searchKeywordInput').value = '';
                renderReviewTable();
                updateResultPanelNormal();
                showTip(`导入成功: ${reviewRows.length}行`, false, 3000);
            } catch(err) { alert("导入失败: "+err.message); }
        };
        input.click();
    }

    function sortAndDisplay() {
        if (!currentMapping.qtyCol) { displayRows = [...reviewRows]; return; }
        displayRows = [...reviewRows].sort((a,b) => {
            let av = parseFloat(String(a[currentMapping.qtyCol]||"0").replace(/[^0-9.-]/g, ''));
            let bv = parseFloat(String(b[currentMapping.qtyCol]||"0").replace(/[^0-9.-]/g, ''));
            if(isNaN(av)) av = 0; if(isNaN(bv)) bv = 0;
            return av - bv;
        });
    }

    function getQtyBackground(qtyVal) {
        if (!currentMapping.qtyCol) return 'white';
        let num = parseFloat(String(qtyVal||"0").replace(/[^0-9.-]/g, ''));
        if(isNaN(num)) num = 0;
        let maxQty = 1;
        for(let row of displayRows){
            let v = parseFloat(String(row[currentMapping.qtyCol]||"0").replace(/[^0-9.-]/g, ''));
            if(!isNaN(v) && v > maxQty) maxQty = v;
        }
        if(maxQty === 0) maxQty = 1;
        let intensity = num / maxQty;
        let r = 255 - Math.floor(intensity * 80);
        let g = 255 - Math.floor(intensity * 40);
        let b = 255;
        return `rgb(${r}, ${g}, ${b})`;
    }

    function renderReviewTable() {
        const thead = document.getElementById('reviewThead'), tbody = document.getElementById('reviewTbody');
        if(!thead || !tbody) return;
        if(!allColumns.length){
            thead.innerHTML = '<tr><th>暂无数据，请导入Excel</th><\/tr>';
            tbody.innerHTML = ''; return;
        }
        if(!currentMapping.isbnCol || !currentMapping.titleCol || !currentMapping.qtyCol){
            thead.innerHTML = '<tr><th>请在上方工具栏选择书号、书名、订数列</th><\/tr>';
            tbody.innerHTML = ''; return;
        }
        const headers = ['书号','书名','订数'];
        thead.innerHTML = '<tr>'+headers.map(h=>`<th>${escapeHtml(h)}</th>`).join('')+'</tr>';
        let html = '';
        for(let idx=0; idx<displayRows.length; idx++){
            const row = displayRows[idx];
            const isbnVal = row[currentMapping.isbnCol] || '';
            const titleVal = row[currentMapping.titleCol] || '';
            const qtyVal = row[currentMapping.qtyCol] || '';
            const bgColor = getQtyBackground(qtyVal);
            const isHighlight = (searchResultsIndices.includes(idx) && currentHighlightRowIdx === idx);
            const rowClass = isHighlight ? 'highlight-row' : '';
            html += `<tr data-row-idx="${idx}" class="${rowClass}" style="background-color:${bgColor};">`;
            html += `<td>${escapeHtml(isbnVal)}</td>`;
            html += `<td>${escapeHtml(titleVal)}</td>`;
            html += `<td>${escapeHtml(qtyVal)}</td>`;
            html += `<\/tr>`;
        }
        tbody.innerHTML = html;
        if(currentHighlightRowIdx !== -1 && tbody.rows[currentHighlightRowIdx]){
            tbody.rows[currentHighlightRowIdx].classList.add('highlight-row');
        }
    }

    function clearAllHighlights() {
        const tbody = document.getElementById('reviewTbody');
        if(!tbody) return;
        for(let i=0; i<tbody.rows.length; i++) tbody.rows[i].classList.remove('highlight-row');
    }

    function highlightRowByIndex(idx) {
        const tbody = document.getElementById('reviewTbody');
        if(tbody && tbody.rows[idx]) tbody.rows[idx].classList.add('highlight-row');
    }

    function searchByIsbn(keyword) {
        const kw = keyword.trim().toLowerCase();
        clearAllHighlights();
        if(!kw){
            lastSearchKeyword = '';
            searchResultsIndices = [];
            currentHighlightRowIdx = -1;
            updateResultPanelNormal();
            return;
        }
        if(!currentMapping.isbnCol){
            showTip('请先选择书号列', true);
            return;
        }
        const results = [];
        for(let i=0; i<displayRows.length; i++){
            let val = String(displayRows[i][currentMapping.isbnCol] || "").toLowerCase();
            if(val.includes(kw)) results.push(i);
        }
        if(results.length === 0){
            showTip(`未找到包含“${keyword}”的书号记录`, true);
            lastSearchKeyword = '';
            searchResultsIndices = [];
            currentHighlightRowIdx = -1;
            updateResultPanelNormal();
            return;
        }
        lastSearchKeyword = kw;
        searchResultsIndices = results;
        currentHighlightRowIdx = results[0];
        highlightRowByIndex(currentHighlightRowIdx);
        const tbody = document.getElementById('reviewTbody');
        if(tbody && tbody.rows[currentHighlightRowIdx]){
            tbody.rows[currentHighlightRowIdx].scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        updateResultPanelNormal();
    }

    function updateResultPanelNormal() {
        const panel = document.getElementById('resultPanel');
        if(!panel) return;
        if(!lastSearchKeyword || searchResultsIndices.length===0){
            panel.innerHTML = '<div class="result-header">🔍 查找结果</div><div style="color:#8ba0bc; padding:4px 8px;">输入书号后按回车或点击查找</div>';
            return;
        }
        let html = `<div class="result-header">🔍 找到 ${searchResultsIndices.length} 条记录</div>`;
        for(let i=0; i<Math.min(searchResultsIndices.length,50); i++){
            const idx = searchResultsIndices[i];
            let preview = `第${idx+1}行: ${String(displayRows[idx][currentMapping.isbnCol]||'').slice(0,50)}`;
            const active = (currentHighlightRowIdx === idx) ? 'active' : '';
            html += `<div class="result-item ${active}" data-idx="${idx}">📍 ${escapeHtml(preview)}</div>`;
        }
        panel.innerHTML = html;
        document.querySelectorAll('#resultPanel .result-item').forEach(el => {
            el.onclick = () => {
                const idx = parseInt(el.dataset.idx);
                if(!isNaN(idx)){
                    clearAllHighlights();
                    currentHighlightRowIdx = idx;
                    highlightRowByIndex(idx);
                    const tbody = document.getElementById('reviewTbody');
                    if(tbody && tbody.rows[idx]) tbody.rows[idx].scrollIntoView({ behavior: 'smooth', block: 'center' });
                    updateResultPanelNormal();
                }
            };
        });
    }

    function clearReviewAll() {
        if(reviewRows.length && confirm("清空所有复核数据？不可恢复")){
            reviewRows = []; displayRows = []; allColumns = [];
            currentMapping = { isbnCol: null, titleCol: null, qtyCol: null };
            lastSearchKeyword = ''; searchResultsIndices = []; currentHighlightRowIdx = -1;
            document.getElementById('isbnColSelect').innerHTML = '<option value="">—请选择—</option>';
            document.getElementById('titleColSelect').innerHTML = '<option value="">—请选择—</option>';
            document.getElementById('qtyColSelect').innerHTML = '<option value="">—请选择—</option>';
            document.getElementById('searchKeywordInput').value = '';
            renderReviewTable();
            updateResultPanelNormal();
            showTip("已清空", false);
        }
    }

    function onColumnMappingChange() {
        currentMapping = {
            isbnCol: document.getElementById('isbnColSelect').value,
            titleCol: document.getElementById('titleColSelect').value,
            qtyCol: document.getElementById('qtyColSelect').value
        };
        if(currentMapping.qtyCol) sortAndDisplay();
        else displayRows = [...reviewRows];
        renderReviewTable();
        lastSearchKeyword = '';
        searchResultsIndices = [];
        currentHighlightRowIdx = -1;
        updateResultPanelNormal();
    }

    function initSearchEvents() {
        const searchInput = document.getElementById('searchKeywordInput');
        const searchBtn = document.getElementById('searchBtn');
        const doSearch = () => {
            const kw = searchInput.value;
            searchByIsbn(kw);
            searchInput.select();
        };
        searchBtn.onclick = doSearch;
        searchInput.onkeypress = (e) => { if(e.key === 'Enter') doSearch(); };
        searchInput.addEventListener('focus', function() { this.select(); });
    }

    // ---------- 多文件对比 (简化但保留框架) ----------
    let baseFileData = null, targetFileItems = [], nextId = 1;
    function parseExcelFileSimple(file) { return parseExcelFileEnhanced(file); }
    function initCompare() { 
        document.getElementById('uploadBaseBtn').onclick = ()=> document.getElementById('baseFileInput').click();
        document.getElementById('baseFileInput').onchange = async (e) => { if(e.target.files[0]){ baseFileData = await parseExcelFileSimple(e.target.files[0]); document.getElementById('baseFileStatus').innerHTML = `✅ ${baseFileData.fileName} (${baseFileData.rows.length}行)`; } };
        document.getElementById('addTargetFileBtn').onclick = () => { showTip("多文件对比功能演示，可自行扩展", false); };
        document.getElementById('batchCompareBtn').onclick = () => { showTip("多文件对比示例，完整版请参考之前代码", false); };
    }

    // ---------- 到货复核 (完整保留并修复布局) ----------
    let orderData = null, arrivalData = null;
    let mappings = [];
    let matchResult = [];
    let orderCandidateStats = [];
    
    async function parseArrivalFileSmart(file) { return parseExcelFileEnhanced(file); }
    async function parseOrderFile(file) { return parseExcelFileEnhanced(file); }
    
    function updateCustomerFilter() {
        if(!orderData) return;
        const custField = '客户名称';
        if(!orderData.cols.includes(custField)) { document.getElementById('customerFilterSelect').innerHTML = '<option value="">— 无客户字段 —</option>'; return; }
        const customers = [...new Set(orderData.rows.map(r => r[custField]).filter(v=>v && v.trim()))];
        let html = '<option value="">— 全部客户 —</option>';
        customers.forEach(c => { html += `<option value="${escapeAttr(c)}">${escapeHtml(c)}</option>`; });
        document.getElementById('customerFilterSelect').innerHTML = html;
    }
    
    function refreshFieldSelects() {
        const orderCols = orderData ? orderData.cols : [];
        const arrivalCols = arrivalData ? arrivalData.cols : [];
        const orderOptions = orderCols.map(c=>`<option value="${escapeAttr(c)}">${escapeHtml(c)}</option>`).join('');
        const arrivalOptions = arrivalCols.map(c=>`<option value="${escapeAttr(c)}">${escapeHtml(c)}</option>`).join('');
        document.getElementById('orderFieldSelect').innerHTML = orderOptions || '<option value="">—无字段—</option>';
        document.getElementById('arrivalFieldSelect').innerHTML = arrivalOptions || '<option value="">—无字段—</option>';
    }
    
    function renderMappings() {
        const container = document.getElementById('mappingTagsContainer');
        if(!container) return;
        if(mappings.length === 0){ container.innerHTML = '<span style="color:#8ba0bc; font-size:0.7rem;">暂无映射，请添加至少一组（书号匹配）</span>'; return; }
        let html = '';
        mappings.forEach((m, idx) => { html += `<div class="tag">${escapeHtml(m.orderField)} ➔ ${escapeHtml(m.arrivalField)} <button data-idx="${idx}" class="removeMappingBtn">✖</button></div>`; });
        container.innerHTML = html;
        document.querySelectorAll('.removeMappingBtn').forEach(btn => { btn.onclick = (e) => { let idx = parseInt(btn.dataset.idx); if(!isNaN(idx)) { mappings.splice(idx,1); renderMappings(); } }; });
    }
    
    function addMapping() {
        const orderField = document.getElementById('orderFieldSelect').value;
        const arrivalField = document.getElementById('arrivalFieldSelect').value;
        if(!orderField || !arrivalField){ showTip("请完整选择字段对"); return; }
        if(mappings.some(m => m.orderField === orderField && m.arrivalField === arrivalField)){ showTip("该映射已存在"); return; }
        mappings.push({ orderField, arrivalField });
        renderMappings();
    }
    
    async function performMatchAndAnalyze() {
        if(!orderData || !arrivalData){ showTip("请先上传订单文件和到货文件"); return; }
        if(mappings.length === 0){ showTip("请至少添加一组字段映射"); return; }
        const selectedCustomer = document.getElementById('customerFilterSelect').value;
        const custField = '客户名称';
        const orderNoField = '馆配需求单名称';
        if(!orderData.cols.includes(custField)){ showTip("订单文件中缺少“客户名称”列"); return; }
        if(!orderData.cols.includes(orderNoField)){ showTip("订单文件中缺少“馆配需求单名称”列"); return; }
        
        const orderMap = new Map();
        for(let row of orderData.rows){
            let keys = mappings.map(m => String(row[m.orderField]||"").trim());
            if(keys.some(k => k === "")) continue;
            let compositeKey = keys.join('|');
            if(!orderMap.has(compositeKey)) orderMap.set(compositeKey, []);
            let cust = row[custField] || "";
            let orderNo = row[orderNoField] || "";
            if(selectedCustomer && cust !== selectedCustomer) continue;
            orderMap.get(compositeKey).push({ customer: cust, orderNo: orderNo });
        }
        
        const orderCountMap = new Map();
        matchResult = [];
        for(let row of arrivalData.rows){
            let keys = mappings.map(m => String(row[m.arrivalField]||"").trim());
            if(keys.some(k => k === "")){ matchResult.push({ arrivalRow: row, matchedOrders: [] }); continue; }
            let compositeKey = keys.join('|');
            let orders = orderMap.get(compositeKey) || [];
            matchResult.push({ arrivalRow: row, matchedOrders: orders.slice() });
            for(let ord of orders){ let key = `${ord.customer}|${ord.orderNo}`; orderCountMap.set(key, (orderCountMap.get(key)||0) + 1); }
        }
        
        let totalEntries = arrivalData.rows.length;
        let candidates = [];
        for(let [key, count] of orderCountMap.entries()){
            let [customer, orderNo] = key.split('|');
            candidates.push({ customer, orderNo, count, confidence: (count / totalEntries * 100).toFixed(1) });
        }
        candidates.sort((a,b) => b.count - a.count);
        orderCandidateStats = candidates;
        
        const analysisWrapper = document.getElementById('analysisWrapper');
        const analysisTbody = document.querySelector('#analysisTable tbody');
        if(candidates.length > 0){
            analysisWrapper.style.display = 'flex';
            analysisTbody.innerHTML = '';
            candidates.forEach((c, idx) => { analysisTbody.innerHTML += `<tr><td style="text-align:center">${idx+1}</td><td>${escapeHtml(c.customer)}</td><td>${escapeHtml(c.orderNo)}</td><td style="text-align:center">${c.count}</td><td style="text-align:center">${c.confidence}%</td></tr>`; });
        } else { analysisWrapper.style.display = 'none'; }
        
        // 渲染匹配详情
        const thead = document.getElementById('matchThead');
        const tbody = document.getElementById('matchTbody');
        if(arrivalData){
            const arrivalCols = arrivalData.cols;
            const headers = [...arrivalCols, "匹配到的订单 (按可能性排序: 客户+馆配需求单名称)"];
            thead.innerHTML = '<tr>'+headers.map(h=>`<th>${escapeHtml(h)}</th>`).join('')+'</tr>';
            const orderCountMapQuick = new Map(); for(let c of orderCandidateStats) orderCountMapQuick.set(`${c.customer}|${c.orderNo}`, c.count);
            let html = '';
            for(let item of matchResult){
                let row = item.arrivalRow;
                let cells = arrivalCols.map(c => `<td>${escapeHtml(row[c]||'')}</td>`);
                let sortedOrders = item.matchedOrders.slice();
                sortedOrders.sort((a,b) => {
                    let countA = orderCountMapQuick.get(`${a.customer}|${a.orderNo}`) || 0;
                    let countB = orderCountMapQuick.get(`${b.customer}|${b.orderNo}`) || 0;
                    if(countA !== countB) return countB - countA;
                    return (a.orderNo).localeCompare(b.orderNo);
                });
                let orderText = sortedOrders.map(o => `${o.customer} ${o.orderNo}`).join("\n");
                let matchCell = `<td class="matched-orders" style="white-space:pre-line;">${escapeHtml(orderText || "无匹配")}</td>`;
                html += '<tr>'+cells.join('')+matchCell+'</tr>';
            }
            tbody.innerHTML = html;
        }
        let matchedCount = matchResult.filter(r => r.matchedOrders.length > 0).length;
        let unmatchedCount = totalEntries - matchedCount;
        document.getElementById('matchStats').innerHTML = `📊 到货总数: ${totalEntries} | ✅ 匹配到至少一个订单: ${matchedCount} | ❌ 完全未匹配: ${unmatchedCount} | 🏆 最可能订单: ${candidates.length>0 ? candidates[0].customer+' '+candidates[0].orderNo : '无'}`;
        document.getElementById('exportMatchBtn').disabled = false;
    }
    
    function exportMatchResult() {
        if(!arrivalData || matchResult.length===0){ showTip("无匹配结果可导出"); return; }
        const wb = XLSX.utils.book_new();
        const arrivalCols = arrivalData.cols;
        const headers = [...arrivalCols, "匹配到的订单 (按可能性排序)"];
        const detailData = [headers];
        const orderCountMap = new Map(); for(let c of orderCandidateStats) orderCountMap.set(`${c.customer}|${c.orderNo}`, c.count);
        for(let item of matchResult){
            let row = item.arrivalRow;
            let rowVals = arrivalCols.map(c => row[c]||"");
            let sortedOrders = item.matchedOrders.slice();
            sortedOrders.sort((a,b) => {
                let countA = orderCountMap.get(`${a.customer}|${a.orderNo}`) || 0;
                let countB = orderCountMap.get(`${b.customer}|${b.orderNo}`) || 0;
                if(countA !== countB) return countB - countA;
                return (a.orderNo).localeCompare(b.orderNo);
            });
            rowVals.push(sortedOrders.map(o => `${o.customer} ${o.orderNo}`).join("\n"));
            detailData.push(rowVals);
        }
        XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(detailData), "匹配详情");
        const summaryData = [["客户名称", "馆配需求单名称", "匹配条目数", "置信度"]];
        for(let c of orderCandidateStats) summaryData.push([c.customer, c.orderNo, c.count, c.confidence+"%"]);
        XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(summaryData), "订单归属分析");
        XLSX.writeFile(wb, `到货匹配分析_${new Date().toISOString().slice(0,19).replace(/:/g,'-')}.xlsx`);
        showTip("导出成功", false);
    }
    
    function initArrival() {
        const orderFileInput = document.getElementById('orderFileInput');
        const uploadOrderBtn = document.getElementById('uploadOrderBtn');
        uploadOrderBtn.onclick = () => orderFileInput.click();
        orderFileInput.onchange = async (e) => { if(e.target.files[0]){ try{ orderData = await parseOrderFile(e.target.files[0]); document.getElementById('orderFileStatus').innerHTML = `✅ ${orderData.fileName} (${orderData.rows.length}行) <span style="cursor:pointer; color:#b91c1c;" id="clearOrderStatusBtn">🗑 清空</span>`; document.getElementById('clearOrderStatusBtn').onclick = () => { orderData = null; document.getElementById('orderFileStatus').innerHTML = '未加载'; orderFileInput.value = ''; refreshFieldSelects(); }; updateCustomerFilter(); refreshFieldSelects(); } catch(err){ showTip(`订单文件加载失败: ${err}`); } } };
        const arrivalFileInput = document.getElementById('arrivalFileInput');
        const uploadArrivalBtn = document.getElementById('uploadArrivalBtn');
        uploadArrivalBtn.onclick = () => arrivalFileInput.click();
        arrivalFileInput.onchange = async (e) => { if(e.target.files[0]){ try{ arrivalData = await parseArrivalFileSmart(e.target.files[0]); document.getElementById('arrivalFileStatus').innerHTML = `✅ ${arrivalData.fileName} (${arrivalData.rows.length}行) <span style="cursor:pointer; color:#b91c1c;" id="clearArrivalStatusBtn">🗑 清空</span>`; document.getElementById('clearArrivalStatusBtn').onclick = () => { arrivalData = null; document.getElementById('arrivalFileStatus').innerHTML = '未加载'; arrivalFileInput.value = ''; refreshFieldSelects(); }; refreshFieldSelects(); } catch(err){ showTip(`到货文件加载失败: ${err}`); } } };
        document.getElementById('addMappingBtn').onclick = addMapping;
        document.getElementById('matchBtn').onclick = performMatchAndAnalyze;
        document.getElementById('exportMatchBtn').onclick = exportMatchResult;
        refreshFieldSelects(); renderMappings();
    }
    
    // 模式切换
    const radioNormal = document.querySelector('input[value="normal"]');
    const radioCompare = document.querySelector('input[value="compare"]');
    const radioArrival = document.querySelector('input[value="arrival"]');
    const normalPanel = document.getElementById('normalPanel');
    const comparePanel = document.getElementById('comparePanel');
    const arrivalPanel = document.getElementById('arrivalPanel');
    const modeTipSpan = document.getElementById('modeTip');
    function switchMode(mode){
        normalPanel.classList.add('panel-hidden');
        comparePanel.classList.add('panel-hidden');
        arrivalPanel.classList.add('panel-hidden');
        if(mode === 'normal'){ normalPanel.classList.remove('panel-hidden'); modeTipSpan.innerText = '普通模式：导入Excel，自动匹配三列，按回车或按钮查找，未找到弹窗提示'; }
        else if(mode === 'compare'){ comparePanel.classList.remove('panel-hidden'); modeTipSpan.innerText = '多文件对比模式'; }
        else if(mode === 'arrival'){ arrivalPanel.classList.remove('panel-hidden'); modeTipSpan.innerText = '到货复核模式：上传订单和到货文件，自定义字段映射，分析整批到货最可能的订单归属'; }
    }
    radioNormal.onchange = () => switchMode('normal');
    radioCompare.onchange = () => switchMode('compare');
    radioArrival.onchange = () => switchMode('arrival');
    
    function startup(){
        renderReviewTable();
        document.getElementById('importExcelBtn').onclick = importExcelReview;
        document.getElementById('clearReviewBtn').onclick = clearReviewAll;
        document.getElementById('isbnColSelect').onchange = onColumnMappingChange;
        document.getElementById('titleColSelect').onchange = onColumnMappingChange;
        document.getElementById('qtyColSelect').onchange = onColumnMappingChange;
        initSearchEvents();
        initCompare();
        initArrival();
        switchMode('normal');
    }
    startup();
})();
</script>
</body>
</html>