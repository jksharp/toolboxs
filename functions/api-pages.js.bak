// ✅ 获取页面列表
export async function onRequestGet(context) {
  try {
    const { MY_KV } = context.env;
    const data = await MY_KV.get("page-list");
    return Response.json(data ? JSON.parse(data) : []);
  } catch (e) {
    return Response.json([]);
  }
}

// ✅ 创建/更新页面
export async function onRequestPost(context) {
  try {
    const { MY_KV } = context.env;
    const body = await context.request.json();
    const { id, name, desc, icon, html } = body;

    if (!id || !name || !html) {
      return Response.json({ ok: 0, msg: "缺少参数" });
    }

    await MY_KV.put(`page-${id}`, html);

    const listData = await MY_KV.get("page-list");
    const list = listData ? JSON.parse(listData) : [];

    const index = list.findIndex(item => item.id === id);
    if (index >= 0) {
      list[index] = { id, name, desc, icon };
    } else {
      list.push({ id, name, desc, icon });
    }

    await MY_KV.put("page-list", JSON.stringify(list));
    return Response.json({ ok: 1 });
  } catch (e) {
    return Response.json({ ok: 0, msg: e.message });
  }
}

// ✅ 删除页面
export async function onRequestDelete(context) {
  try {
    const { MY_KV } = context.env;
    const { id } = await context.request.json();

    await MY_KV.delete(`page-${id}`);

    const listData = await MY_KV.get("page-list");
    const list = listData ? JSON.parse(listData) : [];
    const newList = list.filter(item => item.id !== id);

    await MY_KV.put("page-list", JSON.stringify(newList));
    return Response.json({ ok: 1 });
  } catch (e) {
    return Response.json({ ok: 0 });
  }
}