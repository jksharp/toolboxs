// 获取 Gist 列表 / 获取单个 Gist / 备份 Excel
export async function onRequestGet(context) {
  try {
    const { MY_KV } = context.env;
    const url = new URL(context.request.url);
    const act = url.searchParams.get('act');

    // 备份成 Excel
    if (act === 'backup') {
      const { keys } = await MY_KV.list({ prefix: 'gist:' });
      const rows = [['ID', '标题', '创建时间', '内容']];
      for (const key of keys) {
        const d = await MY_KV.get(key.name, 'json');
        rows.push([
          key.name.replace('gist:', ''),
          d.title.replace(/,/g, '，'),
          d.time,
          d.content.replace(/\n/g, ' ').replace(/,/g, '，')
        ]);
      }
      return new Response(rows.map(e => e.join(',')).join('\n'), {
        headers: {
          'Content-Type': 'text/csv; charset=utf-8',
          'Content-Disposition': 'attachment; filename=gist-backup.csv'
        }
      });
    }

    // 获取单个
    const id = url.searchParams.get('id');
    if (id) {
      const data = await MY_KV.get(`gist:${id}`, 'json');
      return Response.json(data || null);
    }

    // 获取全部列表
    const { keys } = await MY_KV.list({ prefix: 'gist:' });
    const list = [];
    for (const key of keys) {
      const data = await MY_KV.get(key.name, 'json');
      list.push({
        id: key.name.replace('gist:', ''),
        title: data.title,
        time: data.time
      });
    }
    return Response.json(list);
  } catch (e) {
    return Response.json([]);
  }
}

// 创建 Gist
export async function onRequestPost(context) {
  try {
    const { MY_KV } = context.env;
    const body = await context.request.json();
    const id = Math.random().toString(36).substring(2, 8);
    const time = new Date().toLocaleString();
    await MY_KV.put(`gist:${id}`, JSON.stringify({
      title: body.title,
      content: body.content,
      time
    }));
    return Response.json({ id });
  } catch (e) {
    return Response.json({ error: 'error' });
  }
}